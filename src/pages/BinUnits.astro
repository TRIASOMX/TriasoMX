---
import CustomBins from "../components/BinUnits/CustomBins.astro";
import IntroSection from "../components/BinUnits/IntroSection.astro";
import Layout from "../layouts/Layout.astro";
import IntegrateControl from "../components/BinUnits/IntegrateControl.astro";
import BinGallery from "../components/BinUnits/BinGallery.astro";
import BinSelector from "../components/BinUnits/BinSelector";
import BinPlanosSection from "../components/BinUnits/BinPlanosSection";
import CardSectionResponsive from "../components/unitComponents/CardSectionResponsive.astro";
import AcordeonItem from "../components/unitComponents/AcordeonItem";
import binUnit1 from "../assets/images/BinUnits/binUnit1.webp";
import OSectionBin from "../components/BinUnits/OSectionBin.astro";
import { Image } from "astro:assets";
import Whatsbtn from "../components/unitComponents/Whatsbtn.astro";
---

<Layout title="Bin Units">
  <IntroSection />

  <!-- Dropdowns -->
  <section>
    <div
      class="w-full max-w-7xl px-8 mx-auto grid grid-cols-1 md:grid-cols-5 md:gap-10 items-start justify-center mb-5"
    >
      <div class="col-span-2 flex justify-start md:justify-center">
        <Image
          src={binUnit1}
          alt="Precision Dosing System in action"
          class="w-3/4 md:w-full"
        />
      </div>
      <div class="col-span-3 flex flex-col items-start h-full justify-center">
        <div class="w-full flex flex-col gap-3 md:gap-6">
          <AcordeonItem
            client:only
            title="Sensores de alta precisión"
            content="Los sensores integrados controlan los niveles de material en tiempo real, lo que permite un control preciso de las cantidades dosificadas y evita desbordamientos o faltas de material."
          />
          <AcordeonItem
            client:only
            title="Dosificación ajustable"
            content="El sistema permite a los operadores ajustar el caudal, lo que permite procesar una amplia variedad de materiales, desde áridos finos hasta rocas de mayor tamaño o arena."
          />
          <AcordeonItem
            client:only
            title="Distribución constante del material"
            content="Garantiza una dosificación uniforme para mantener una mezcla equilibrada en las operaciones posteriores, como los procesos de mezcla o trituración."
          />
          <AcordeonItem
            client:only
            title="Controles automatizados"
            content="Equipado con controladores lógicos programables (PLC), el sistema puede automatizarse para ofrecer un rendimiento constante y repetible en diferentes proyectos."
          />
          <AcordeonItem
            client:only
            title="Mecanismo anti-obstrucción"
            content="Las rampas y compuertas especialmente diseñadas minimizan el riesgo de atascos, lo que garantiza un flujo de material fluido e ininterrumpido."
          />
          <AcordeonItem
            client:only
            title="Operación de bajo consumo energético"
            content="Diseñado para optimizar el consumo de energía, reduciendo los costos operativos sin dejar de ofrecer un alto rendimiento."
          />
        </div>
      </div>
    </div>
  </section>



  <!-- OS -->
  <div
    class="w-full bg-[#1e1e1e] text-grisSubP text-base md:text-lg my-20 max-w-7xl mx-auto px-8 rounded-2xl"
  >
    <details class="mx-auto px-8 group">
      <summary
        class="relative flex justify-between items-center cursor-pointer list-none"
      >
        <h1 class="text-white font-bold text-2xl md:text-3xl">
          Especificaciones y características
        </h1>
        <svg
          class="transition-transform duration-300 group-open:rotate-180 ml-auto"
          width="64"
          height="64"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
            id="SVGRepo_tracerCarrier"
            stroke-linecap="round"
            stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
            <path
              d="M5.70711 9.71069C5.31658 10.1012 5.31658 10.7344 5.70711 11.1249L10.5993 16.0123C11.3805 16.7927 12.6463 16.7924 13.4271 16.0117L18.3174 11.1213C18.708 10.7308 18.708 10.0976 18.3174 9.70708C17.9269 9.31655 17.2937 9.31655 16.9032 9.70708L12.7176 13.8927C12.3271 14.2833 11.6939 14.2832 11.3034 13.8927L7.12132 9.71069C6.7308 9.32016 6.09763 9.32016 5.70711 9.71069Z"
              fill="white"></path>
          </g></svg
        >
      </summary>

      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 justify-center max-w-7xl mx-auto pt-5 gap-5"
      >
        <div class="pb-5">
          <p>
            Dimensiones y sistemas de dosificación de agregados que cumplen con
            las regulaciones de construcción
            <ul class="list-disc ml-6">
              <li>SEMARNAT</li>
              <li>SCT</li>
              <li>NOM-001-SEDE</li>
            </ul>
            <br />
            Fabricadas con acero de alta resistencia para soportar cargas pesadas
            y evitar deformaciones en condiciones de trabajo exigentes.
            <br />
            <br />
            Diseñadas para un descargue rápido y fluido, manteniendo un flujo continuo
            de operación y reduciendo al mínimo los tiempos muertos.
          </p>
        </div>
        <div>
          <p>
            Equipos de alta calidad diseñados para larga vida útil y producción
            eficiente de mezcla asfáltica. Con estructuras de acero reforzado e
            integración de sistemas de vibración, nuestras unidades de tolvas
            garantizan un flujo constante de agregados, mínima obstrucción y
            menor desgaste. Diseñadas para operación continua, ofrecen un
            desempeño confiable y estable, con bajo mantenimiento, incluso en
            las condiciones más exigentes de obra.
            <br />
            <br />
            Equipadas con mecanismos de dosificación de agregados de control preciso,
            aseguran una entrega exacta y uniforme del material durante todo el proceso
            de producción.
          </p>
        </div>
      </div>
    </details>
  </div>

  <CustomBins />
  <BinSelector client:only />

  <!-- <section>
    <div
      class="max-w-7xl mx-auto px-8 flex flex-col justify-center items-center py-5"
    >
      <div>
        <h1 class="text-2xl lg:text-3xl md:text-3xl font-bold text-black">
          La durabilidad no es un extra, es un requisito.
        </h1>
      </div>
      <div class="flex flex-col justify-center items-center">
        <p class="text-[#393939]">
          Estricto control de calidad para una larga vida útil de nuestros
          equipos.
        </p>
        <p class="text-[#393939]">
          Conocemos las condiciones industriales de trabajo y la abrasividad del
          manejo de materiales.
        </p>
      </div>
    </div>

    <div class="w-full flex justify-center max-w-7xl px-8 mx-auto">
      <SmartVideo
        client:visible
        src="/Videos/Webm/tolvasVideo.webm"
        poster={poster1.src}
        isLoop={false}
        autoplayOnMobile={false}
      />
    </div>
  </section> -->
  <div class="pt-10">
    <OSectionBin />
  </div>

  <BinGallery />
  <section class="">
    <div
      class="bg-[#2b2b2b] lg:h-[50vh] md:h-[50vh] flex items-center bg-[url(/triasoLogo.webp)] bg-center bg-no-repeat relative"
    >
      <div class="absolute inset-0 bg-[#000000]/70"></div>
      <div class="max-w-7xl mx-auto px-8 space-y-5 relative">
        <div class="pt-5">
          <h1 class="text-4xl font-bold text-white">
            ¿Indeciso sobre el equipo ideal para su proyecto?
          </h1>
        </div>

        <div
          class="w-full flex flex-col justify-center pb-5 lg:justify-around md:justify-around items-center lg:flex-row relative"
        >
          <div class="">
            <p class="text-white">
              La compra de una planta de asfalto es una gran inversión, y la
              base de un negocio de producción de mezcla asfáltica. Compre
              inteligentemente y con criterio.
            </p>
            <p class="text-white">
              Podemos asesorarlo de forma transparente en la inversión de su
              planta de asfalto, ayudándolo a elegir la opción más adecuada.
            </p>
          </div>
          <div
            class="w-full flex flex-col justify-center items-center gap-4 mb-5 lg:ml-28"
          >
            <!-- Botón 1 -->
            <Whatsbtn />

            <a
              href="/Contact"
              aria-label="Button to request a quote"
              class="bg-blueSecondary border-white border border- text-white text-sm md:text-lg rounded-full w-full py-2 flex items-center justify-center gap-2 shadow-md hover:bg-[#0044A4]/80"
            >
              Solicitar una cotización
              <svg
                width="24px"
                height="24px"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                color="#FFFFFF"
              >
                <!-- Icono del segundo botón (opcional) -->
                <path
                  d="M5 12H19M19 12L12 5M19 12L12 19"
                  stroke="#FFFFFF"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <BinPlanosSection client:only />
  <!-- <CardSection /> -->
  <CardSectionResponsive />
</Layout>
