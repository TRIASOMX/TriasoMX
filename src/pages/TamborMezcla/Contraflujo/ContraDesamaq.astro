---
import Layout from "../../../layouts/Layout.astro";
import OdometerDrum from "../../../components/DrumMixers/OdometerDrum";
import DrumMixPlanos from "../../../components/DrumMixers/DrumMixPlanos";
import HeroComponent from "../../../components/unitComponents/HeroComponent.astro";
import hero1 from "../../../../public/fabricaBG.webp";
import DropdownComponent from "../../../components/unitComponents/DropdownComponent.astro";
import OsDrumSection from "../../../components/DrumMixers/OsDrumSection.astro";
import StackedInfoCards from "../../../components/unitComponents/StackedInfoCards.astro";
import HotspotSection from "../../../components/DrumMixers/HotspotSection.astro";
import SliderTambores from "../../../components/DrumMixers/SliderTambores.astro";
import QuemadorSeccion from "../../../components/DrumMixers/QuemadorSeccion.astro";
import BolsasSeccion from "../../../components/DrumMixers/BolsasSeccion.astro";
import hero2 from "../../../assets/images/DrumMixers/Gallery/DM1.webp";

const cards = [
    {
        title: "La planta de asfalto de contraflujo más equipada, más robusta, más moderna de Latinoamérica.",
        text: "",
        bg: "#d13c3c",
        textColor: "#ffffff",
    },
    {
        title: "Con una configuración ideal para trabajo pesado y condiciones cariables la planta de asfalto está completamente equipada.",
        text: "",
        bg: "#14427c",
        textColor: "#ffffff",
    },
    {
        title: "Operación total manual o automática para un control eficiente y sencillo del equipo, con menor necesidad de intervención del operador.",
        text: "",
        bg: "#00840d",
        textColor: "#ffffff",
    },
    {
        title: "Equipos auxiliares y componentes sobredimensionados y de gran volumen, permitiendo operaciones a gran escala, con total estabilidad, continuas, intensivas y prolongadas, sin paros, con mínima intervención del operador",
        text: "",
        bg: "#6b97c6",
        textColor: "#ffffff",
    },
];
---

<Layout title="Tambor de contraflujo">
    <div class="mt-10">
        <HeroComponent
            title="Tambor de Contraflujo Desamaq"
            image={hero1.src}
            imageAlt="Tambor de Contraflujo Desamaq"
            altImage={hero2.src}
            descAltImage="Tambor de Contraflujo Desamaq"
        />
    </div>
    <div class="bg-[#1e1e1e]">
        <div class="max-w-7xl mx-auto px-8 space-y-10 py-10">
            <div class="flex flex-row justify-center items-center gap-10">
                <a
                    class="underline font-bold text-white text-xl lg:text-2xl"
                    href="/TamborMezcla/Contraflujo/ContraDesamaq">Desamaq</a
                >
                <a class="font-thin text-white text-xl lg:text-2xl" href="/TamborMezcla/Contraflujo/ContraPlus"
                    >Plus</a
                >
                <a
                    class="font-thin text-white text-xl lg:text-2xl"
                    href="/DrumMixers">Pro +</a
                >
            </div>

            <div class="flex justify-center items-center text-center">
                <h1 class="font-semibold text-white text-lg lg:text-xl">
                    Ideal para contratistas que están iniciando con proyectos
                    pequeños y buscan no depender de otros productores de
                    mezcla. Ideal para una operación ecológica evitando multas y
                    paros costosos por contaminación, con bajo consumo de
                    combustible ofreciendo una excelente relación
                    costo-beneficio en su categoría.
                </h1>
            </div>

            <div
                class="flex flex-col lg:flex-row md:flex-row justify-center items-center gap-5"
            >
                <div
                    class="bg-black rounded-2xl w-36 text-center transition-all duration-300 hover:bg-white"
                >
                    <p class="py-3 font-semibold text-white hover:text-black">
                        Cotizar
                    </p>
                </div>
                <div
                    class="bg-white rounded-2xl w-36 text-center transition-all duration-300 hover:bg-black"
                >
                    <p class="py-3 font-semibold text-black hover:text-white">
                        Comparar
                    </p>
                </div>
            </div>
        </div>
    </div>
    <OdometerDrum client:only />

    <div>
        <DropdownComponent
            title="El equipo ideal para una inversión más económica, el modelo para una operación manual, es el equipo más económico del mercado, sin comprometer rendimiento."
        >
            <p>
                Triaso® ofrece una solución práctica y confiable para la
                producción continua de mezcla asfáltica, con tambores
                mezcladores que integran secado, mezclado, captura de finos en
                la casa de bolsas y su reincorporación en un solo chasis
                diseñado para trabajo pesado, con opción de tolvas montadas. Su
                diseño está orientado a una operación estable, garantizando
                eficiencia operativa, tranquilidad de su cliente y durabilidad
                del pavimento en cualquier proyecto.
            </p>
        </DropdownComponent>
    </div>
    <OsDrumSection />

    <div class="bg-[#1e1e1e] flex flex-col justify-center items-center px-8">
        <div class="flex flex-col justify-center items-center pb-10">
            <h1
                class="text-white font-bold text-3xl text-center lg:text-start md:text-start"
            >
                Para evitar desperdicios, robos y mala operación de su planta de
                asfalto
            </h1>
            <p class="text-white text-center lg:text-start md:text-start">
                Paro total con un solo botón desde su celular
            </p>
        </div>
    </div>

    <div class="mt-5">
        <StackedInfoCards
            cards={cards}
            mainTitle="Su mejor negocio comienza con nosotros"
            mainDescription="Los contratistas que nos conocen prefieren Triaso sobre otras marcas por nuestra alta calidad, confiabilidad y precios."
        />
    </div>

    <HotspotSection />

    <div class="max-w-7xl mx-auto px-8">
        <SliderTambores />
    </div>

    <QuemadorSeccion />

    <BolsasSeccion />

    <DrumMixPlanos client:only />
</Layout>
