---
import Hero from '../components/AsphaltPlants/Hero.astro';
import Layout from '../layouts/Layout.astro';
import MainSection from '../components/AsphaltPlants/MainSection.astro'
import Hero1 from '../assets/images/AsphaltPlant/NewBanner.webp';
---
<Layout title="Plantas de asfalto">
  <head>
    <!-- Preload para la imagen Hero -->
    <link 
      rel="preload" 
      href={Hero1.src} 
      as="image" 
      imagesrcset={`
        ${Hero1.src}?width=400 1200w,
        ${Hero1.src}?width=800 800w,
        ${Hero1.src}?width=1200 1200w
      `}
      imagesizes="100vw"
      fetchpriority="high"
    />
  </head>

  <Hero 
    heroImage={Hero1} 
    title="PLANTAS DE ASFALTO" 
    altText="Modern asphalt production plant with heavy machinery" 
  />
    <MainSection />
  
</Layout>