---
import Card from "../unitComponents/Card.astro";
import img1 from "../../assets/images/ColdMix/PlaMFDscC.webp";
import img2 from "../../assets/images/ColdMix/CMWhats.webp";
import { Image } from "astro:assets";
import StackedInfoCards from "../unitComponents/StackedInfoCards.astro";

const cards = [
    {
        title: "Producción de mezcla en frío bajo demanda según se requiera en el sitio, reduciendo la dependencia de proveedores externos. Minimizando retrasos y permitiendo preparar y aplicar la mezcla de inmediato.",
        text: "",
        bg: "#d13c3c",
        textColor: "#ffffff",
    },
    {
        title: "Costos de operación bajos sin quemadores ni sistemas de aceite térmico, las plantas de mezclado en frío reducen significativamente el consumo de combustible y los costos de mantenimiento.",
        text: "",
        bg: "#14427c",
        textColor: "#ffffff",
    },
    {
        title: "Soluciones de asfalto ecológicas las plantas de mezclado en frío operan a temperaturas bajas. Esto la convierte en una solución práctica y ambientalmente responsable.",
        text: "",
        bg: "#00840d",
        textColor: "#ffffff",
    },
    {
        title: "Diseñadas para movilidad e instalación sencilla, configuraciones compactas y móviles permitiendo su transporte e instalación sencilla en cualquier sitio. Con requisitos mínimos de instalación, son ideales para proyectos de corta duración o para reubicaciones rápidas de manera eficiente.",
        text: "",
        bg: "#6b97c6",
        textColor: "#ffffff",
    },
];
