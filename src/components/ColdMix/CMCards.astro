  <div class="">
    <StackedInfoCards
    cards={cards}
    mainTitle="Operación estable, continua, intensiva y prolongada"
    mainDescription="Sin paros, a gran escala, con una configuración ideal para trabajo pesado y condiciones variables, la planta está completamente equipada."
/>
</div>
</section>
