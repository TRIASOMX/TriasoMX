---
import { Image } from "astro:assets";
import img2 from "../../assets/images/ColdMix/pugmill2.webp";
import img3 from "../../assets/images/ColdMix/pugmill3.webp";
import poster1 from "../../../public/Videos/Webm/Posters/9.webp";
import SliderCold from "./SliderCold.astro";
import GallerySlider from "../unitComponents/GallerySlider";
import TwoColumnSection from "../unitComponents/TwoColumnSection.astro";
import AcordeonItem from "../unitComponents/AcordeonItem";
import binUnit1 from "../../assets/images/BinUnits/binUnit1.webp";
import Tred from "../../assets/images/AsphaltStorage/redT.webp";
import CMHigh from "../../assets/images/ColdMix/CMHigh.webp";
import PlaMFDscC1 from "../../assets/images/ColdMix/PlaMFDscC1.webp";
import g1 from "../../assets/images/ColdMix/GallerySlider/CMG1.webp";
import g2 from "../../assets/images/ColdMix/GallerySlider/CMG2.webp";
import g3 from "../../assets/images/ColdMix/GallerySlider/CMG3.webp";
import g4 from "../../assets/images/ColdMix/GallerySlider/CMG4.webp";
import g5 from "../../assets/images/ColdMix/GallerySlider/CMG5.webp";
import g6 from "../../assets/images/ColdMix/GallerySlider/CMG6.webp";
import g7 from "../../assets/images/ColdMix/GallerySlider/CMG7.webp";
import g8 from "../../assets/images/ColdMix/GallerySlider/CMG8.webp";
import SmartVideo from "../unitComponents/SmartVideo";
import Whatsbtn from "../unitComponents/Whatsbtn.astro";
import DropdownComponent from "../unitComponents/DropdownComponent.astro";
import Card from "../unitComponents/Card.astro";

const binSlides = [
  {
    image: g1.src,
    caption:
      "Cold mixing plant, stabilizer, up to 200 Tmph, with floor discharge",
  },
  {
    image: g2.src,
    caption:
      "Cold mixing plant, stabilizer, up to 200 Tmph, with floor discharge",
  },
  {
    image: g3.src,
    caption:
      "Cold mixing plant, stabilizer, up to 200 Tmph, with floor discharge",
  },
  {
    image: g4.src,
    caption:
      "Cold mixing plant, stabilizer, up to 200 Tmph, with floor discharge",
  },
  {
    image: g5.src,
    caption:
      "Cold mixing plant, stabilizer, up to 300 Tmph, with elevated discharge",
  },
  {
    image: g6.src,
    caption:
      "Cold mixing plant, stabilizer, up to 300 Tmph, with elevated discharge",
  },
  {
    image: g7.src,
    caption:
      "Cold mixing plant, stabilizer, up to 300 Tmph, with elevated discharge",
  },
  {
    image: g8.src,
    caption:
      "Cold mixing plant, stabilizer, up to 300 Tmph, with elevated discharge",
  },
];
---

<!-- Sección sliders -->
<section>
  <SliderCold />
</section>

<div class="w-full font-bold flex flex-col justify-center items-center">
  <div
    class="max-w-[2400px] grid grid-cols-1 md:grid-cols-5 gap-10 items-start justify-center"
  >
    <div class="col-span-2 flex justify-start md:justify-center">
      <Image
        src={binUnit1}
        alt="Precision Dosing Systems in Cold Mix Asphalt Plants"
        class="w-3/4 md:w-full"
      />
    </div>
    <div
      class="col-span-3 flex flex-col items-start h-full justify-center lg:pr-52 pr-8 md:pl-0 pl-8"
    >
      <div class="w-full flex flex-col gap-3 md:gap-6 pr-5 md:pr-10">
        <AcordeonItem
          client:only
          title="Sensores de alta precisión"
          content="El sistema puede equiparse con sensores opcionales que monitorean los niveles de material en tiempo real, permitiendo un control preciso de la dosificación y evitando derrames o faltantes."
        />
        <AcordeonItem
          client:only
          title="Dosificación ajustable"
          content="Los operadores pueden modificar la dosificación para adaptarse a una amplia gama de materiales, desde agregados finos hasta rocas de mayor tamaño o arena."
        />
        <AcordeonItem
          client:only
          title="Distribución constante del material"
          content="Garantiza una dosificación pareja para mantener una mezcla equilibrada en procesos posteriores, como mezclado o trituración."
        />
        <AcordeonItem
          client:only
          title="Controles automatizados"
          content="Equipado con controladores lógicos programables (PLC) y con nuestra versión más reciente, Triaso 8.0, el sistema puede automatizarse completamente para ofrecer un desempeño constante y repetible en distintos proyectos."
        />
        <AcordeonItem
          client:only
          title="Mecanismo anti-obstrucción"
          content="Los chutes y compuertas están diseñados especialmente para minimizan el riesgo de bloqueos, asegurando un flujo de material continuo y sin interrupciones."
        />
        <AcordeonItem
          client:only
          title="Operación de bajo consumo energético"
          content="Diseñado para optimizar el consumo de energía, reduciendo los costos operativos sin comprometer el rendimiento."
        />
      </div><br />
      <p class="text-base md:text-lg font-thin text-grisT text-justify">
        Estas características convierten nuestros sistemas de dosificación en un
        componente esencial para proyectos que requieren un manejo de materiales
        preciso y eficiente.
      </p>
    </div>
  </div>

  <TwoColumnSection
    leftBg="bg-redBg"
    rightBg="bg-blueMain"
    imageSrc={Tred.src}
    imageAlt="Red T icon"
    imageWidth="150px"
  >
    <div slot="left" class="flex flex-col justify-center gap-3">
      <h1 class="text-xl md:text-2xl">
        Configuraciones para cualquier poyecto y necesidas
      </h1>
      <p class="text-sm md:text-lg">
        Nuestras plantas de mezcla en frío pueden equiparse con detectores de
        flujo, vibradores, divisores de tolvas, indicadores de nivel,
        extensiones y rejillas grizzly. Estas opciones permiten adaptar la
        planta a distintos requisitos de manejo de materiales, garantizando
        eficiencia y confiabilidad en cualquier proyecto.
      </p>
    </div>
    <div slot="right" class="flex flex-col justify-center lg:pl-3 md:pl-5">
      <h1 class="text-xl md:text-2xl">Servicio al cliente 24/7</h1>
      <div class="text-sm lg:text-lg md:text-lg">
        <p>
          Sabemos que la operación de muchos equipos depende de la confiabilidad
          de su planta de asfalto, nuestro equipo está disponible las 24 horas,
          listo para ayudarte en cualquier momento, incluso fines de semana y
          días festivos.
        </p>
      </div>

      <div>
        <Whatsbtn />
      </div>
    </div>
  </TwoColumnSection>

  <div class="w-full md:w-3/4 max-w-7xl mx-auto px-8 py-10">
    <SmartVideo
      client:visible
      src="/Videos/Webm/PGMC.webm"
      poster={img2.src}
      isLoop={false}
      autoplayOnMobile={false}
    />
  </div>

  <div>
    <div>
      <DropdownComponent
        title="Descubra la ingeniería detrás de nuestro pugmill"
      >
        <div class="flex flex-col space-y-5">
          <p>
            El pugmill es un componente fundamental en las plantas de mezcla en
            frío, diseñado eficientemente para hacer una variedad de
            mezclas—incluyendo agregados y emulsión asfáltica. Su fabricación
            extra-reforzada, de trabajo pesado garantiza una operación estable y
            un rendimiento confiable con el paso del tiempo.
          </p>
          <p>
            El proceso de mezclado del pugmill permite una homogeneización
            precisa de los agregados, siendo perfecto para una amplia gama de
            aplicaciones que requieren una mezcla en frío de alta calidad. Con
            un mantenimiento sencillo y un diseño fácil de operar, nuestro
            pugmill ofrece una vida prolongada y económica incluso en entornos
            de trabajo exigentes, no es solo una promesa, lo respaldamos con dos
            años de garantía, la más alta en el mercado.
          </p>
        </div>
      </DropdownComponent>
    </div>
  </div>

  <!-- cards -->
  <div class="max-w-7xl mx-auto px-8">
    <div
      class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 justify-between items-stretch font-bold mt-6"
    >
      <Card>
        <div>
          <Image
            src="https://placehold.co/600x400/png"
            alt="Cold mix plant with a plugmill mixer"
            width={600}
            height={400}
          />
        </div>
        <details class="group">
