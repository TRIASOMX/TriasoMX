---
import CMG5 from "../../assets/images/ColdMix/GallerySlider/CMG5.webp";
import HeroCold from "../../assets/images/ColdMix/HeroColdMix.webp";
import { Image } from "astro:assets";
import SmartVideo from "../unitComponents/SmartVideo";
---

<div class="w-full flex flex-col justify-center">
  <div class="w-full pt-14 lg:pt-0 md:pt-0 flex justify-center">
    <Image src={HeroCold} alt="Hero from ColdMix" width={2000} />
  </div>
  <div
    class="w-full max-w-7xl mx-auto px-8 flex flex-col justify-center items-center font-bold"
  >
    <div
      class="text-start self-start lg:text-end md:text-end lg:self-end md:self-end lg:w-1/2 md:w-1/2 mt-5 lg:mt-24"
    >
      <h1 class="text-2xl md:text-3xl">COLD MIX ASPHALT PLANTS</h1><br />
      <div class="h-0.5 bg-blueMain w-full"></div>
    </div>

    <div class="my-6">
      <p class="text-[#393939] text-sm lg:text-lg md:text-lg">
        Triaso® cold mix plants are specifically engineered to produce aggregate
        mixtures without applying heat. Using a robust pugmill mixer, these
        plants blend unheated aggregates with asphalt emulsion or other liquid
        binders to deliver a uniform,

        <br /><br />
        Their capability to handle different aggregate types makes them well-suited
        for patching, road maintenance, and small-scale paving applications.
      </p>
    </div>

    <div class="w-full flex justify-center">
      <div
        class="max-w-7xl bg-grisT rounded-xl p-8 grid grid-cols-1 md:grid-cols-2 items-center justify-center gap-10"
      >
        <div class="w-full text-white flex flex-col gap-3 justify-center">
          <h1 class="text-3xl md:text-4xl font-bold">
            Cold Mixing = Eco-Friendly Mix
          </h1>
          <div class="w-full h-0.5 bg-white"></div>
          <p class="text-sm lg:text-lg md:text-lg">
            Designed for efficiency and flexibility, quick setup, and minimal
            maintenance, cold mix plants provide a reliable solution for
            contractors, municipalities, and remote projects — delivering
            consistent aggregate mix production whenever required, with the ease
            of not needing to heat the aggregates.
          </p>
        </div>
        <div
          class="w-full flex justify-center rounded-2xl overflow-hidden self-center"
        >
          <SmartVideo
            client:visible
            src="/Videos/Webm/CMVideo.webm"
            poster="/Gallery/customdes.webp"
            isLoop={true}
            autoplayOnMobile={true}
          />
        </div>
      </div>
    </div>
  </div>
</div>
