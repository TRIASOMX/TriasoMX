---
import item1 from "../../assets/images/DrumMixers/extrareinfo.webp";
import item2 from "../../assets/images/DrumMixers/plantaLim.webp";
import item3 from "../../assets/images/DrumMixers/singlegift.gif";
import item4 from "../../assets/images/DrumMixers/drumT.webp";
import img3 from "../../assets/images/AsphaltPlant/render.webp";
import DMProv1 from "../../assets/images/DrumMixers/DMProv1.webp";
import render5 from "../../assets/images/DrumMixers/Low/render5Low.webp";
import obracivil from "../../assets/images/DrumMixers/obracivil.webp";
import obracivil2 from "../../assets/images/DrumMixers/obracivil2.webp";
import obracivil2Low from "../../assets/images/DrumMixers/Low/obracivil2Low.webp";
import { Image } from "astro:assets";
import Tred from "../../assets/images/AsphaltStorage/redT.webp";
import TwoColumnSection from "../unitComponents/TwoColumnSection.astro";
import img6 from "../../assets/images/DrumMixers/2.webp";
import AcordeonItemCol from "../unitComponents/AcordeonItemCol";
import OSection from "../unitComponents/OSection.astro";
import flag from "../../assets/images/Burners/flag.svg";
import thrustrollers from "../../assets/images/DrumMixers/thrustrollers.webp";
import SmartVideo from "../unitComponents/SmartVideo";
---

<div class="w-full flex flex-col items-center justify-center font-bold mt-5 lg:mt-0">
  <div class="max-w-7xl px-8 lg:mb-28 mx-auto">
    <h1 class="text-redBg text-xl lg:text-5xl md:text-5xl text-center">
      The One and Always
    </h1>
  </div>
  <div class="max-w-7xl px-8 mx-auto flex justify-center">
    <Image
      src={obracivil}
      alt="Drum mixer on a construction zone"
      class="hero-img lg:w-4/5 rounded-lg"
    />
  </div>
  <div
    class="max-w-7xl px-8 mx-auto flex flex-col md:flex-row items-center gap-6"
  >
    <div class="w-full mt-10">
      <h2 class="text-black text-lg md:text-xl">
        Engineered for Demanding Producers. Built for Performance.
      </h2>
      <p class="text-grisT text-base md:text-lg text-justify">
        At Triaso, we know that no two asphalt operations are alike. That’s why
        our plants are precision-engineered to match each producer’s unique
        requirements. From heavy-duty construction designed for continuous
        operation to configurations that improve efficiency and safety, every
        component serves a defined purpose.
        <br /><br />
        With a range of capacities and fully customizable features, our plants adapt
        to your operation—not the other way around. Whether you're expanding capacity
        or optimizing your process, Triaso delivers the flexibility, performance,
        and reliability you need to stay ahead in a competitive market.
      </p>
    </div>

    <div class="w-full hidden lg:flex md:w-auto">
      <Image
        src={obracivil2}
        alt="Drum mixer"
        class="side-img rounded-2xl will-change-transform"
      />
    </div>
  </div>

  <div
    class="max-w-7xl hidden px-8 mx-auto lg:flex justify-center lg:justify-start"
  >
    <Image
      src={DMProv1}
      alt="Usage of a Drum mixer"
      class="fade-img rounded-lg lg:w-3/5 will-change-transform"
    />
  </div>

  <div class="relative flex flex-col lg:hidden">
    <Image
      src={obracivil2Low}
      alt="Drum mixer"
      class="rounded-2xl w-[40%] translate-x-[230px] translate-y-14"
    />

    <Image
      src={DMProv1}
      alt="Usage of a Drum mixer"
      class="absolute top-0 left-0 w-2/3 rounded-lg -translate-x-1 translate-y-2 shadow-lg"
    />
  </div>

  <div
    class="max-w-7xl px-8 mx-auto flex flex-col gap-0 md:gap-3 mb-10 mt-20 lg:mt-10"
  >
    <h2 class="reveal text-blueMain text-xl lg:text-4xl text-center px-8">
      Precision where it matters.
    </h2>

    <h2 class="reveal text-blueMain text-xl lg:text-4xl text-center px-8">
      Strength that lasts.
    </h2>

    <h2 class="reveal text-blueMain text-xl lg:text-4xl text-center px-8">
      Flexibility when it counts.
    </h2>

    <h2 class="reveal text-blueMain text-xl lg:text-4xl text-center px-8">
      That’s the Triaso promise.
    </h2>
  </div>

  <div
    class="flex flex-col max-w-7xl px-8 mx-auto  items-center justify-center bg-white rounded-2xl relative"
  >
    <details class="group max-w-7xl">
      <summary class="cursor-pointer list-none">
        <h2 class="text-2xl md:text-3xl my-6 text-center">
          Retractable Drag Slat for Efficient Transport and Operation
        </h2>
        <div class="z-20 flex items-center justify-center">
          <SmartVideo
          client:visible
          desktopWidth="70%"
          desktopHeight="70%"
          src="/Videos/Webm/PlaC140ET.webm"
          poster="/Gallery/customdes.webp"
          autoplayOnMobile={true}
          isLoop={true}
          />

        </div>
        <div class="flex justify-end py-10">
          <svg
            class="transition-transform duration-300 group-open:rotate-180"
            width="64px"
            height="64px"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            color="#0044a4"
            stroke-width="1.5"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 1.25C6.06294 1.25 1.25 6.06294 1.25 12C1.25 17.9371 6.06294 22.75 12 22.75C17.9371 22.75 22.75 17.9371 22.75 12C22.75 6.06294 17.9371 1.25 12 1.25ZM16.0303 13.0303L12.5303 16.5303C12.2374 16.8232 11.7626 16.8232 11.4697 16.5303L7.96967 13.0303C7.67678 12.7374 7.67678 12.2626 7.96967 11.9697C8.26256 11.6768 8.73744 11.6768 9.03033 11.9697L11.25 14.1893V8C11.25 7.58579 11.5858 7.25 12 7.25C12.4142 7.25 12.75 7.58579 12.75 8V14.1893L14.9697 11.9697C15.2626 11.6768 15.7374 11.6768 16.0303 11.9697C16.3232 12.2626 16.3232 12.7374 16.0303 13.0303Z"
              fill="#0044a4"></path></svg
          >
        </div>
      </summary>
      <div class="w-full max-w-full flex flex-col items-center justify-center mt-20 z-20">
        <p class="text-grisT text-justify text-base md:text-lg pb-5">
          The vertical drag slat features a retractable configuration that
          complies with DOT transportation height limits, ensuring safe and
          legal road transport. Once the drum mixer is installed on-site, the
          elevator extends to its full operational height, allowing efficient
          material discharge into truck with minimal setup time. This smart
          design improves logistics while maintaining high performance during
          loading and discharge operations.
        </p>

        <div class="w-full max-w-[calc(100vw-4rem)] overflow-hidden lg:hidden">
          <div
            class="w-full lg:hidden overflow-x-auto snap-x snap-mandatory flex gap-4 mt-6"
          >
            <div
              class="snap-center shrink-0 w-[80%] max-w-[320px] bg-bgMain rounded-2xl p-4 min-h-[350px] box-border"
            >
              <h1
                class="text-2xl md:text-4xl text-black mb-10 w-full text-start"
              >
                Hinged and Integrated
              </h1>
              <p class="text-base md:text-lg font-thin text-grisT">
                This hinged drag slat is fully assembled on its own chassis,
                allowing for immediate installation and reducing on-site
                assembly time. Its structural design is intended to integrate
                directly with the mix discharge system without the need for
                additional adjustments.
              </p>
            </div>
            <div
              class="snap-center shrink-0 w-[80%] max-w-[320px] bg-bgMain rounded-2xl p-4 min-h-[350px] box-border"
            >
              <h1
                class="text-2xl md:text-4xl text-black mb-10 w-full text-start"
              >
                Chain with a 4” pitch
              </h1>
              <p class="text-grisT text-base lg:text-lg">
                The 4” pitch chain is a key component of the elevator, designed
                for heavy-duty operation. <span style="color:black;">
                  With a tensile strength of 50,000 lbs (22,700 kg) and
                  floating-type chain</span
                >
                guides to prevent jams, ensuring smooth and reliable performance,
                durability, efficiency, and minimal maintenance.
              </p>
            </div>
            <div
              class="snap-center shrink-0 w-[80%] max-w-[320px] bg-bgMain rounded-2xl p-4 min-h-[350px] box-border"
            >
              <h1
                class="text-2xl md:text-4xl text-black mb-10 w-full text-start"
              >
                Self-aligning bearings
              </h1>
              <p class="text-grisT text-base lg:text-lg">
                Self-aligning bearings in the straight drag slat ensure smooth
                operation by automatically compensating for misalignment. This
                reduces wear, extends service life, and improves reliability in
                heavy-duty applications.
              </p>
            </div>
          </div>
        </div>

        <h1
          class="hidden lg:flex text-2xl md:text-4xl text-black mb-10 w-full text-start"
        >
          Hinged and Integrated
        </h1>
        <p class="hidden lg:flex text-base md:text-lg font-thin text-grisT">
          This hinged drag slat is fully assembled on its own chassis, allowing
          for immediate installation and reducing on-site assembly time. Its
          structural design is intended to integrate directly with the mix
          discharge system without the need for additional adjustments.
        </p>
        <div
          class="w-full hidden lg:grid grid-cols-2 lg:grid-cols-5 md:gap-8 items-center"
        >
          <div class="flex flex-col col-span-2 gap-8">
            <Image src={render5} alt="4” pitch chain" />
          </div>
          <div class="flex flex-col col-span-3 items-center gap-10">
            <div
              class="bg-white rounded-2xl text-base lg:text-lg flex flex-col text-start lg:p-4 md:p-4 justify-center"
            >
              <h1 class="text-black mb-4">Chain with a 4” pitch</h1>
              <p class="text-grisT text-base lg:text-lg">
                The 4” pitch chain is a key component of the elevator, designed
                for heavy-duty operation. <span style="color:black;">
                  With a tensile strength of 50,000 lbs (22,700 kg) and
                  floating-type chain</span
                >
                guides to prevent jams, ensuring smooth and reliable performance,
                durability, efficiency, and minimal maintenance.
              </p>
            </div>
            <div
              class="bg-white rounded-2xl text-base lg:text-lg flex flex-col text-start lg:p-4 md:p-4 justify-center"
            >
              <h1 class="text-black mb-4">Self-aligning bearings</h1>
              <p class="text-grisT text-base lg:text-lg">
                Self-aligning bearings in the straight drag slat ensure smooth
                operation by automatically compensating for misalignment. This
                reduces wear, extends service life, and improves reliability in
                heavy-duty applications.
              </p>
            </div>
          </div>
        </div>

        <div
          class="flex flex-col justify-center items-center gap-4 mt-10 h-full"
        >
          <div class="gap-10 md:gap-20">
            <div
              class="grid grid-cols-2 space-y-10 gap-5 pt-5 lg:pt-0 md:pt-0 lg:gap-0 md:gap-0 text-grisT md:text-lg text-base relative z-20"
            >
              <div
                class="flex flex-col justify-center lg:items-start text-grisT md:text-lg text-base"
              >
                <h2 class="font-medium">It can hold up</h2>
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  0.5 cubic meters
                </h1>
                <h2 class="font-medium">of material.</h2>
              </div>

              <div class="flex flex-col lg:justify-end lg:items-end">
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  Automatic opening
                </h1>
                <h2>controlled by variables such as</h2>
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  time or weight.
                </h1>
              </div>

              <div
                class="flex flex-col lg:justify-center lg:items-start text-grisT md:text-lg text-base"
              >
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  Integrated control
                </h1>
                <h2>in the console centralizes system management.</h2>
              </div>

              <div
                class="flex flex-col lg:justify-end lg:items-end text-grisT md:text-lg text-base"
              >
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  Pneumatic opening
                </h1>
                <h2>with a</h2>
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  double-acting jack
                </h1>
              </div>

              <div
                class="flex flex-col lg:justify-center lg:items-start text-grisT md:text-lg text-base"
              >
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  Automatic or manual opening
                </h1>
                <h2>allows operation either manually or automatically</h2>
              </div>

              <div
                class="flex flex-col lg:justify-end lg:items-end text-grisT md:text-lg text-base"
              >
                <h1
                  class="text-black font-bold text-lg lg:text-3xl md:text-3xl"
                >
                  7.5 Hp air compressor <br /> with a 293-liter air tank
                </h1>
                <h2>supplies air for pneumatic operation</h2>
              </div>
            </div>
          </div>
        </div>
        <div
          class="p-4 flex flex-col max-w-7xl px-8 mx-auto items-center justify-center bg-white rounded-2xl relative"
        >
          <div class="w-full relative mt-10 pb-40 md:pb-60">
            <div class="w-full z-20 relative">
              <h2 class="text-center text-2xl md:text-3xl text-blueMain">
                Real-time data monitoring of hot-mix discharge into trucks
              </h2>
            </div>

            <div
              class="flex items-start justify-start gap-10 absolute bottom-0 left-[-220px] z-10 pointer-events-none"
            >
              <Image
                src={img6}
                alt="4” pitch chain"
                class="w-[80%] max-w-[750px]"
              />
            </div>
          </div>
        </div>
      </div>
    </details>
  </div>
  <div class="w-full space-y-3 my-6">
    <div class="h-0.5 bg-redBg w-1/5 self-start"></div>
    <div class="h-0.5 bg-blueMain w-1/4 pr-6 self-start"></div>
  </div>
  <div class="max-w-7xl">
    <h2 class="text-2xl md:text-3xl text-center text-redBg mt-10">
      With Triaso, Become the Exclusive Provider of Hot Mix <br /> for All Paving
      Projects in Your Region
    </h2>
    <Image
      src={img3}
      alt="Drum Mixer machine with vibrating mixers"
      class="mt-10"
    />
  </div>
  <OSection />
  <div class="px-4">
    <h2 class="text-2xl md:text-3xl text-center text-redBg mt-10">
      Lower fuel consumption than any other asphalt plant
    </h2>
  </div>
  <div
    class="w-full bg-[url(/newBanner.webp)] bg-no-repeat bg-center bg-cover px-8 py-10 lg:py-20 mt-10"
  >
    <div class="max-w-7xl mx-auto flex flex-col">
      <div class="w-full flex justify-center">
        <Image src={flag} alt="Flag icon" class="w-[125px] md:w-[200px]" />
      </div>
      <p
        class="text-white font-bold text-center lg:text-justify md:text-justify text-base lg:text-xl"
      >
        Our latest burner innovation features an oxygen sensor that
        automatically regulates excess oxygen to no more than 3%, eliminating
        the need for manual fuel carburization adjustment when relocating the
        equipment. Thanks to our self-carburizing system, NOx levels remain even
        lower.
      </p>
    </div>
  </div>
  <TwoColumnSection
    leftBg="bg-redBg"
    rightBg="bg-blueMain"
    imageSrc={Tred.src}
    imageAlt="Red T icon"
    imageWidth="150px"
  >
    <div slot="left" class="flex flex-col justify-center gap-3">
      <h1 class="text-xl md:text-2xl">STATIONARY DRUM MIXERS</h1>
      <p class="text-base md:text-lg">
        Durable and easy to transport, the drum mixers are designed for
        long-term operation, featuring heavy-duty steel supports that eliminate
        the need for concrete foundations.
      </p>
    </div>
    <div slot="right" class="flex flex-col justify-center gap-3">
      <h1 class="text-xl md:text-2xl">MOBILE DRUM MIXERS</h1>
      <p class="text-base md:text-lg">
        Perfect for remote job sites, these mixers offer quick setup,
        portability, and high production output—all while keeping operating
        costs low.
      </p>
    </div>
  </TwoColumnSection>
  <div class="max-w-7xl px-2 mx-auto flex flex-col gap-3 my-10">
    <AcordeonItemCol title="Extra-reinforced front shield" client:idle>
      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 items-center py-5"
      >
        <div class="w-full flex justify-center">
          <Image
            src={item1}
            alt="Extra-reinforced front shield"
            class="rounded-lg w-3/4"
          />
        </div>
        <div class="w-full">
          <p class="text-base md:text-lg text-grisT font-light">
            The Triaso® drum is fully sealed at both ends with extra
            reinforcement to maintain internal temperatures and maximize
            combustion efficiency. Heavy-duty steel and EPDM rubber seals
            prevent the entry of cold air, improving fuel economy and ensuring
            consistent, high-quality asphalt mixes. The entire drum is sealed to
            prevent the entry of unwanted cold air, maintaining optimal internal
            temperatures and combustion efficiency. This airtight design
            includes an extra-reinforced front shield and sealing components
            made of heavy-duty steel or EPDM rubber. These materials provide
            long-lasting durability, resist high temperatures, and ensure that
            no external air disrupts the controlled environment inside the drum,
            improving fuel efficiency and mix quality.'
          </p>
        </div>
      </div>
    </AcordeonItemCol>
    <AcordeonItemCol title="Optimized Insulation Design" client:idle>
      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 items-center py-5"
      >
        <div class="w-full">
          <p class="text-base md:text-lg text-grisT font-light">
            The drum mixer is built with high-efficiency mineral wool insulation
            that maintains consistent internal temperatures throughout the
            drying and mixing process. This insulation minimizes heat loss,
            reduces fuel consumption, and ensures the asphalt mix stays at
            optimal temperature—delivering reliable performance even in
            demanding weather conditions.
          </p>
        </div>
        <div class="w-full flex justify-center">
          <Image
            src={item2}
            alt="Optimized Insulation Design"
            class="rounded-lg w-3/4"
          />
        </div>
      </div>
    </AcordeonItemCol>
    <AcordeonItemCol title="Single-Point Adjustment System" client:idle>
      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 items-center py-5"
      >
        <div class="w-full flex justify-center">
          <Image
            src={item3}
            alt="Single-Point Adjustment System"
            class="rounded-lg w-3/4"
          />
        </div>
        <div class="w-full">
          <p class="text-base md:text-lg text-grisT font-light">
            Triaso® equips all its drum mixers with a centralized trunnion
            adjustment system designed for fast, precise alignment in the field.
            Each trunnion base includes a fixed central pivot that keeps the
            drum tire centered during adjustments, eliminating guesswork and
            preventing lateral drift. With a single-point adjustment mechanism,
            operators can easily align the drum without needing to reposition
            multiple components. This system ensures smoother rotation, reduces
            wear on tires and trunnions, and simplifies maintenance—keeping your
            plant running efficiently with minimal downtime.
          </p>
        </div>
      </div>
    </AcordeonItemCol>
    <AcordeonItemCol title="Drum Tires & Trunnions" client:idle>
      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 items-center py-5"
      >
        <div class="w-full flex justify-center">
          <Image
            src={item4}
            alt="Drum Tires & Trunnions"
            class="rounded-lg w-3/4"
          />
        </div>
        <div class="w-full space-y-3">
          <p class="text-base md:text-lg text-grisT font-light">
            At the heart of all our drum mixers is a heavy-duty trunnion drive
            system. Each drum is powered by two high-efficiency electric motors,
            providing full control of the rotation system to optimize the
            behavior of the virgin aggregate curtain.
          </p>
          <p class="text-base md:text-lg text-grisT font-light">
            This drum rotation system is controlled by a Variable-Speed Rotation
            Drive, which allows precise control of RAP residence time inside the
            drum. The heating exposure time directly affects RAP binder
            softening and its ability to fully blend and incorporate with virgin
            aggregates. This exposure time must be adjusted according to the RAP
            percentage in the mix.
          </p>
        </div>
      </div>
      <div class="w-full text-base md:text-lg text-grisT font-light">
        <p>
          Special high-carbon alloy steel trunnions and tires forged and
          normalized, with fixed central pivot roller bases to prevent lateral
          misalignment and facilitate drum flotation.
        </p><br />
        <p>
          The trunnions are forged, precision-machined, and heat-treated for
          maximum durability, and come equipped with industry-trusted bearings.
          Designed for smooth, stable rotation under all load conditions, this
          configuration delivers consistent performance while minimizing wear
          and maintenance over time.
        </p>
      </div>
    </AcordeonItemCol>
    <AcordeonItemCol title="Triaso Thrust Rollers" client:idle>
      <div
        class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 items-center py-5"
      >
        <div class="w-full">
          <p class="text-base md:text-lg text-grisT font-light">
            Triaso drum mixers rotate on solid one-piece forged steel tires,
            delivering the strength and reliability needed for continuous
            operation. These tires are secured using bolt-on spring plate
            assemblies that flex with thermal expansion, preventing stress and
            distortion during high-temperature cycles.
          </p><br />
          <h2 class="text-lg md:text-xl text-black font-bold">
            Built to Move. Designed to Last.
          </h2><br />
          <p class="text-base md:text-lg text-grisT font-light">
            To maintain precise alignment and stability during rotation, the
            system features individual guide rollers on every tire. This system
            ensures smooth, centered operation throughout the production
            process—reducing wear and preserving the integrity of the entire
            assembly. Rugged, responsive, and built for long-term performance.
          </p>
        </div>
        <div class="w-full flex justify-center">
          <Image
            src={thrustrollers}
            alt="Triaso Thrust Rollers"
            class="rounded-lg w-3/4"
          />
        </div>
      </div>
    </AcordeonItemCol>
  </div>
</div>

<script>
  import { initScrollAnimations } from "../../components/DrumMixers/scrollAnimations";

  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      initScrollAnimations();
    });
  }
</script>
