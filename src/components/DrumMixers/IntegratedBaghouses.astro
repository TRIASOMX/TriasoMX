import baghouse2 from "../../assets/images/DrumMixers/baghouse2.webp";
import { Image } from "astro:assets";
import SeparatorBlue from "../unitComponents/SeparatorBlue.astro";
import GallerySlider from "../../components/unitComponents/GallerySlider";
import g1 from "../../assets/images/DrumMixers/Gallery/DM1.webp";
import g2 from "../../assets/images/DrumMixers/Gallery/DM2.webp";
import g3 from "../../assets/images/DrumMixers/Gallery/DM3.webp";
import g4 from "../../assets/images/DrumMixers/Gallery/DM4.webp";
import g5 from "../../assets/images/DrumMixers/Gallery/DM5.webp";
