import g15 from "../../assets/images/DrumMixers/Gallery/DM16.webp";
import g16 from "../../assets/images/DrumMixers/Gallery/DM17.webp";
import poster1 from "../../assets/images/DrumMixers/Gallery/DM11.webp"
import SmartVideo from "../unitComponents/SmartVideo";

const binSlides2 = [
  {
    image: g1.src,
    caption: "Drum mixer, 110-150 Tph, counter-flow, in working position",
  },
  {
    image: g2.src,
    caption: "Drum mixer, 110-150 Tph, counter-flow, in working position",
  },
  {
    image: g3.src,
    caption: "Drum mixer, 110-150 Tph, counter-flow, in transporting position",
  },
  {
    image: g4.src,
    caption: "Drum mixer, 60-80 Tph, counter-flow, in working position",
  },
  {
    image: g5.src,
    caption: "Drum mixer, 60-80 Tph, counter-flow, in working position",
  },
  {
    image: g6.src,
    caption: "Drum mixer, 60-80 Tph, counter-flow, in working position",
  },
  {
    image: g7.src,
    caption: "Drum mixer, 60-80 Tph, counter-flow, in transporting position",
  },
  {
    image: g8.src,
    caption:
      "Drum mixer, 110-150 Tph, counter-flow, with pugmill, in working position",
  },
  {
    image: g9.src,
    caption:
      "Drum mixer, 110-150 Tph, counter-flow, with pugmill, in working position",
  },
  {
    image: g10.src,
    caption:
      "Drum mixer, 110-150 Tph, counter-flow, with pugmill, in transporting position",
  },
  {
    image: g11.src,
    caption:
      "Drum mixer, 110-150 Tph, counter-flow, with pugmill, in working position with RAP Bin",
  },
  {
    image: g12.src,
    caption: "Control console, with Plus computer for counterflow plant",
  },
  {
    image: g13.src,
    caption: "Triple bin unit, Plus version",
  },
  {
    image: g14.src,
    caption: "Triple bin unit, Plus version",
  },
  {
    image: g15.src,
    caption: "Triple bin unit, Plus version",
  },
  {
    image: g16.src,
    caption: "Triple bin unit, Plus version",
  },
