import g9 from "../../assets/images/DrumMixers/Gallery/DM9.webp";
import g10 from "../../assets/images/DrumMixers/Gallery/DM10.webp";
import g11 from "../../assets/images/DrumMixers/Gallery/DM11.webp";
import g12 from "../../assets/images/DrumMixers/Gallery/DM13.webp";
import g13 from "../../assets/images/DrumMixers/Gallery/DM14.webp";
