            flex: 0 0 85%;
            scroll-snap-align: start;
        }
    }
</style>

<script>
    const TOTAL_SLIDES = 3;
    const AUTO_INTERVAL = 10000;

    const track = document.getElementById("sliderTrack") as HTMLElement;
    const viewport = document.getElementById("sliderViewport") as HTMLElement;
    const dots = Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-dot]"),
    );

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
        current = (index + TOTAL_SLIDES) % TOTAL_SLIDES;
        track.style.transform = `translateX(-${current * 100}%)`;

        dots.forEach((dot, i) => {
            const active = i === current;
            dot.setAttribute("aria-selected", String(active));
            dot.className = active
                ? "dot w-3 h-3 rounded-full bg-gray-800 transition-all duration-300"
                : "dot w-2 h-2 mt-0.5 rounded-full bg-gray-300 transition-all duration-300 hover:bg-gray-500";
        });
    }

    function startAuto() {
        timer = setInterval(() => goTo(current + 1), AUTO_INTERVAL);
    }
    function resetAuto() {
        clearInterval(timer);
        startAuto();
    }

    dots.forEach((dot) => {
        dot.addEventListener("click", () => {
            goTo(Number(dot.dataset.dot));
            resetAuto();
        });
    });

    document
        .querySelectorAll<HTMLButtonElement>(".mostrar-mas")
        .forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const expandible = btn.nextElementSibling as HTMLElement;
                const chevron = btn.querySelector(".chevron") as HTMLElement;
                const isOpen =
                    expandible.style.maxHeight &&
                    expandible.style.maxHeight !== "0px";

                if (isOpen) {
                    expandible.style.maxHeight = "0px";
                    chevron.style.transform = "rotate(0deg)";
                    btn.setAttribute("aria-expanded", "false");
                } else {
                    expandible.style.maxHeight = expandible.scrollHeight + "px";
                    chevron.style.transform = "rotate(180deg)";
                    btn.setAttribute("aria-expanded", "true");
                }
            });
        });

    let touchStartX = 0;
    let touchStartY = 0;
    let swipeBlockedByCardRow = false;

    viewport.addEventListener(
        "touchstart",
        (e) => {
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
            const target = e.target as Element;
            swipeBlockedByCardRow =
                window.innerWidth < 640 &&
                target.closest(".card-row-wrapper") !== null;
        },
        { passive: true },
    );

    viewport.addEventListener("touchend", (e) => {
        if (swipeBlockedByCardRow) return;

        const deltaX = touchStartX - e.changedTouches[0].clientX;
        const deltaY = Math.abs(touchStartY - e.changedTouches[0].clientY);
        if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY) {
            goTo(deltaX > 0 ? current + 1 : current - 1);
            resetAuto();
        }
    });

    function initCardRowDots() {
        document
            .querySelectorAll<HTMLElement>(".card-row")
            .forEach((row, rowIndex) => {
                const dotsContainer = document.querySelector<HTMLElement>(
                    `.card-dots[data-row="${rowIndex}"]`,
                );
                if (!dotsContainer) return;

                const dotEls = Array.from(
                    dotsContainer.querySelectorAll<HTMLElement>(".card-dot"),
                );

                row.addEventListener(
                    "scroll",
                    () => {
                        if (window.innerWidth >= 640) return;
                        const cardWidth =
                            (row.firstElementChild as HTMLElement)
                                ?.offsetWidth ?? 1;
                        const activeIndex = Math.round(
                            row.scrollLeft / cardWidth,
                        );
                        dotEls.forEach((dot, i) => {
                            if (i === activeIndex) {
                                dot.className =
                                    "card-dot w-2 h-2 rounded-full bg-gray-800 transition-all duration-300";
                            } else {
                                dot.className =
                                    "card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300 transition-all duration-300";
                            }
                        });
                    },
                    { passive: true },
                );
            });
    }

    initCardRowDots();
    goTo(0);
    startAuto();
</script>
