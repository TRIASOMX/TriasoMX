---
import img6 from "../../assets/images/DrumMixers/2.webp";
import SmartVideo from "../unitComponents/SmartVideo";
import poster1 from "../../../public/Videos/Webm/Posters/drummixers2.webp";
import render5 from "../../assets/images/DrumMixers/Low/render5Low.webp";
import sidePanel from "../../assets/images/SidePanels/FEPlaC_1.webp";
import LearnBtnBlue from "../unitComponents/LearnBtnBlue.astro";
import { Image } from "astro:assets";


import slider1 from "../../assets/images/DrumMixers/trunnions.webp"
import slider2 from "../../assets/images/DrumMixers/drumT.webp"
import slider3 from "../../assets/images/DrumMixers/drumtires.webp"
import bigSlider1 from "../../assets/images/DrumMixers/rap.webp"

import slider4 from "../../assets/images/DrumMixers/Contraflujo/Pro+/Aislamiento.webp"
import slider5 from "../../assets/images/DrumMixers/thrustrollers.webp"
import slider6 from "../../assets/images/DrumMixers/Contraflujo/Pro+/Plasma.webp"
import bigSlider2 from "../../assets/images/RapBins/Low/RAProv3Low.webp"

import slider8 from "../../assets/images/SidePanels/FEPlaC1_1.webp"
import slider9 from "../../assets/images/DrumMixers/drumT.webp"
import bigSlider3 from "../../assets/images/DrumMixers/Low/a21Low.webp"


---

<section
    id="tamborMezclador"
    class="w-full select-none"
    aria-label="Tambor Mezclador"
>
    <h2 class="font-bold text-2xl lg:text-3xl text-black mb-5 uppercase">
        Tambor Mezclador
    </h2>

    <div class="overflow-hidden" id="sliderViewport">
        <div
            id="sliderTrack"
            class="flex transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform"
        >
            <div class="w-full shrink-0 space-y-4">
                <div class="card-row-wrapper relative">
                    <div
                        class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3"
                        id="cardRow0"
                    >
                        <!-- Card 1-A -->
                        <div
                            class="relative rounded-lg overflow-hidden group cursor-pointer"
                            data-card="0-0"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider1.src}
                                    alt=""
                                />
                            </div>

                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Roles de carga
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Roles de carga extra reforzados
                                        fabricados en acero forjado, maquinado
                                        con precisión y equipados con
                                        rodamientos industriales para una
                                        rotación del tambor suave y estable.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 1-B -->
                        <div
                            class="relative rounded-lg overflow-hidden group cursor-pointer"
                            data-card="0-1"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider2.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Variadores de<br />velocidad de giro
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Nuestra más reciente innovación para
                                        alto porcentajes de incorporación de RAP
                                        es el uso de variadores de velocidad de
                                        rotación en los sistemas de giro del
                                        tambor
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 1-C -->
                        <div
                            class="relative rounded-lg overflow-hidden group cursor-pointer"
                            data-card="0-2"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider3.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Aros
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Forjados en acero aleado de alta
                                        resistencia y maquinados con precisión
                                        para garantizar un soporte confiable y
                                        una operación silenciosa y uniforme.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- MÓVIL INDICADORES -->
                    <div
                        class="card-dots flex justify-center gap-1.5 mt-2 sm:hidden"
                        data-row="0"
                    >
                        <span class="card-dot w-2 h-2 rounded-full bg-gray-800"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                    </div>
                </div>

                <!-- Bloque RAP slide 1 -->
                <div
                    class="rounded-xl bg-[#727272] p-6 flex flex-col sm:flex-row items-center gap-6"
                >
                    <div class="flex-1 min-w-0">
                        <h3
                            class="font-extrabold text-white text-2xl md:text-3xl uppercase tracking-wide mb-2"
                        >
                            Collar de RAP
                        </h3>
                        <p class="text-white/80 text-sm mb-1">
                            Nuestro sistema de RAP puede incorporar
                        </p>
                        <p class="text-white font-bold text-lg mb-3">
                            hasta 50% <span
                                class="font-normal text-sm text-white/80"
                                >de carpeta asfáltica reciclada</span
                            >
                        </p>
                        <p class="text-white/80 text-sm mb-1">
                            Por cada 10% de RAP,<br />el costo de la mezcla
                            asfáltica se
                        </p>
                        <p class="text-white font-bold text-xl mb-4">
                            reduce 7%
                        </p>
                        <a
                            href="#"
                            class="inline-block px-5 py-2 border border-white/60 rounded-full text-white text-sm
                               hover:bg-white hover:text-gray-700 transition-all duration-200"
                        >
                            Saber más
                        </a>
                    </div>
                    <!-- Imagen 3D placeholder collar -->
                    <div
                        class="shrink-0 w-40 h-40 flex items-center justify-center"
                    >
                        <img src={bigSlider1.src} alt="" />
                    </div>
                </div>
            </div><!-- /SLIDE 1 -->

            <div class="w-full shrink-0 space-y-4">
                <div class="card-row-wrapper relative">
                    <div class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <!-- Card 2-A -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="1-0"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider4.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Aislamiento para eficiencia energética
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Aislamiento de lana mineral minimizando
                                        la pérdida de calor, reduciendo el
                                        consumo de combustible y asegura que la
                                        mezcla asfáltica se mantenga a la
                                        temperatura óptima.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 2-B -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="1-1"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider5.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Platos axiales
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Para mantener una alineación precisa y
                                        estabilidad durante la rotación, el
                                        sistema incorpora platos axiales
                                        individuales en cada aro.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 2-C -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="1-2"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider6.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Escudo frontal extra-reforzado
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Escudo frontal con refuerzo adicional y
                                        sellado con acero extra reforzado y hule
                                        EPDM para evitar la entrada de aire frío
                                        no deseado, manteniendo temperaturas
                                        internas óptimas y una alta eficiencia
                                        de combustión.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div
                        class="card-dots flex justify-center gap-1.5 mt-2 sm:hidden"
                        data-row="1"
                    >
                        <span class="card-dot w-2 h-2 rounded-full bg-gray-800"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                    </div>
                </div>

                <!-- Bloque RAP slide 2 -->
                <div
                    class="rounded-xl bg-[#727272] p-6 flex flex-col sm:flex-row items-center gap-6"
                >
                    <div class="flex-1 min-w-0">
                        <h3
                            class="font-extrabold text-white text-2xl md:text-3xl uppercase tracking-wide mb-2"
                        >
                            TOLVAS DE RAP
                        </h3>
                        <p class="text-white/80 text-sm mb-1">
                            Nuestro sistema de RAP puede incorporar
                        </p>
                        <p class="text-white font-bold text-lg mb-3">
                            hasta 50% <span
                                class="font-normal text-sm text-white/80"
                                >de carpeta asfáltica reciclada</span
                            >
                        </p>
                        <p class="text-white/80 text-sm mb-1">
                            Por cada 10% de RAP, <br />
                            el costo de la mezcla asfáltica se
                        </p>
                        <p class="text-white font-bold text-xl mb-4">
                            reduce 7%
                        </p>
                        <a
                            href="#"
                            class="inline-block px-5 py-2 border border-white/60 rounded-full text-white text-sm
                               hover:bg-white hover:text-gray-700 transition-all duration-200"
                        >
                            Saber más
                        </a>
                    </div>
                    <div
                        class="shrink-0 w-[30%] flex items-center justify-center"
                    >
                        <img src={bigSlider2.src} alt="" />
                    </div>
                </div>
            </div>

            <div class="w-full shrink-0 space-y-4">
                <div class="card-row-wrapper relative">
                    <div class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <!-- Card 3-A -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="2-0"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src="https://placehold.co/600x400"
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Chasis con alta distancia al suelo
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Permite el transporte seguro del equipo
                                        en terrenos, calles y carreteras con
                                        baches y desniveles muy comunes en
                                        México, evitando daños a los componentes
                                        inferiores.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 3-B -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="2-1"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider8.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Flancos estéticos
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        Los paneles estéticos están diseñados no
                                        solo para ofrecer una mejor apariencia
                                        visual, sino también para reforzar la
                                        imagen profesional de tu equipo y de tu
                                        empresa.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Card 3-C -->
                        <div
                            class="relative rounded-lg overflow-hidden cursor-pointer"
                            data-card="2-2"
                        >
                            <div
                                class="w-full h-44 bg-black/10 flex items-center justify-center"
                            >
                                <img
                                    src={slider9.src}
                                    alt=""
                                />
                            </div>
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                            >
                                <span
                                    class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                                >
                                    Sistema de ajuste centralizado
                                </span>
                                <button
                                    class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                    aria-expanded="false"
                                >
                                    <svg
                                        class="chevron w-3 h-3 transition-transform duration-300"
                                        viewBox="0 0 12 12"
                                        fill="none"
                                    >
                                        <path
                                            d="M2 4l4 4 4-4"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"></path>
                                    </svg>
                                    mostrar más
                                </button>
                                <div
                                    class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                                >
                                    <p
                                        class="text-white/75 text-xs leading-relaxed mt-2"
                                    >
                                        placeholder
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div
                        class="card-dots flex justify-center gap-1.5 mt-2 sm:hidden"
                        data-row="2"
                    >
                        <span class="card-dot w-2 h-2 rounded-full bg-gray-800"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                        <span
                            class="card-dot w-1.5 h-1.5 mt-0.5 rounded-full bg-gray-300"
                        ></span>
                    </div>
                </div>
                <div
                    class="rounded-xl bg-[#727272] p-6 flex flex-col sm:flex-row items-center gap-6"
                >
                    <div class="flex-1 min-w-0">
                        <h3
                            class="font-extrabold text-white text-2xl md:text-3xl uppercase tracking-wide mb-2"
                        >
                            TOLVAS DE RAP
                        </h3>
                        <p class="text-white/80 text-sm mb-1">
                            Nuestro sistema de RAP puede incorporar
                        </p>
                        <p class="text-white font-bold text-lg mb-3">
                            hasta 50% <span
                                class="font-normal text-sm text-white/80"
                                >de carpeta asfáltica reciclada</span
                            >
                        </p>
                        <p class="text-white/80 text-sm mb-1">
                            Por cada 10% de RAP, <br />
                            el costo de la mezcla asfáltica se
                        </p>
                        <p class="text-white font-bold text-xl mb-4">
                            reduce 7%
                        </p>
                        <a
                            href="#"
                            class="inline-block px-5 py-2 border border-white/60 rounded-full text-white text-sm
                               hover:bg-white hover:text-gray-700 transition-all duration-200"
                        >
                            Saber más
                        </a>
                    </div>
                    <div
                        class="shrink-0 w-[30%] flex items-center justify-center"
                    >
                        <img src={bigSlider3.src} alt="" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div
        class="flex justify-center gap-2 mt-5"
        id="dotsContainer"
        role="tablist"
        aria-label="Navegación de slides"
    >
        <button
            role="tab"
            aria-selected="true"
            data-dot="0"
            class="dot w-3 h-3 rounded-full bg-gray-800 transition-all duration-300"
            aria-label="Slide 1"></button>
        <button
            role="tab"
