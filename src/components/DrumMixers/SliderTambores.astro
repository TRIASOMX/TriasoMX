<!-- ════════════════════════════
     Responsive: mobile slider para los cards
     Solo estas 2 reglas no pueden expresarse con Tailwind (selector de hijo)
════════════════════════════ -->
<style>
    /* En mobile cada slide ocupa el 100% del viewport del slider (ya lo hace por defecto).
     Los cards en mobile se convierten en un scroll horizontal interno. */
    @media (max-width: 639px) {
        #sliderTrack .grid {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            gap: 0.75rem;
            padding-bottom: 0.25rem;
        }
        #sliderTrack .grid > * {
            flex: 0 0 80%;
            scroll-snap-align: start;
        }
    }
</style>

<script>
    const TOTAL_SLIDES = 3;
    const AUTO_INTERVAL = 1000000; // ms

    const track = document.getElementById("sliderTrack") as HTMLElement;
    const viewport = document.getElementById("sliderViewport") as HTMLElement;
    const dots = Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-dot]"),
    );

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    // ── Ir a slide ──
    function goTo(index: number) {
        current = (index + TOTAL_SLIDES) % TOTAL_SLIDES;
        track.style.transform = `translateX(-${current * 100}%)`;

        dots.forEach((dot, i) => {
            const active = i === current;
            dot.setAttribute("aria-selected", String(active));
            dot.className = active
                ? "dot w-3 h-3 rounded-full bg-gray-800 transition-all duration-300"
                : "dot w-2 h-2 mt-0.5 rounded-full bg-gray-300 transition-all duration-300 hover:bg-gray-500";
        });
    }

    // ── Autoplay ──
    function startAuto() {
        timer = setInterval(() => goTo(current + 1), AUTO_INTERVAL);
    }
    function resetAuto() {
        clearInterval(timer);
        startAuto();
    }

    // ── Dots click ──
    dots.forEach((dot) => {
        dot.addEventListener("click", () => {
            goTo(Number(dot.dataset.dot));
            resetAuto();
        });
    });

    // ── Mostrar más / menos ──
    document
        .querySelectorAll<HTMLButtonElement>(".mostrar-mas")
        .forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const expandible = btn.nextElementSibling as HTMLElement;
                const chevron = btn.querySelector(".chevron") as HTMLElement;
                const isOpen =
                    expandible.style.maxHeight &&
                    expandible.style.maxHeight !== "0px";

                if (isOpen) {
                    expandible.style.maxHeight = "0px";
                    chevron.style.transform = "rotate(0deg)";
                    btn.setAttribute("aria-expanded", "false");
                } else {
                    expandible.style.maxHeight = expandible.scrollHeight + "px";
                    chevron.style.transform = "rotate(180deg)";
                    btn.setAttribute("aria-expanded", "true");
                }
            });
        });

    // ── Touch / swipe ──
    let touchStartX = 0;
    viewport.addEventListener(
        "touchstart",
        (e) => {
            touchStartX = e.touches[0].clientX;
        },
        { passive: true },
    );
    viewport.addEventListener("touchend", (e) => {
        const delta = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(delta) > 50) {
            goTo(delta > 0 ? current + 1 : current - 1);
            resetAuto();
        }
    });

    // ── Init ──
    goTo(0);
    startAuto();
</script>
