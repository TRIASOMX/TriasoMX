---
// TamborMezclador.astro
// Slider automático con 3 slides (cada slide = 3 cards + bloque RAP)
// Tailwind CSS · responsive · indicadores navegables
---

<section
    id="tamborMezclador"
    class="w-full select-none"
    aria-label="Tambor Mezclador"
>
    <h2 class="font-bold text-2xl lg:text-3xl text-black mb-5 uppercase">
        Tambor Mezclador
    </h2>

    <div class="overflow-hidden" id="sliderViewport">
        <div
            id="sliderTrack"
            class="flex transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform"
        >
            <div class="w-full shrink-0 space-y-4">
                <div
                    class="grid grid-cols-1 sm:grid-cols-3 gap-3"
                    id="cardRow0"
                >
                    <!-- Card 1-A -->
                    <div
                        class="relative rounded-lg overflow-hidden group cursor-pointer"
                        data-card="0-0"
                    >
                        <!-- Imagen placeholder -->
                        <div
                            class="w-full h-44 bg-gradient-to-br from-gray-700 via-gray-600 to-gray-800 flex items-center justify-center"
                        >
                            <img src="https://placehold.co/600x400" alt="" />
                        </div>
                        <!-- Overlay -->
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                        >
                            <span
                                class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                            >
                                Roles de carga
                            </span>
                            <button
                                class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                aria-expanded="false"
                            >
                                <svg
                                    class="chevron w-3 h-3 transition-transform duration-300"
                                    viewBox="0 0 12 12"
                                    fill="none"
                                >
                                    <path
                                        d="M2 4l4 4 4-4"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"></path>
                                </svg>
                                mostrar más
                            </button>
                            <div
                                class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                            >
                                <p
                                    class="text-white/75 text-xs leading-relaxed mt-2"
                                >
                                    Roles de carga extra reforzados fabricados
                                    en acero forjado, maquinado con precisión y
                                    equipados con rodamientos industriales para
                                    una rotación del tambor suave y estable.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Card 1-B -->
                    <div
                        class="relative rounded-lg overflow-hidden group cursor-pointer"
                        data-card="0-1"
                    >
                        <div
                            class="w-full h-44 bg-gradient-to-br from-slate-600 via-slate-500 to-slate-700 flex items-center justify-center"
                        >
                            <img src="https://placehold.co/600x400" alt="" />
                        </div>
                        <div
                            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                        >
                            <span
                                class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                            >
                                Variadores de<br />velocidad de giro
                            </span>
                            <button
                                class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                                aria-expanded="false"
                            >
                                <svg
                                    class="chevron w-3 h-3 transition-transform duration-300"
                                    viewBox="0 0 12 12"
                                    fill="none"
                                >
                                    <path
                                        d="M2 4l4 4 4-4"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"></path>
                                </svg>
                                mostrar más
                            </button>
                            <div
                                class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                            >
                                <p
                                    class="text-white/75 text-xs leading-relaxed mt-2"
                                >
                                    Nuestra más reciente innovación para alto
                                    porcentajes de incorporación de RAP es el
                                    uso de variadores de velocidad de rotación
                                    en los sistemas de giro del tambor
                                </p>
                            </div>
                        </div>
                    </div>

