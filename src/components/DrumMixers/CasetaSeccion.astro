---

---

<section class="overflow-hidden max-w-7xl mx-auto px-8">
  <div class="pt-10 pb-6">
    <h2 class=" font-bold text-black text-2xl mb-1">
      CASETA DE CONTROL REMOLCABLE
    </h2>
    <p class="text-[#200707] font-semibold text-base mb-4">
      La caseta de control en las que su personal disfrutará trabajar.
    </p>
    <p class="text-black text-sm mb-6 max-w-xl">
      Todos los procesos son controlados desde una consola de control, de forma manual o automática
      con nuestro más avanzado sistema de control Traso Relief™. Por lo que garantizamos su gran
      productividad, calidad de mezcla y operación libre de problemas.
    </p>
    <a
      href="#"
      class="inline-block px-6 py-2 border border-gray-400 rounded-full text-gray-800 text-sm font-medium"
    >
      Saber más
    </a>
  </div>

  <div class="flex min-h-[280px] bg-gradient-to-r from-white to to-black">
    <div class="basis-[52%] shrink-0 relative overflow-hidden">
      <img
        src="https://placehold.co/600x400/png"
        alt="Caseta de control remolcable Traso"
        class="w-full h-full object-cover block"
        onerror="this.style.display='none'"
      />
    </div>

    <div class="flex-1 flex flex-col justify-center px-6 py-6 overflow-hidden">

      <div
        id="carruselTrack"
        class="flex gap-4 transition-transform duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform"
      >

        <article class="max-w-[300px] shrink-0 bg-white rounded-md p-4 shadow-md
                        transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
          <div class="w-10 h-10 mb-3">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <rect x="4" y="14" width="32" height="20" rx="3" stroke="#222" stroke-width="2.5" fill="none"/>
              <rect x="36" y="20" width="8" height="8" rx="2" stroke="#222" stroke-width="2" fill="none"/>
              <circle cx="12" cy="36" r="4" stroke="#222" stroke-width="2" fill="none"/>
              <circle cx="28" cy="36" r="4" stroke="#222" stroke-width="2" fill="none"/>
            </svg>
          </div>
          <h3 class="font-bold text-base text-black mb-1 ">
            Instalación rápida
          </h3>
          <p class=" text-gray-500 ">
            Caseta de control remolcable diseñada para una instalación rápida, segura y práctica en cualquier sitio de trabajo.
          </p>
        </article>

        <article class="max-w-[300px] shrink-0 bg-white rounded-md p-4 shadow-md
                        transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
          <div class="w-10 h-10 mb-3">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <circle cx="24" cy="24" r="18" stroke="#222" stroke-width="2.5" fill="none"/>
              <path d="M17 24l5 5 9-10" stroke="#222" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M24 6v4M24 38v4M6 24h4M38 24h4" stroke="#222" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="font-bold text-base text-black mb-1">
            Totalmente personalizable
          </h3>
          <p class="text-gray-500">
            Preparada para la instalación de cámaras, sistemas de registro digital o monitoreo en tiempo real con oficina, según los requerimientos del cliente.
          </p>
        </article>

        <article class="max-w-[300px] shrink-0 bg-white rounded-md p-4 shadow-md
                        transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
          <div class="w-10 h-10 mb-3">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <rect x="8" y="8" width="32" height="32" rx="4" stroke="#222" stroke-width="2.5" fill="none"/>
              <rect x="14" y="14" width="8" height="8" rx="1" stroke="#222" stroke-width="2" fill="none"/>
              <rect x="26" y="14" width="8" height="8" rx="1" stroke="#222" stroke-width="2" fill="none"/>
              <rect x="14" y="26" width="8" height="8" rx="1" stroke="#222" stroke-width="2" fill="none"/>
              <rect x="26" y="26" width="8" height="8" rx="1" stroke="#222" stroke-width="2" fill="none"/>
            </svg>
          </div>
          <h3 class="font-bold text-base text-black mb-1">
            Operación sencilla
          </h3>
          <p class="text-gray-500">
            Nuestro sistema de control ha sido diseñado para ser operado por una sola persona, reduciendo los costos de mano de obra y simplificando la operación de la planta.
          </p>
        </article>

        <article class="max-w-[300px] shrink-0 bg-white rounded-md p-4 shadow-md
                        transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
          <div class="w-10 h-10 mb-3">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <path d="M24 4L4 16v16l20 12 20-12V16L24 4z" stroke="#222" stroke-width="2.5" fill="none"/>
              <path d="M24 4v28M4 16l20 12 20-12" stroke="#222" stroke-width="2" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-bold text-base text-black mb-1">
            Estructura robusta
          </h3>
          <p class="text-gray-500">
            Fabricada con materiales de alta resistencia para soportar las condiciones más exigentes de trabajo en campo, garantizando durabilidad y seguridad.
          </p>
        </article>

        <article class="max-w-[300px] shrink-0 bg-white rounded-md p-4 shadow-md
                        transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
          <div class="w-10 h-10 mb-3">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <circle cx="24" cy="20" r="10" stroke="#222" stroke-width="2.5" fill="none"/>
              <path d="M8 42c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="#222" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <h3 class="font-bold text-base text-black mb-1">
            Confort operativo
          </h3>
          <p class="text-gray-500">
            Espacio interior climatizado y ergonómico, diseñado para que el personal trabaje con comodidad durante largas jornadas de operación.
          </p>
        </article>

      </div>

      <div class="flex justify-end gap-2 mt-4">
        <button
          id="btnPrev"
          aria-label="Anterior"
          class="w-8 h-8 flex items-center justify-center rounded text-xl text-white leading-none cursor-pointer
                 bg-white/10 border border-white/30
                 transition-colors duration-200 hover:bg-red-600 hover:border-red-600
                 disabled:opacity-35 disabled:cursor-not-allowed"
        >
          &#8249;
        </button>
        <button
          id="btnNext"
          aria-label="Siguiente"
          class="w-8 h-8 flex items-center justify-center rounded text-xl text-white leading-none cursor-pointer
                 bg-white/10 border border-white/30
                 transition-colors duration-200 hover:bg-red-600 hover:border-red-600
                 disabled:opacity-35 disabled:cursor-not-allowed"
        >
          &#8250;
        </button>
      </div>

    </div>
  </div>

  <style>
    @media (max-width: 768px) {
      .flex.min-h-\[280px\] { flex-direction: column; }
      .basis-\[52\%\]        { flex-basis: auto; height: 200px; }
      #carruselTrack > article { min-width: calc(85% - 0.5rem); }
    }
    @media (max-width: 480px) {
      #carruselTrack > article { min-width: 90%; }
    }
  </style>

</section>

<script>
  const track   = document.getElementById('carruselTrack') as HTMLElement;
  const btnPrev = document.getElementById('btnPrev')       as HTMLButtonElement;
  const btnNext = document.getElementById('btnNext')       as HTMLButtonElement;

  let currentIndex = 0;

  const getVisibleCount = () => (window.innerWidth < 600 ? 1 : 2);
  const getTotalCards   = () => track.children.length;
  const getMaxIndex     = () => Math.max(0, getTotalCards() - getVisibleCount());

  function updateCarrusel() {
    const card   = track.children[0] as HTMLElement;
    const gap    = 10; 
    const offset = currentIndex * (345);
    track.style.transform = `translateX(-${offset}px)`;
    btnPrev.disabled = currentIndex === 0;
    btnNext.disabled = currentIndex >= getMaxIndex();
  }

  btnNext.addEventListener('click', () => {
    if (currentIndex < getMaxIndex()) { currentIndex++; updateCarrusel(); }
  });
  btnPrev.addEventListener('click', () => {
    if (currentIndex > 0) { currentIndex--; updateCarrusel(); }
  });
  window.addEventListener('resize', () => {
    currentIndex = Math.min(currentIndex, getMaxIndex());
    updateCarrusel();
  });

  updateCarrusel();
</script>