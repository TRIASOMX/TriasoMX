---
import { Image } from "astro:assets";
import ASCustom from "../AsphaltStorage/ASCustom.astro";
import Slider from "../LandinPage/SliderOs";
import TriasoLogo from "../../assets/logos/triasoLogo.webp";
import LearnBtnBlue from "../unitComponents/LearnBtnBlue.astro";
import OSHand from "../../assets/images/AsphaltStorage/OsHand.webp";

const iconos = [
  {
    src: "/Gallery/sliderHotMix/1.webp",
    title: "Preservation of Quality",
    texto: "Perservation of quality and integrity of the asphalt.",
  },
  {
    src: "/Gallery/sliderHotMix/2.webp",
    title: "Efficient Logistics",
    texto:
      "Streamlines delivery with reports, history tracking, and precise asphalt flow control.",
  },
  {
    src: "/Gallery/sliderHotMix/3.webp",
    title: "Versatile Storage Options",
    texto:
      "Long-duration thermal retention, ensuring it remains liquid and high-quality for extended periods.",
  },
  {
    src: "/Gallery/sliderHotMix/4.webp",
    title: "Mobility",
    texto:
      "Triaso asphalt tanks allow quick setup without heavy machinery, ideal for relocatable operations.",
  },
  {
    src: "/Gallery/sliderHotMix/5.webp",
    title: "Durability",
    texto:
      "Built with reinforced materials, thermally insulated cylinders, and corrosion-resistant finishes.",
  },
  {
    src: "/Gallery/sliderHotMix/6.webp",
    title: "Seamless Integration",
    texto:
      "Compatible with asphalt plant systems through protocols like Ethernet Industrial, Modbus, and CANopen.",
  },
  {
    src: "/Gallery/sliderHotMix/7.webp",
    title: "Enhanced Safety",
    texto:
      "Equipped with guards, alarms, and visual indicators to protect personnel and equipment.",
  },
  {
    src: "/Gallery/sliderHotMix/8.webp",
    title: "Cost-Effective",
    texto:
      "Reduces downtime, transportation costs, and maintenance with efficient design and reliable performance.",
  },
  {
    src: "/Gallery/sliderHotMix/9.webp",
    title: "Improved Company Image",
    texto: "Industrial aesthetics elevate the visual appeal of your operation.",
  },
  {
    src: "/Gallery/sliderHotMix/10.webp",
    title: "Customizable",
    texto:
      "Adaptable features to meet specific project requirements and operational goals.",
  },
];
---

<section class="bg-[#1e1e1e] mt-20 overflow-visible pb-10">
  <div class="flex justify-center items-center py-5">
    <Image src={TriasoLogo} alt="TRIASO LOGO" width={1690} />
  </div>

  <div class="max-w-7xl mx-auto lg:px-0 py-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12">
      <!-- Imagen -->
      <div class="flex justify-end relative">
        <Image
          src="https://placehold.co/600x400/png"
          alt="Triaso OS"
          width={600}
          height={400}
          class="rounded-2xl"
        />
      </div>

      <!-- Texto -->
      <div class="text-white max-w-xl px-8">
        <h1
          class="text-2xl md:text-3xl font-semibold my-6 bg-gradient-to-r from-[#f8ad00] via-[#dc363a] to-[#3992ff] bg-clip-text text-transparent"
        >
          Sistema de operación Triaso® − Relief
        </h1>
        <p class="text-[#adadad] font-semibold leading-relaxed">
          Ofrecemos una forma práctica y eficiente de gestionar el
          funcionamiento de nuestros equipos. Gracias a sistemas avanzados de
          monitoreo y automatización, <span class="text-white"
            >simplificamos tanto el manejo de los equipos como el trabajo de la
            tripulación.
          </span> Control total de cada etapa de la producción, con un seguimiento
          completo de todos los datos operativos.
        </p>
        <div class="pt-5 flex items-center justify-center">
          <a
            href="/Relief"
            aria-label="View page drum Mixers"
            class="text-white text-center mb-5 mt-5 text-xs md:text-sm font-normal border-2 border-[#14427c] rounded-full py-2 px-6 transition-all duration-300 ease-out transform hover:scale-110 hover:shadow-lg bg-[#14427c] hover:bg-white hover:text-black hover:border-white"
          >
            Ver más
          </a>
        </div>
      </div>
    </div>
    <div class="flex lg:hidden md:flex">
      <Slider client:only />
    </div>
    
  </div>

  <div class="grid max-w-7xl mx-auto grid-cols-1 lg:grid-cols-2 md:grid-cols-2">
    <div class="flex flex-col justify-center items-center">
      <div class="hidden lg:flex md:hidden">
        <Slider client:only />
      </div>

      <div class="space-y-5 flex flex-col justify-center items-center">
        <h1 class="text-white font-bold text-center text-3xl">
          Para evitar desperdicios, robos y mala operación de su tanque de
          asfalto
        </h1>
        <p class="text-white">Paro total con un solo botón desde su celular</p>
        <LearnBtnBlue />
      </div>
    </div>

    <div>
      <div class="flex justify-end relative">
        <Image
          src={OSHand}
          alt="Triaso OS"
          class="w-[280px] md:w-[360px] lg:w-[420px]"
        />
      </div>
    </div>
  </div>
</section>

<section class="w-full flex flex-col items-center justify-center font-bold">
  <ASCustom />

  <!-- <ItemsSlider client:only images={iconos} /> -->
</section>
