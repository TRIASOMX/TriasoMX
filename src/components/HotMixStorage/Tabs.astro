  <style is:global>
    .tab-button-1[aria-selected="true"] {
      background-color: var(--azul-main, #0044a4);
      color: #ffffff;
      box-shadow: 0 4px 14px rgba(26, 58, 107, 0.35);
    }

    .tab-button-1[aria-selected="false"] {
      background-color: #ffffff;
      color: var(--gris-titulos, #555555);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      border: 1px solid #e5e7eb;
    }

    .tab-button-1:hover:not([aria-selected="true"]) {
      background-color: #f0f4ff;
      color: var(--azul-main, #1a3a6b);
      border-color: var(--azul-main, #1a3a6b);
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const wrapper = document.getElementById("tabs-wrapper");
      const allContents = document.querySelectorAll(".tab-content-1");
      const buttons = document.querySelectorAll(".tab-button-1");

      let currentObserver = null;
      const setWrapperHeight = (element) => {
        wrapper.style.height = element.scrollHeight + "px";
      };
      const observeActiveContent = (element) => {
        if (currentObserver) {
          currentObserver.disconnect();
        }
        currentObserver = new ResizeObserver(() => {
          setWrapperHeight(element);
        });
        currentObserver.observe(element);
      };
      const activeContent = document.querySelector(
        ".tab-content-1:not(.hidden)",
      );
      if (activeContent) {
        setWrapperHeight(activeContent);
        observeActiveContent(activeContent);
      }
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const targetId = btn.getAttribute("data-tab");
          const targetContent = document.querySelector(
            `.tab-content-1[data-tab-content="${targetId}"]`,
          );
          buttons.forEach((b) => b.setAttribute("aria-selected", "false"));
          btn.setAttribute("aria-selected", "true");
          allContents.forEach((c) => c.classList.add("hidden"));
          targetContent.classList.remove("hidden");
          setWrapperHeight(targetContent);
          observeActiveContent(targetContent);
        });
      });
      window.addEventListener("resize", () => {
        const active = document.querySelector(".tab-content-1:not(.hidden)");
        if (active) setWrapperHeight(active);
      });
    });
  </script>

  <script>
    document
      .querySelectorAll<HTMLButtonElement>(".mostrar-mas")
      .forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const expandible = btn.nextElementSibling as HTMLElement;
          const chevron = btn.querySelector(".chevron") as HTMLElement;
          const isOpen =
            expandible.style.maxHeight && expandible.style.maxHeight !== "0px";

          if (isOpen) {
            expandible.style.maxHeight = "0px";
            chevron.style.transform = "rotate(0deg)";
            btn.setAttribute("aria-expanded", "false");
          } else {
            expandible.style.maxHeight = expandible.scrollHeight + "px";
            chevron.style.transform = "rotate(180deg)";
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });
  </script>
</section>
