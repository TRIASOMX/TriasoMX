---
import GallerySlider from "../unitComponents/GallerySlider";
import { Image } from "astro:assets";
import Tred from "../../assets/images/AsphaltStorage/redT.webp";
import Separator from "../unitComponents/Separator.astro";
import sideP from "../../assets/images/SidePanels/TolvasFE.webp";
import LearnBtn from "../unitComponents/LearnBtn.astro";
import TwoColumnSection from "../unitComponents/TwoColumnSection.astro";
import BUFeeders from "../../assets/images/BinUnits/BUFeeders.webp";
import binHigh from "../../assets/images/BinUnits/binHigh.webp";
import img1 from "../../assets/images/BinUnits/TolvaCinta.webp";
import img2 from "../../assets/images/BinUnits/ProvBU1.webp";
import img3 from "../../assets/images/BinUnits/ProvBU3.webp";
import img4 from "../../assets/images/BinUnits/1.webp";
import img5 from "../../assets/images/BinUnits/2.webp";
import img6 from "../../assets/images/BinUnits/3.webp";
import Whatsbtn from "../unitComponents/Whatsbtn.astro";

import g29 from "../../assets/images/BinUnits/GallerySlider/Big/Cuadruple bin unit.webp";
import g25 from "../../assets/images/BinUnits/GallerySlider/Big/TlvP317P268A.webp";
import g26 from "../../assets/images/BinUnits/GallerySlider/Big/TlvP317P268B.webp";
import g27 from "../../assets/images/BinUnits/GallerySlider/Big/TlvP317P268C.webp";
import g28 from "../../assets/images/BinUnits/GallerySlider/Big/TlvP317P268D.webp";

const binSlides2 = [
  {
    image: g29.src,
    caption: "Cuadruple bin unit",
  },

  {
    image: g25.src,
    caption: "Triple plus hopper unit",
  },
  {
    image: g26.src,
    caption: "Triple plus hopper unit",
  },
  {
    image: g27.src,
    caption: "Triple plus hopper unit",
  },
  {
    image: g28.src,
    caption: "Triple plus hopper unit",
  },
];
---

<div class="w-full flex flex-col">
  <section>
    <TwoColumnSection
      leftBg="bg-redBg"
      rightBg="bg-blueMain"
      imageSrc={Tred.src}
      imageAlt="Red T icon"
      imageWidth="150px"
    >
      <div slot="left" class="flex flex-col justify-center gap-3">
        <h1 class="text-xl md:text-2xl">Nos adaptamos a su proyecto</h1>
        <p class="text-sm md:text-base lg:text-lg">
          Pueden personalizarse y adaptarse a diferentes requerimientos de
          manejo de materiales, ofreciendo eficiencia y confiabilidad en
          cualquier proyecto.
        </p>
        <Whatsbtn />
      </div>

      <div slot="right" class="flex flex-col justify-center gap-3">
        <h1 class="text-xl md:text-2xl">Servicio al cliente 24/7</h1>
        <p class="text-sm md:text-base lg:text-lg">
          Nuestro equipo está disponible en todo momento, listo para asistirte
          cuando lo necesites, incluso fines de semana y días festivos.
        </p>
        <Whatsbtn />
      </div>
    </TwoColumnSection>
  </section>

  <section>
    <div
      class="relative bg-gradient-to-b from-[#f1eeb8] to-white text-center py-20 px-6
                rounded-b-[60%]"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Agende una reunión</h2>

      <p class="text-sm md:text-base mb-8 max-w-2xl mx-auto">
        Cuéntenos más sobre su proyecto para identificar la solución industrial
        que mejor se ajuste a sus necesidades.
      </p>

      <button
        class="border border-black px-6 py-3 rounded-full hover:bg-black hover:text-white transition"
      >
        Ver horarios disponibles
      </button>
    </div>
  </section>

  <div class="w-full max-w-7xl px-8 mx-auto text-2xl md:text-4xl font-bold">
    <div class="flex flex-col max-w-7xl mx-auto items-center">
      <div
        class="grid grid-cols-2 lg:flex lg:flex-row items-center justify-center"
      >
        <div>
          <Image src={img4} alt="Triaso® Conveyor Rollers" class="" />
        </div>
        <div>
          <Image src={img5} alt="Triaso® Conveyor Rollers" class="" />
        </div>
        <div class="col-span-2">
          <Image
            src={img6}
            alt="Triaso® Conveyor Rollers"
            class="w-1/2 mx-auto lg:w-full lg:mx-0"
          />
        </div>
      </div>
      <div class="pt-4 pb-4">
        <h1 class="uppercase text-[#393939]">Rodillos de transportador</h1>
        <h1 class="text-[#393939]">Triaso®</h1>

        <p
          class="font-medium text-base md:text-xl font-[#393939] w-full md:w-4/6"
        >
          Nuestros rodillos de transportador para las bandas de las unidades de
          tolvas y los transportadores de agregados se fabrican con tapas en
          hierro fundido y tubería densa, fabricación completamente en casa,
          reduciendo la dependencia de proveedores externos para refacciones.
        </p>
      </div>
    </div>
  </div>

  <div
    class="relative bg-[url(/fondoAsp.webp)] hidden lg:flex md:flex bg-cover bg-center w-full"
  >
    <div class="absolute inset-0 bg-black/50"></div>
    <div
      class="relative w-full max-w-7xl px-8 lg:px-0 md:px-0 mx-auto py-10 grid grid-cols-1 gap-10"
    >
      <!-- 1 -->
      <div class="flex flex-col w-full md:flex-row lg:flex-row">
        <div class="text-white font-bold flex flex-col justify-center">
          <h1 class="text-2xl md:text-3xl">Equipo altamente portátil</h1><br />
          <p class="text-base md:text-lg lg:pr-8 md:pr-8">
            Entendemos la importancia de poner su equipo en operación lo más
            rápido posible. Nuestro equipo Triaso está diseñado para una
            instalación y puesta en marcha rápidas.
          </p>
        </div>
        <div class="w-full flex justify-center py-5">
          <Image
            src={binHigh}
            alt="Truck eqquipped with a bin system unit"
            class="w-full rounded-2xl"
          />
        </div>
      </div>

      <!-- 2 -->
      <div class="flex flex-col-reverse w-full lg:flex-row md:flex-row">
        <div class="w-full flex py-5 items-start justify-start">
          <Image
            src={img2}
            alt="Truck eqquipped with a bin system unit"
            class="lg:w-[80%] md:w-[80%] rounded-2xl"
          />
        </div>
        <div class="text-white font-bold flex flex-col justify-center">
          <h1 class="text-2xl md:text-3xl lg:text-end">
            En cualquier momento, en cualquier lugar
          </h1><br />
          <p class="text-base md:text-lg lg:text-end">
            Entendemos la importancia de que su equipo permanezca operando sin
            interrupciones.
          </p>
        </div>
      </div>

      <!-- 3 -->
      <div class="flex flex-col w-full md:flex-row lg:flex-row">
        <div class="text-white font-bold flex flex-col justify-center">
          <h1 class="text-2xl md:text-3xl">Almacenamiento sencillo</h1><br />
          <p class="text-base md:text-lg lg:pr-8 md:pr-8">
            Diseñado para facilitar su resguardo, nuestro equipo puede
            almacenarse de manera rápida y práctica en cualquier lugar.
          </p>
        </div>
        <div class="w-full flex justify-end py-5">
          <Image
            src={img3}
            alt="Bin system unit"
            class="lg:w-[80%] md:w-[80%] rounded-2xl"
          />
        </div>
      </div>
    </div>
  </div>

  <div
    class="relative bg-[url(/fondoAsp.webp)] flex flex-col lg:hidden md:hidden bg-cover bg-center w-full pb-10"
  >
    <div class="absolute inset-0 bg-black/50"></div>

    <div
      id="auto-slider"
      class="relative w-full max-w-7xl px-6 mx-auto pt-10 pb-4 gap-4 flex overflow-x-auto snap-x snap-mandatory [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
    >
      <div class="relative w-[85%] snap-center shrink-0">
        <div class="absolute inset-0 bg-white/15 rounded-2xl"></div>
        <div
          class="relative z-10 flex flex-col w-full md:flex-row lg:flex-row p-6"
        >
          <div class="text-white font-bold flex flex-col justify-center">
            <h1 class="text-2xl md:text-3xl">Equipo altamente portátil</h1>
            <br />
            <p class="text-base md:text-lg lg:pr-8 md:pr-8 font-normal">
              Entendemos la importancia de poner su equipo en operación lo más
              rápido posible. Nuestro equipo Triaso está diseñado para una
              instalación y puesta en marcha rápidas.
            </p>
          </div>
          <div class="w-full flex justify-center py-5">
            <Image
              src={binHigh}
              alt="Truck equipped with a bin system unit"
              class="w-full rounded-2xl"
            />
          </div>
        </div>
      </div>

      <div class="relative w-[85%] snap-center shrink-0">
        <div class="absolute inset-0 bg-white/15 rounded-2xl"></div>
        <div
          class="relative z-10 flex flex-col justify-around items-center w-full h-full p-6"
        >
          <div class="text-white font-bold flex flex-col justify-center">
            <h1 class="text-2xl md:text-3xl">
              En cualquier momento, en cualquier lugar
            </h1>
            <br />
            <p class="text-base md:text-lg lg:pr-8 md:pr-8 font-normal">
              Entendemos la importancia de que su equipo permanezca operando sin
              interrupciones.
            </p>
          </div>
          <div class="w-full flex justify-center py-5">
            <Image
              src={img2}
              alt="Truck equipped with a bin system unit"
              class="w-full rounded-2xl"
            />
          </div>
        </div>
      </div>

      <div class="relative w-[85%] snap-center shrink-0">
        <div class="absolute inset-0 bg-white/15 rounded-2xl"></div>
        <div
          class="relative z-10 flex flex-col justify-around items-center w-full h-full p-6"
        >
          <div class="text-white font-bold flex flex-col justify-center">
            <h1 class="text-2xl md:text-3xl">Almacenamiento sencillo</h1>
            <br />
            <p class="text-base md:text-lg lg:pr-8 md:pr-8 font-normal">
              Diseñado para facilitar su resguardo, nuestro equipo puede
              almacenarse de manera rápida y práctica en cualquier lugar.
            </p>
          </div>
          <div class="w-full flex justify-center py-5">
            <Image
              src={img3}
              alt="Truck equipped with a bin system unit"
              class="w-full rounded-2xl"
            />
          </div>
        </div>
      </div>
    </div>

    <div
      id="slider-dots"
      class="relative z-10 flex justify-center items-center gap-2 mt-2"
    >
      <div class="w-3 h-2.5 rounded-full bg-white transition-all"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-white/40 transition-all"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-white/40 transition-all"></div>
    </div>
  </div>
</div>

<script>
  const slider = document.getElementById("auto-slider");
  const dotsContainer = document.getElementById("slider-dots");

  if (slider && dotsContainer) {
    const slidesCount = slider.children.length;
    const dots = Array.from(dotsContainer.children);
    let index = 0;
    let resumeTimeout;
    let interval = setInterval(moveSlider, 3000);

    // 1. Función para actualizar visualmente los puntos
    function updateDots(activeIndex) {
      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          // Clases para el punto activo (más blanco y un poco más ancho)
          dot.className = "w-3 h-2.5 rounded-full bg-white transition-all";
        } else {
          // Clases para los puntos inactivos (transparentes)
          dot.className = "w-2.5 h-2.5 rounded-full bg-white/40 transition-all";
        }
      });
    }

    function moveSlider() {
      index = (index + 1) % slidesCount;
      const slideWidth = slider.children[0].offsetWidth;
      const gap = parseFloat(getComputedStyle(slider).gap) || 0;

      slider.scrollTo({
        left: (slideWidth + gap) * index,
        behavior: "smooth",
      });

      updateDots(index);
    }

    slider.addEventListener(
      "scroll",
      () => {
        const slideWidth = slider.children[0].offsetWidth;
        const gap = parseFloat(getComputedStyle(slider).gap) || 0;
        const currentIndex = Math.round(slider.scrollLeft / (slideWidth + gap));

        if (currentIndex !== index) {
          index = currentIndex;
          updateDots(index);
        }
      },
      { passive: true },
    );

    function pauseAutoplay() {
      clearInterval(interval);
      clearTimeout(resumeTimeout);

      resumeTimeout = setTimeout(() => {
        interval = setInterval(moveSlider, 4000);
      }, 2000);
    }

    slider.addEventListener("touchstart", pauseAutoplay, { passive: true });
    updateDots(index);
  }
</script>
