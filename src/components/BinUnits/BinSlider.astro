---
import img1 from "../../assets/images/AsphaltStorage/sedenaBG.jpg"
import img2 from "../../assets/images/AsphaltStorage/Low/versatil.webp"

const slides = [
  {
    id: 1,
    title: "Vibrador en tolva de finos para flujo continuo de material",
    description:
      "Equipada con un vibrador en la tolva de finos para evitar la acumulación de material causada por la humedad y asegurar un flujo continuo de alimentación.",
      image: "https://placehold.co/600x400/png",
    },
  {
    id: 2,
    title: "Sistemas de dosificación de precisión en unidades de tolvas",
    description:
      "Desde nuestros inicios como fabricantes de plantas de asfalto, identificamos un problema en la mayoría de las plantas del mercado: la dosificación de agregados basada únicamente en peso y no en volumen. Este enfoque limita la precisión del diseño de mezcla, ya que el peso de los agregados varía con la humedad, mientras que el volumen se mantiene constante.",
    image: "https://placehold.co/600x400/png",
  },
  {
    id: 3,
    title: "Sistemas de dosificación por volumen preciso",
    description:
      "Nuestras tolvas están equipadas con sistemas de dosificación avanzados, diseñados para ofrecer la máxima precisión y confiabilidad. Garantizamos un flujo y una distribución exacta del material, cumpliendo con las necesidad de proyectos con especificaciones de exactitud.",
      image: "https://placehold.co/600x400/png",
    },
  {
    id: 4,
    title: "Flancos estéticos",
    description:
      "Estos paneles que destacan originalidad brindan un aspecto limpio, moderno y estético que refleja calidad y atención al detalle, dejando una fuerte impresión en clientes, inspectores y en el público. Ideales para proyectos en zonas urbanas o de alta visibilidad, refuerzan el compromiso de su marca con la excelencia y mejoran la presentación general de su planta de asfalto.",
    image: "https://placehold.co/600x400/png",
  },
  {
    id: 5,
    title: "Alimentadores de banda ",
    description:
      "Nuestros alimentadores de banda están equipados con poleas de cabeza y cola recubiertas de hule, lo que proporciona una tracción firme y minimiza el deslizamiento durante la operación. Este diseño aumenta la resistencia al desgaste, reduce el deterioro de la banda y garantiza un desempeño confiable incluso bajo cargas pesadas y en condiciones de trabajo exigentes.",
    image: "https://placehold.co/600x400/png",
  },
];

const duplicatedSlides = [...slides, ...slides];
---

<section class="pb-5">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-center text-[#14427c] font-bold text-2xl md:text-3xl mb-10">
      Eficiencia térmica que reduce el consumo de combustible.
    </h2>

    <div class="relative">
      <div class="overflow-hidden" id="slider-wrapper">
        <div
          class="flex gap-6 transition-transform duration-500 ease-in-out"
          id="slider-track"
        >
          {
            duplicatedSlides.map((slide, index) => (
              <div
                class="
                  slide-item
                  flex-shrink-0
                  w-full
                  sm:w-[calc(50%-12px)]
                  lg:w-[calc(40%-16px)]
                  relative
                  rounded-xl
                  overflow-hidden
                  min-h-[280px]
                  md:min-h-[320px]
                "
                data-index={index}
              >
                <img
                  src={slide.image}
                  alt={slide.title}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
                  <h3 class="font-bold text-xl mb-2">{slide.title}</h3>
                  <p class="text-sm text-gray-200 leading-relaxed">
                    {slide.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <button
        id="prev-btn"
        class="absolute left-0 top-1/2 -translate-y-1/2 lg:-translate-x-12 md:-translate-x-4 z-10 bg-white border border-gray-200 rounded-full w-10 h-10 flex items-center justify-center shadow-md hover:bg-gray-50 transition-colors hidden md:flex"
        aria-label="Anterior"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 text-gray-700"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        id="next-btn"
        class="absolute right-0 top-1/2 -translate-y-1/2 lg:translate-x-12 md:translate-x-4 z-10 bg-white border border-gray-200 rounded-full w-10 h-10 flex items-center justify-center shadow-md hover:bg-gray-50 transition-colors hidden md:flex"
        aria-label="Siguiente"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 text-gray-700"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <div class="flex justify-center gap-2 mt-6" id="dots-container">
      {
        slides.map((_, i) => (
          <button
            class="dot w-3 h-3 rounded-full transition-colors duration-300"
            data-dot={i}
            aria-label={`Ir al slide ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  (function () {
    const track = document.getElementById("slider-track") as HTMLElement;
    const wrapper = document.getElementById("slider-wrapper") as HTMLElement;
    const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
    const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
    const dotsContainer = document.getElementById(
      "dots-container"
    ) as HTMLElement;
    const dots = dotsContainer.querySelectorAll<HTMLButtonElement>(".dot");

    const TOTAL_SLIDES = 5;
    let currentIndex = 0;
    let slidesVisible = getSlidesVisible();
    let isTransitioning = false;
    let autoplayTimer: ReturnType<typeof setInterval>;

    function getSlidesVisible(): number {
      const w = window.innerWidth;
      if (w >= 1024) return 3;
      if (w >= 640) return 2;
      return 1;
    }

    function getSlideWidth(): number {
      const gap = 24;
      const slideItems = track.querySelectorAll<HTMLElement>(".slide-item");
      if (!slideItems.length) return 0;
      return slideItems[0].offsetWidth + gap;
    }

    function updateTrack(animate = true) {
      const offset = currentIndex * getSlideWidth();
      if (!animate) {
        track.style.transition = "none";
      } else {
        track.style.transition = "transform 500ms ease-in-out";
      }
      track.style.transform = `translateX(-${offset}px)`;
    }

    function updateDots() {
      const realIndex = currentIndex % TOTAL_SLIDES;
      dots.forEach((dot, i) => {
        if (i === realIndex) {
          dot.classList.add("bg-white");
          dot.classList.remove("bg-gray-400");
        } else {
          dot.classList.remove("bg-white");
          dot.classList.add("bg-gray-400");
        }
      });
    }

    function goToNext() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      updateTrack(true);

      if (currentIndex >= TOTAL_SLIDES) {
        setTimeout(() => {
          currentIndex = currentIndex % TOTAL_SLIDES;
          updateTrack(false);
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              isTransitioning = false;
            });
          });
        }, 510);
      } else {
        setTimeout(() => {
          isTransitioning = false;
        }, 510);
      }
      updateDots();
    }

    function goToPrev() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex--;
      if (currentIndex < 0) {
        currentIndex = TOTAL_SLIDES - 1;
        updateTrack(false);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            track.style.transition = "transform 500ms ease-in-out";
            currentIndex--;
            if (currentIndex < 0) currentIndex = TOTAL_SLIDES - 1;
            updateTrack(true);
            setTimeout(() => {
              isTransitioning = false;
            }, 510);
          });
        });
      } else {
        updateTrack(true);
        setTimeout(() => {
          isTransitioning = false;
        }, 510);
      }
      updateDots();
    }

    function goToSlide(index: number) {
      if (isTransitioning) return;
      currentIndex = index;
      updateTrack(true);
      updateDots();
    }

    function startAutoplay() {
      autoplayTimer = setInterval(goToNext, 4000);
    }

    function stopAutoplay() {
      clearInterval(autoplayTimer);
    }

    function onResize() {
      slidesVisible = getSlidesVisible();
      updateTrack(false);
    }

    nextBtn?.addEventListener("click", () => {
      stopAutoplay();
      goToNext();
      startAutoplay();
    });

    prevBtn?.addEventListener("click", () => {
      stopAutoplay();
      goToPrev();
      startAutoplay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        stopAutoplay();
        goToSlide(i);
        startAutoplay();
      });
    });

    let touchStartX = 0;
    wrapper?.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
      stopAutoplay();
    });
    wrapper?.addEventListener("touchend", (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? goToNext() : goToPrev();
      }
      startAutoplay();
    });

    window.addEventListener("resize", onResize);

    updateDots();
    startAutoplay();
  })();
</script>