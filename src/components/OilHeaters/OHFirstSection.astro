---
import oil from "../../assets/images/AsphaltPlant/oil1.webp";
import img1 from "../../assets/images/OilHeaters/21.webp";
import img2 from "../../assets/images/OilHeaters/23.webp";
import img3 from "../../assets/images/OilHeaters/24.webp";
import img4 from "../../assets/images/OilHeaters/22.webp";
import HeroComponent from "../unitComponents/HeroComponent.astro";
import OHOdometer from "./OHOdometer";
import { Image } from "astro:assets";
---

<section>
    <HeroComponent
        title="Calderas de aceite térmico"
        image="https://placehold.co/1920x1080/png"
        imageAlt="alt"
        altImage={oil.src}
        descAltImage="Caldera"
    />
    <div class="bg-[#1e1e1e]">
        <div class="max-w-7xl mx-auto px-8 space-y-10 py-10">
            <div class="flex justify-center items-center text-center">
                <h1 class="font-semibold text-white text-lg lg:text-xl">
                    Diseñados para una regulación precisa de la temperatura,
                    nuestras de aceite térmico garantizan una distribución
                    uniforme del calor en el tanque de asfalto —o en cualquier
                    sistema que requiera calentamiento constante. Gracias a su
                    diseño de circulación de aceite térmico, ofrecen un
                    desempeño óptimo, evitando puntos calientes y manteniendo la
                    estabilidad de temperatura en todo el proceso, siendo
                    capaces de conectarse a más sistemas de calentamiento de la
                    planta de asfalto.
                </h1>
            </div>
        </div>
    </div>
</section>

<section
    class="w-full mt-20 md:mt-32 font-bold text-grisT flex flex-col gap-10"
>
    <OHOdometer client:only />

    <div
