                instalación rápida
            </h3>

            <p
                class="text-sm md:text-base text-grisT font-light leading-relaxed"
            >
                sin maquinaria pesada, ideales para operaciones reubicables
            </p>
        </div>

        <!-- ITEM -->
        <div
            class="flex flex-col items-center text-center lg:items-start lg:text-start gap-2"
        >
            <Image
                src={img2}
                alt="Location icon"
                class="w-[160px] md:w-[180px] object-contain"
            />
            <p
                class="text-sm md:text-base text-grisT font-light leading-relaxed"
