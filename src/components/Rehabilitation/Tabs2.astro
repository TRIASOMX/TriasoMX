---
import Card from "../unitComponents/Card.astro";
---

<section
  class="w-full flex flex-col items-center justify-center gap-4 bg-grisT px-8 lg:px-52"
  data-tabs
>
  <div class="flex flex-col items-center justify-center gap-4 mt-8">
    <div
      role="tablist"
      aria-label="Characteristics tabs"
      class="flex items-end justify-around w-full gap-4"
    >
      <button
        class="text-xl md:text-2xl tab-button py-2 md:px-4 font-bold focus:outline-none"
        data-tab="tab1"
        role="tab"
        aria-selected="true"
      >
        Soporte y evaluación directa
      </button>
      <button
        class="tab-button py-2 md:px-4 font-bold text-xl md:text-2xl focus:outline-none"
        data-tab="tab2"
        role="tab"
        aria-selected="false"
      >
        Enfoque en cumplimiento y seguridad.
      </button>
    </div>
    <div class="py-4">
      <!-- First Section -->
      <div
        class="w-full flex flex-col items-center justify-center gap-14 my-10 tab-content text-base md:text-lg text-grisT font-bold"
        data-tab-content="tab1"
      >
        <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-24">
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Evaluaciones en sitio o remotas
            </h2><br />
            <p class="text-center font-thin text-base md:text-lg text-black">
              Contáctenos para una evaluación sin compromiso por parte de
              nuestros especialistas.
            </p>
          </Card>
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Asesoría completa de principio a fin
            </h2><br />
            <p class="text-center font-thin text-base md:text-lg text-black">
              Ya sea una reparación rápida o una modernización completa,
              nuestros expertos lo guiarán en cada etapa del proceso.
            </p>
          </Card>
        </div>
        <div>
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Calidad de fábrica en su planta existente
            </h2><br />
            <p
              class="text-center font-thin text-base md:text-lg text-black md:px-20"
            >
              Aplicamos los mismos estándares utilizados en la fabricación de
              nuestros equipos nuevos en cada proyecto de rehabilitación.
            </p>
          </Card>
        </div>
      </div>
      <!-- Second Section -->
      <div
        class="w-full flex flex-col items-center justify-center gap-14 my-10 md:gap-10 mt-4 tab-content text-base md:text-lg text-grisT font-bold"
        data-tab-content="tab2"
      >
        <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-24">
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Cumplimiento normativo
            </h2><br />
            <p class="text-center font-thin text-base md:text-lg text-black">
              Actualizamos sus equipos para cumplir con las regulaciones
              ambientales y de seguridad más recientes.
            </p>
          </Card>
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Mayor seguridad para el operador
            </h2><br />
            <p class="text-center font-thin text-base md:text-lg text-black">
              Mejoramos guardas, controles y sistemas de protección para una
              operación más segura de la planta.
            </p>
          </Card>
        </div>
        <div>
          <Card>
            <h2 class="text-center font-bold text-xl md:text-2xl text-black">
              Emisiones más limpias
            </h2><br />
            <p
              class="text-center font-thin text-base md:text-lg text-black w-full md:px-20"
            >
              Podemos integrar sistemas de control de emisiones, como casas de
              bolsas o scrubbers, para cumplir con los estándares modernos.
            </p>
          </Card>
        </div>
      </div>
    </div>
  </div>
</section>
<style is:inline>
  /* Estilos para los tabs activos */
  .tab-button[aria-selected="true"] {
    color: #6b97c6;
    border-bottom: 2px solid var(--rojo-btn);
  }

  .tab-button[aria-selected="false"] {
    color: white;
    border-bottom: 2px solid white;
  }

  .tab-button:hover:not([aria-selected="true"]) {
    color: #6b97c6;
    border-bottom: 2px solid var(--rojo-btn);
  }
</style>
<script is:inline>
  (function initTabs() {
    document.querySelectorAll("section[data-tabs]").forEach((tabSection) => {
      const tabButtons = tabSection.querySelectorAll(".tab-button");
      const tabContents = tabSection.querySelectorAll(".tab-content");

      // Ocultar todos menos el primero
      const selectedTab = tabSection.querySelector(
        '.tab-button[aria-selected="true"]',
      );
      const selectedTabId = selectedTab?.getAttribute("data-tab");

      tabContents.forEach((content) => {
        const contentTabId = content.getAttribute("data-tab-content");
        content.classList.toggle("hidden", contentTabId !== selectedTabId);
      });

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const tabId = button.getAttribute("data-tab");

          tabButtons.forEach((btn) =>
            btn.setAttribute("aria-selected", "false"),
          );
          button.setAttribute("aria-selected", "true");

          tabContents.forEach((content) => {
            content.classList.add("hidden");
          });

          const activeContent = tabSection.querySelector(
            `.tab-content[data-tab-content="${tabId}"]`,
          );
          if (activeContent) activeContent.classList.remove("hidden");
        });
      });
    });
  })();
</script>
