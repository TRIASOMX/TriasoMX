---
import Logo from "../../assets/logos/LogoTriasoUs.webp";
import Phone from "../../assets/iconos/phone.svg";
import Mail from "../../assets/iconos/mail-2.svg";
import { Image } from "astro:assets";
import { Facebook, Instagram, Linkedin } from "lucide-react";
---

<footer class="bg-[#252726] text-white">
  <div class="max-w-7xl mx-auto py-5">
    <div
      class="grid grid-cols-1 items-center justify-evenly lg:grid-cols-2 space-y-10"
    >
      <!-- logo -->
      <div
        class="flex flex-col items-center justify-center lg:items-start space-y-10"
      >
        <Image src={Logo} alt="Triaso US" class="w-4/6" />
        <p class="text-xs px-8 lg:px-0 md:px-0">
          Triaso we are a leading company in manufacturing and engineering
          development.
        </p>
      </div>

      <div
        class="flex flex-col lg:flex-row justify-evenly items-start px-8 space-y-5 lg:space-y-0 md:space-y-0"
      >
        <!-- 1 -->
        <div class="">
          <h4
            class="text-sm font-semibold uppercase tracking-wide mb-4 border-b border-white pb-2"
          >
            Quick Links
          </h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/AsphaltPlant" class="hover:text-gray-400">Asphalt Plants</a
              >
            </li>
            <li><a href="/AsphaltStorage" class="hover:text-gray-400">Integral Asphalt Plants</a></li>
            <li>
              <a href="/Relief" class="hover:text-gray-400">TRIASO Relief</a>
            </li>
          </ul>
        </div>

        <!-- 2 -->
        <div class="">
          <h4
            class="text-sm font-semibold uppercase tracking-wide mb-4 border-b border-white pb-2"
          >
            About
          </h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/AboutUs" class="hover:text-gray-400">About us</a></li>
            <li><a href="/Newsroom" class="hover:text-gray-400">News Room</a></li>
            <li><a href="/Expo" class="hover:text-gray-400">Expos</a></li>
          </ul>
        </div>

        <!-- 3 -->
        <div>
          <h4
            class="text-sm font-semibold uppercase tracking-wide mb-4 border-b border-white pb-2"
          >
            Contact Us
          </h4>

          <a
            href="https://wa.me/+12487608028"
            target="_blank"
            class="inline-flex items-center gap-2 bg-[#075e54] hover:bg-teal-600 text-white px-5 py-2 rounded-full text-sm mb-4"
          >
            WhatsApp
            <span class="text-lg"
              ><svg
                fill="#ffffff"
                width="20"
                height="20"
                viewBox="0 0 32 32"
                version="1.1"
                xmlns="http://www.w3.org/2000/svg"
                stroke="#ffffff"
                ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                  id="SVGRepo_tracerCarrier"
                  stroke-linecap="round"
                  stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                  <title>whatsapp</title>
                  <path
                    d="M26.576 5.363c-2.69-2.69-6.406-4.354-10.511-4.354-8.209 0-14.865 6.655-14.865 14.865 0 2.732 0.737 5.291 2.022 7.491l-0.038-0.070-2.109 7.702 7.879-2.067c2.051 1.139 4.498 1.809 7.102 1.809h0.006c8.209-0.003 14.862-6.659 14.862-14.868 0-4.103-1.662-7.817-4.349-10.507l0 0zM16.062 28.228h-0.005c-0 0-0.001 0-0.001 0-2.319 0-4.489-0.64-6.342-1.753l0.056 0.031-0.451-0.267-4.675 1.227 1.247-4.559-0.294-0.467c-1.185-1.862-1.889-4.131-1.889-6.565 0-6.822 5.531-12.353 12.353-12.353s12.353 5.531 12.353 12.353c0 6.822-5.53 12.353-12.353 12.353h-0zM22.838 18.977c-0.371-0.186-2.197-1.083-2.537-1.208-0.341-0.124-0.589-0.185-0.837 0.187-0.246 0.371-0.958 1.207-1.175 1.455-0.216 0.249-0.434 0.279-0.805 0.094-1.15-0.466-2.138-1.087-2.997-1.852l0.010 0.009c-0.799-0.74-1.484-1.587-2.037-2.521l-0.028-0.052c-0.216-0.371-0.023-0.572 0.162-0.757 0.167-0.166 0.372-0.434 0.557-0.65 0.146-0.179 0.271-0.384 0.366-0.604l0.006-0.017c0.043-0.087 0.068-0.188 0.068-0.296 0-0.131-0.037-0.253-0.101-0.357l0.002 0.003c-0.094-0.186-0.836-2.014-1.145-2.758-0.302-0.724-0.609-0.625-0.836-0.637-0.216-0.010-0.464-0.012-0.712-0.012-0.395 0.010-0.746 0.188-0.988 0.463l-0.001 0.002c-0.802 0.761-1.3 1.834-1.3 3.023 0 0.026 0 0.053 0.001 0.079l-0-0.004c0.131 1.467 0.681 2.784 1.527 3.857l-0.012-0.015c1.604 2.379 3.742 4.282 6.251 5.564l0.094 0.043c0.548 0.248 1.25 0.513 1.968 0.74l0.149 0.041c0.442 0.14 0.951 0.221 1.479 0.221 0.303 0 0.601-0.027 0.889-0.078l-0.031 0.004c1.069-0.223 1.956-0.868 2.497-1.749l0.009-0.017c0.165-0.366 0.261-0.793 0.261-1.242 0-0.185-0.016-0.366-0.047-0.542l0.003 0.019c-0.092-0.155-0.34-0.247-0.712-0.434z"
                  ></path>
                </g></svg
              ></span
            >
          </a>

          <div class="text-sm space-y-1">
            <a href=" tel:+12486134885
            " class="hover:text-gray-400">
              <div class="flex flex-row gap-2">
                <Phone />
                <p>+1 (248)-613-4885</p>
              </div>
            </a>

            <a
              href="mailto:sales@triasous.com"
              class="underline hover:text-gray-400"
            >
              <div class="flex flex-row gap-2">
                <Mail />
                <p> sales@triasous.com </p>
              </div>
            </a>
          </div>

          <!-- SOCIAL -->
          <div class="flex gap-4 mt-6">
            <a
              href="https://www.linkedin.com/company/triaso-us/"
              aria-label="Linkedin"
              class="hover:text-gray-400"
              target="_blank"
            >
              <Linkedin />
            </a>
            <a
              href="https://www.instagram.com/triaso.us"
              aria-label="Instagram"
              class="hover:text-gray-400"
              target="_blank"
            >
              <Instagram />
            </a>

            <a
              href="https://www.facebook.com/people/Triaso-US/61560859853884/"
              aria-label="Facebook"
              class="hover:text-gray-400"
              target="_blank"
            >
              <Facebook />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- bottom -->
    <div
      class="flex flex-col lg:flex-row gap-10 items-center justify-center mt-5 text-center text-xs text-white"
    >
      <p class="text-xs">Copyright © 2026 Triaso – All rights reserved</p>
      <a href="/TermsandConditions" class="hover:text-gray-400"
        >Terms & Conditions</a
      >
      <a href="/PrivacyPolicy" class="hover:text-gray-400">Privacy Policy</a>
    </div>
  </div>
</footer>
