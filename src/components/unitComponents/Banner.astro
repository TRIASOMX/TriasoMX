---
import { Image } from "astro:assets";
import OSHand from "../../assets/images/OSHand.webp";
import Slider from "../IntegralAsphalt/SliderOsIntegral";
---

<section class="bg-white overflow-visible">
    <div class="max-w-7xl mx-auto lg:px-0">
        <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12">
            <!-- Texto -->
            <div class="text-white max-w-xl px-8">
                <h1
                    class="text-2xl md:text-3xl font-semibold my-6 bg-gradient-to-r from-[#f8ad00] via-[#dc363a] to-[#3992ff] bg-clip-text text-transparent"
                >
                    Sistema de operación Triaso® − Relief
                </h1>
                <p class="text-[#393939] font-semibold leading-relaxed">
                    Ofrecemos una forma práctica y eficiente de gestionar el
                    funcionamiento de nuestros equipos. Gracias a sistemas
                    avanzados de monitoreo y automatización, <span
                        class="text-black"
                        >simplificamos tanto el manejo de los equipos como el
                        trabajo de la tripulación.
                    </span> Control total de cada etapa de la producción, con un seguimiento
                    completo de todos los datos operativos.
                </p>
                <div class="pt-5 flex items-center justify-center">
                    <a
                        href="/Relief"
                        aria-label="View page drum Mixers"
                        class="text-white text-center mb-5 mt-5 text-xs md:text-sm font-normal border-2 border-[#14427c] rounded-full py-2 px-6 transition-all duration-300 ease-out transform hover:scale-110 hover:shadow-lg bg-[#14427c] hover:bg-white hover:text-black hover:border-white"
                    >
                        Ver más
                    </a>
                </div>
            </div>

            <!-- Imagen -->
            <div class="flex justify-end relative">
                <Image
                    src={OSHand}
                    alt="Triaso OS"
                    class="w-[280px] md:w-[360px] lg:w-[420px]"
                />
            </div>
        </div>

        <Slider client:only />
    </div>
</section>

<div class="flex flex-col md:grid md:grid-cols-4 w-full  h-[30vh]">
    <div
        class="bg-blueMain col-span-2 md:col-span-1 w-full h-auto md:h-full flex flex-col justify-center items-center gap-4 p-4"
    >
        <!-- Botón 1 -->
        <button
            class="bg-[#075e54] text-white text-sm md:text-lg rounded-full w-full py-2 flex items-center justify-center gap-2 shadow-md hover:bg-verdeWhats/80"
        >
            Hable con un experto
            <svg
                width="24px"
                height="24px"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                color="#FFFFFF"
            >
                <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M12 1.25C17.9371 1.25 22.75 6.06294 22.75 12C22.75 17.9371 17.9371 22.75 12 22.75C10.1409 22.75 8.39016 22.2775 6.86335 21.4455L2.12395 22.2397C1.88692 22.2794 1.6452 22.2031 1.47391 22.0345C1.30261 21.8659 1.2225 21.6255 1.25845 21.3878L2.05878 16.0977C1.53735 14.8339 1.25001 13.4496 1.25001 12C1.25001 6.06294 6.06295 1.25 12 1.25ZM7.94309 6.7002C7.20774 6.7002 6.599 7.32056 6.71374 8.08595C6.929 9.52188 7.56749 12.1676 9.46536 14.0799C11.4494 16.0789 14.2876 16.9343 15.8259 17.2715C16.6211 17.4459 17.3 16.8158 17.3 16.0387V14.2151C17.3 14.0909 17.2235 13.9796 17.1076 13.935L15.1475 13.1825C15.0949 13.1623 15.0377 13.1573 14.9824 13.1681L13.0048 13.5542C11.7304 12.894 10.958 12.1532 10.4942 11.0387L10.867 9.02365C10.8769 8.97021 10.8721 8.91508 10.8531 8.86416L10.1182 6.89529C10.0744 6.77797 9.96233 6.7002 9.83711 6.7002H7.94309Z"
                    fill="#FFFFFF"></path>
            </svg>
        </button>

        <!-- Botón 2 (añade el segundo botón) -->
        <button
            class="bg-blueSecondary border-white border border- text-white text-sm md:text-lg rounded-full w-full py-2 flex items-center justify-center gap-2 shadow-md hover:bg-[#0044A4]/80"
        >
            Solicite una cotización
            <svg
                width="24px"
                height="24px"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                color="#FFFFFF"
            >
                <!-- Icono del segundo botón (opcional) -->
                <path
                    d="M5 12H19M19 12L12 5M19 12L12 19"
                    stroke="#FFFFFF"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
        </button>
    </div>
    <div
        class="bg-blueSecondary col-span-2 md:col-span-3 w-full h-full px-8 py-8 flex flex-col text-white justify-center items-start md:items-end"
    >
        <h1
            class="font-bold text-base md:text-2xl mb-2 text-center md:text-end"
        >
            Alta productividad y calidad a precios competitivos
        </h1>
        <br />
        <p
            class="text-sm md:text-lg font-bold text-grisSubP text-center md:text-end"
        >
            Los contratistas que nos conocen prefieren Triaso sobre otras marcas
            por nuestra alta calidad, confiabilidad y precios.
        </p>
    </div>
</div>

<script is:inline>
    let currentSlide = 0;
    const slider = document.getElementById("slider");

    function getVisibleSlides() {
        if (window.innerWidth >= 1024) return 4;
        if (window.innerWidth >= 640) return 2;
        return 1;
    }

    function nextSlide() {
        const visible = getVisibleSlides();
        const total = slider.children.length;
        currentSlide = (currentSlide + 1) % (total - visible + 1);
        slider.style.transform = `translateX(-${currentSlide * (100 / visible)}%)`;
    }

    function prevSlide() {
        const visible = getVisibleSlides();
        const total = slider.children.length;
        currentSlide =
            (currentSlide - 1 + (total - visible + 1)) % (total - visible + 1);
        slider.style.transform = `translateX(-${currentSlide * (100 / visible)}%)`;
    }
</script>
