---
import LearnBtnBlue from "./LearnBtnBlue.astro";
---

<div class="mt-10 max-w-7xl mx-auto pb-5 lg:px-8 w-full">
    <div
        class="flex justify-center items-center lg:text-xl text-sm p-4 rounded-2xl"
    >
        <p class="text-center text-black font-bold">
            La estética industrial realza el atractivo visual de su negocio.
        </p>
    </div>
    <div
        class="flex md:grid md:grid-cols-3 gap-4
           overflow-x-auto md:overflow-visible
           snap-x snap-mandatory
           px-4 md:px-0
           scroll-smooth"
    >
        <!-- primero -->
        <div
            class="snap-center shrink-0 w-[85%] md:w-full
             bg-[url('/Gallery/drum-mixer.webp')]
             bg-cover bg-center bg-no-repeat
             rounded-2xl flex flex-col relative
             items-center justify-center
             border-2 border-black
             p-4 min-h-[300px]"
        >
            <div
                class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center p-4 rounded-2xl text-center"
            >
                <h1 class="text-white text-xl md:text-2xl font-bold px-2">
                    FABRICACIÓN
                </h1>
                <p class="text-grisSubP text-sm md:text-base mt-2 md:mt-3 px-2">
                    Fabricamos directamente, sin subcontratistas, lo que
                    garantiza que cada pieza cumpla con nuestros estrictos
                    estándares de calidad.
                </p>
                <div class="mt-3 md:mt-4">
                    <LearnBtnBlue
                        href="/Manufacture"
                        className="bg-blueMain text-sm md:text-base"
                    />
                </div>
            </div>
        </div>

        <!-- segundo -->
        <div
            class="snap-center shrink-0 w-[85%] md:w-full
             bg-[url('/Gallery/Boxes.webp')]
             bg-cover bg-center bg-no-repeat
             rounded-2xl flex flex-col relative
             items-center justify-center
             border-2 border-black
             p-4 min-h-[300px]"
        >
            <div
                class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center p-4 rounded-2xl text-center"
            >
                <h1 class="text-white text-xl md:text-2xl font-bold px-2">
                    PIEZAS DE REPUESTO
                </h1>
                <p class="text-grisSubP text-sm md:text-base mt-2 md:mt-3 px-2">
                    Las piezas de repuesto de Triaso están diseñadas con
                    precisión para garantizar un rendimiento óptimo, lo que
                    prolonga tanto la vida útil de la pieza como la del equipo
                    en su conjunto.
                </p>
                <div class="mt-3 md:mt-4">
                    <LearnBtnBlue
                        href="/Spare"
                        className="bg-blueMain text-sm md:text-base"
                    />
                </div>
            </div>
        </div>

        <!-- tercero -->
        <div
            class="snap-center shrink-0 w-[85%] md:w-full
             bg-[url('/Gallery/customdes.webp')]
             bg-cover bg-center bg-no-repeat
             rounded-2xl flex flex-col relative
             items-center justify-center
             border-2 border-black
             p-4 min-h-[300px]"
        >
            <div
                class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center p-4 rounded-2xl text-center"
            >
                <h1 class="text-white text-xl md:text-2xl font-bold px-2">
                    DISEÑO PERSONALIZADO
                </h1>
                <p class="text-grisSubP text-sm md:text-base mt-2 md:mt-3 px-2">
                    Además de nuestros diseños estandarizados, nos
                    especializamos en ofrecer soluciones personalizadas que se
                    adaptan a las necesidades específicas de nuestros clientes.
                </p>
                <div class="mt-3 md:mt-4">
                    <LearnBtnBlue
                        href="/CustomDesign"
                        className="bg-blueMain text-sm md:text-base"
                    />
                </div>
            </div>
        </div>
    </div>
</div>
