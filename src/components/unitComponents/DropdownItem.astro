---
export interface SubItem {
  subLabel: string;
}

export interface DropdownItem {
  label: string;
  subItems?: SubItem[];
}

export interface DropdownPanel {
  title: string;
  items: DropdownItem[];
}

export interface Props {
  panels: DropdownPanel[];
}

const { panels = [] } = Astro.props;
---

<section class="dropdown-group w-full px-4 py-8 font-sans">
  <div class="hidden md:grid md:grid-cols-3 gap-5">
    {panels.map((panel, i) => (
      <div class="dropdown-card" data-index={i}>
        <button
          class="dropdown-trigger w-full flex items-center justify-between gap-3 px-5 py-4 rounded-2xl bg-[#14427c] text-white font-semibold text-sm leading-tight text-left cursor-pointer select-none"
          aria-expanded="false"
          aria-controls={`panel-${i}`}
        >
          <span class="flex-1">{panel.title}</span>
          <span class="trigger-icon flex-shrink-0 w-8 h-8 rounded-full border-2 border-white flex items-center justify-center">
            <svg class="plus-icon w-4 h-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none">
              <line x1="8" y1="2" x2="8" y2="14" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
              <line x1="2" y1="8" x2="14" y2="8" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>

        <div
          id={`panel-${i}`}
          class="dropdown-content overflow-hidden max-h-0 opacity-0 transition-[max-height,opacity] duration-500 ease-in-out"
        >
          <ul class="mt-3 ml-2 space-y-3 pb-2">
            {panel.items.map((item) => (
              <li class="group/item">
                <div class="flex items-start gap-3 text-sm text-black leading-snug">
                  <span class="mt-[6px] flex-shrink-0 w-2 h-2 rounded-full bg-[#0d2d6b]" aria-hidden="true"></span>
                  <span class=" transition-colors duration-200">{item.label}</span>
                </div>

                {item.subItems && item.subItems.length > 0 && (
                  <ul class="mt-2 ml-5 pl-3 border-l-2 border-[#0d2d6b]/20 space-y-1.5">
                    {item.subItems.map((sub) => (
                      <li class="flex items-start gap-2.5 text-sm text-black leading-snug group/sub">
                        <span class="mt-[6px] flex-shrink-0 w-1.5 h-1.5 rounded-full bg-gray-400 " aria-hidden="true"></span>
                        <span class="font-medium transition-colors duration-200 ">{sub.subLabel}</span>
                      </li>
                    ))}
                  </ul>
                )}

              </li>
            ))}
          </ul>
        </div>

      </div>
    ))}
  </div>

  <div
    class="md:hidden flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4"
    style="scrollbar-width: none; -ms-overflow-style: none;"
  >
    {panels.map((panel, i) => (
      <div class="snap-center flex-shrink-0 w-[80vw] max-w-xs rounded-2xl bg-[#0d2d6b] overflow-hidden shadow-lg">

        <!-- Mobile header -->
        <div class="px-5 py-4 flex items-center justify-between gap-3">
          <span class="text-white font-semibold text-sm leading-tight flex-1">{panel.title}</span>
          <span class="flex-shrink-0 w-8 h-8 rounded-full border-2 border-white/40 flex items-center justify-center opacity-40" aria-hidden="true">
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
              <line x1="8" y1="2" x2="8" y2="14" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
              <line x1="2" y1="8" x2="14" y2="8" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>

        <div class="bg-white mx-3 mb-3 rounded-xl px-4 py-4">
          <ul class="space-y-3">
            {panel.items.map((item) => (
              <li>
                <div class="flex items-start gap-3 text-sm text-[#1a2a4a] leading-snug">
                  <span class="mt-[6px] flex-shrink-0 w-2 h-2 rounded-full bg-[#0d2d6b]" aria-hidden="true"></span>
                  <span class="font-semibold">{item.label}</span>
                </div>

                {item.subItems && item.subItems.length > 0 && (
                  <ul class="mt-1.5 ml-5 pl-3 border-l-2 border-[#0d2d6b]/20 space-y-1">
                    {item.subItems.map((sub) => (
                      <li class="flex items-start gap-2.5 text-sm text-[#3a4f70] leading-snug">
                        <span class="mt-[6px] flex-shrink-0 w-1.5 h-1.5 rounded-full bg-[#0d2d6b]/40" aria-hidden="true"></span>
                        <span class="font-medium">{sub.subLabel}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="flex justify-center gap-1.5 pb-3">
          {panels.map((_, j) => (
            <span class={`w-1.5 h-1.5 rounded-full ${i === j ? 'bg-white' : 'bg-white/30'}`}></span>
          ))}
        </div>

      </div>
    ))}
  </div>

  <p class="md:hidden text-center text-xs text-gray-400 mt-2 tracking-wide">Desliza para ver más →</p>
</section>

<style>
  .dropdown-card.is-open .dropdown-content {
    max-height: 600px;
    opacity: 1;
  }

  .dropdown-card.is-open .plus-icon {
    transform: rotate(45deg);
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.dropdown-card');

  cards.forEach((card) => {
    const trigger = card.querySelector<HTMLButtonElement>('.dropdown-trigger');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      const isOpen = card.classList.contains('is-open');

      cards.forEach((c) => {
        c.classList.remove('is-open');
        c.querySelector('.dropdown-trigger')?.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        card.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>