---
import { Image } from "astro:assets";
import img2 from "../../../../public/consola1.webp";
import SliderCasetas from "./SliderCasetas.astro";
import SecondWhatsBtn from "../../unitComponents/SecondWhatsBtn.astro";
import PlanosMontable from "./PlanosMontable"
---

<section>
    <div class="w-full flex flex-col font-bold mt-10">
        <div class="max-w-7xl px-8 mx-auto flex justify-start">
            <Image
                src={img2}
                alt="Baghouse"
                class="hero-img lg:w-4/5 rounded-lg"
                fetchpriority="high"
                loading="lazy"
            />
        </div>
        <div class="bg-[#100f0d]">
            <div
                class="max-w-7xl px-8 mx-auto flex flex-col lg:flex-row justify-between items-center py-2"
            >
                <div class="flex flex-col md:flex-row gap-6 lg:w-[40%]">
                    <div class="w-full">
                        <h2 class="text-[#f9f9f9] text-lg md:text-xl">
                            Operación manual cuando se requiera
                        </h2>
                        <p
                            class="text-[#f4f5f6] text-sm lg:text-lg md:text-lg text-justify"
                        >
                            Entendemos la importancia de tener control total de
                            la operación. Por eso, nuestro sistema aparte del
                            modo de operación automática, incluye un modo de
                            operación completamente manual. No dependemos de una
                            configuración totalmente automatizada: si algún
                            componente deja de funcionar, la planta puede seguir
                            operando manualmente sin interrumpir la producción.
                        </p>
                    </div>
                </div>
                <div class="w-full hidden lg:flex md:w-auto">
                    <Image
                        src="https://placehold.co/600x400/png"
                        width={600}
                        height={400}
                        alt="Baghouse cleaning system"
                        class="side-img rounded-2xl will-change-transform"
                    />
                </div>
            </div>
        </div>
    </div>
</section>

<section>
    <SliderCasetas />
    <div class="max-w-7xl mx-auto px-8">
        <div class="relative w-full rounded-2xl overflow-hidden px-8">
            <img
                src="https://placehold.co/1200x500/png"
                alt="Planta asfáltica Triaso"
                class="w-full h-full object-cover absolute inset-0"
            />

            <div
                class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/40 to-transparent"
            >
            </div>

            <div class="relative z-10 flex justify-start">
                <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col gap-4">
                    <h2
                        class="text-white font-black text-3xl md:text-4xl uppercase"
                    >
                        Vista amplia a la obra
                    </h2>

                    <p class="text-white font-bold text-lg md:text-xl">
                        El diseño está pensado para que tener una vista amplia a la obra, permitiendo ver toda la obra
                    </p>
                </div>
            </div>
        </div>


       
    </div>
    <div class="max-w-7xl mx-auto px-8 py-5">
         <div class="flex justify-center items-center">
            <div class="flex flex-col">
            <h1 class="text-4xl">
              Con <span class="italic font-bold">Triaso</span>
            </h1>
            <p class="font-bold text-[#14427c] text-3xl">
              conviértase en el proveedor preferido de mezcla asfáltica
            </p>
            <p class="font-bold text-[#14427c] text-3xl">
              en todos los proyectos de pavimentación de su región.
            </p>
          </div>
        </div>
    </div>
   
</section>


<section class="">
  <div
    class="bg-black lg:h-[50vh] md:h-[50vh] flex items-center bg-[url(https://placehold.co/1920x1080/png)] bg-cover bg-center bg-no-repeat relative"
  >
    <div class="absolute inset-0 bg-[#000000]/70"></div>
    <div class="max-w-7xl mx-auto px-8 space-y-5 relative">
      <div class="pt-5">
        <h1 class="text-4xl font-bold text-white">
          ¿Indeciso sobre el equipo ideal para su proyecto?
        </h1>
      </div>

      <div
        class="w-full flex flex-col justify-center pb-5 lg:justify-around md:justify-around items-center lg:flex-row relative"
      >
        <div class="">
          <p class="text-white">
            La compra de una planta de asfalto es una gran inversión, y la base
            de un negocio de producción de mezcla asfáltica. Compre
            inteligentemente y con criterio.
          </p>
          <p class="text-white">
            Podemos asesorarlo de forma transparente en la inversión de su
            planta de asfalto, ayudándolo a elegir la opción más adecuada.
          </p>
        </div>
        <div
          class="w-full flex flex-col justify-center items-center gap-4 mb-5 lg:ml-28"
        >
          <!-- Botón 1 -->
          <SecondWhatsBtn />

          <a
            href="/Contact"
            aria-label="Button to request a quote"
            class=" border-white border text-white text-sm md:text-lg rounded-full w-full py-2 flex items-center justify-between gap-2 shadow-md"
          >
          <div class="px-5 py-2">
            <p>Solicitar una cotización</p>
          </div>
          <div class="px-5 py-2">
            <svg
              width="24px"
              height="24px"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              color="#FFFFFF"
            >
              <!-- Icono del segundo botón (opcional) -->
              <path
                d="M5 12H19M19 12L12 5M19 12L12 19"
                stroke="#FFFFFF"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
            
          </a>
        </div>
      </div>
    </div>
  </div>

    <div class="max-w-7xl mx-auto px-8 flex items-center justify-center">
        <h1 class="text-2xl md:text-3xl font-semibold my-6 bg-gradient-to-r from-black to-[#2325a5] bg-clip-text text-transparent">
            Invertir en calidad siempre tiene sentido.
        </h1>
    </div>
</section>

<section>
    <PlanosMontable client:only/>
</section>


<script>
    import { initScrollAnimations } from "../scrollAnimationCaseta";

    if (typeof window !== "undefined") {
        window.addEventListener("DOMContentLoaded", () => {
            initScrollAnimations();
        });
    }
</script>
