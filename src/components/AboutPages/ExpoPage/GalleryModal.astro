<div
  id="gallery-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center"
>
  <div class="absolute inset-0 bg-black/80"></div>

  <div
    class="relative z-10 w-full max-w-5xl h-[80vh] flex items-center justify-center"
  >
    <div
      id="slider-title"
      class="absolute top-20 lg:top-5 left-1/2 -translate-x-1/2 -translate-y-1/2
             text-white text-xl lg:text-2xl md:text-2xl font-semibold text-center
             pointer-events-none select-none"
    >
    </div>

    <button
      id="close"
      class="absolute top-4 right-4 text-white text-2xl hover:opacity-70 z-20"
    >
      ✕
    </button>

    <button
      id="prev"
      class="absolute left-4 lg:left-[-50px] text-white rounded-full text-4xl hover:opacity-70 z-20"
    >
      ‹
    </button>

    <img
      id="slider-image"
      class="max-h-full max-w-full object-contain"
      alt=""
    />

    <button
      id="next"
      class="absolute right-4 lg:right-[-50px] text-white text-4xl hover:opacity-70 z-20"
    >
      <p>›</p>
    </button>
  </div>
</div>

<script type="module">
const modal = document.getElementById('gallery-modal')
const closeBtn = document.getElementById('close')
const prevBtn = document.getElementById('prev')
const nextBtn = document.getElementById('next')
const imageEl = document.getElementById('slider-image')
const titleEl = document.getElementById('slider-title')

let images = []
let index = 0

function updateImage() {
  imageEl.src = images[index]
}

document.addEventListener('click', (e) => {
  const target = e.target
  if (!(target instanceof HTMLElement)) return

  const item = target.closest('.gallery-item')
  if (!item) return

  images = JSON.parse(item.dataset.images || '[]')
  index = 0

  titleEl.textContent = item.dataset.title || ''

  updateImage()

  modal.classList.remove('hidden')
  modal.classList.add('flex')
})

prevBtn.addEventListener('click', () => {
  index = (index - 1 + images.length) % images.length
  updateImage()
})

nextBtn.addEventListener('click', () => {
  index = (index + 1) % images.length
  updateImage()
})

closeBtn.addEventListener('click', () => {
  modal.classList.add('hidden')
  modal.classList.remove('flex')
})
</script>
