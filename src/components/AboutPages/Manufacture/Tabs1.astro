---
import Manu1 from "../../../assets/images/About/Manufacture/Manufac1.webp";
import Manu2 from "../../../assets/images/About/Manufacture/Manufac2.webp";
import { Image } from "astro:assets";
---
<section class="w-full flex 2 mt-10 md:mt-20 flex-col items-center justify-center gap-4 bg-blueMain" data-tabs>
    <div class="flex flex-col items-center justify-center gap-4 mt-8">
        <div class="flex items-center justify-around w-full gap-4 px-8 " role="tablist">
            <button class="text-xl md:text-2xl tab-button py-2 md:px-4 font-bold focus:outline-none"
            data-tab="tab1" aria-selected="true" role="tab">
                Plantas de asfalto
            </button>
            <button class="tab-button py-2 md:px-4 font-bold text-xl md:text-2xl focus:outline-none"
            data-tab="tab2" aria-selected="false" role="tab">
                Trituradoras
            </button>
        </div>
        <div class="py-4">
            <!-- First Section -->
            <div class="w-full flex flex-col items-center justify-center gap-4 mt-4 tab-content text-base md:text-lg text-grisT font-bold" data-tab-content="tab1">
                <div class="w-full px-8 ">
                    <Image src={Manu1} alt="Asphalt plant pieces">
                </div>
             </div>
        <!-- Second Section -->
            <div class="w-full flex flex-col items-center justify-center gap-10 mt-4 tab-content text-base md:text-lg text-grisT font-bold" data-tab-content="tab2">
            <div class="w-full px-8 ">
                    <Image src={Manu2} alt="Rock crusher pieces">
                </div>
            </div>
        </div>    
    </div>
    <div class="w-full bg-bgBeige -skew-y-2">
        <div class="w-full max-w-7xl mx-auto px-8  py-10 font-bold text-grisT skew-y-2">
            <h2 class="text-xl md:text-2xl pt-10">
                Atención Directa del Fabricante
            </h2><br>
            <p class="text-base md:text-lg">
                En Triaso, usted trata directamente con el fabricante, sin intermediarios ni revendedores. Todos nuestros equipos son diseñados y fabricados en México, asegurando mayor calidad, precios competitivos y atención personalizada.


            </p><br>
            <p class="text-base md:text-lg pb-10">
              Nuestra fabricación interna nos da control total sobre cada componente, permitiéndonos ofrecer una garantía superior, soporte rápido y confiable, disponibilidad inmediata de refacciones y soluciones especiales adaptadas a sus necesidades específicas.


            </p> <br>
            <p class="text-base md:text-lg pb-10">
Cada equipo sale de nuestra fábrica completamente equipado. Lo que ve en el precio es lo que paga — sin "opciones adicionales" que aparezcan después. Sabemos que muchos componentes son esenciales para la producción de mezcla asfáltica, y por eso los incluimos desde el inicio.

            </p> <br>
            
        </div>
    </div>
    <div class="w-full bg-gradient-to-b from-blueMain to-bgMain py-10 h-[250px]">

        
    </div>
    
</section>
<style is:inline>
  /* Estilos para los tabs activos */
  .tab-button[aria-selected="true"] {
    color: white;
    border-bottom: 2px solid white;
  }
  
  .tab-button[aria-selected="false"] {
    color: #d6d6d6;
    border-bottom: 2px solid #d6d6d6;
  }
  
  .tab-button:hover:not([aria-selected="true"]) {
    color: white;
    border-bottom: 2px solid white;
  }
  
</style>
<script is:inline>

    (function initTabs() {
      document.querySelectorAll('section[data-tabs]').forEach(tabSection => {
        const tabButtons = tabSection.querySelectorAll('.tab-button');
        const tabContents = tabSection.querySelectorAll('.tab-content');
    
        // Ocultar todos menos el primero
        const selectedTab = tabSection.querySelector('.tab-button[aria-selected="true"]');
const selectedTabId = selectedTab?.getAttribute('data-tab');

tabContents.forEach(content => {
  const contentTabId = content.getAttribute('data-tab-content');
  content.classList.toggle('hidden', contentTabId !== selectedTabId);
});

    
        tabButtons.forEach(button => {
          button.addEventListener('click', () => {
            const tabId = button.getAttribute('data-tab');
    
            tabButtons.forEach(btn => btn.setAttribute('aria-selected', 'false'));
            button.setAttribute('aria-selected', 'true');
    
            tabContents.forEach(content => {
              content.classList.add('hidden');
            });
    
            const activeContent = tabSection.querySelector(`.tab-content[data-tab-content="${tabId}"]`);
            if (activeContent) activeContent.classList.remove('hidden');
          });
        });
      });
    })();
</script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const dropdown = document.getElementById("extradiv");
    const arrow = document.getElementById("dropdown-arrow");
    const button = document.getElementById("dropdown-button");

    if (button) {
      button.addEventListener("click", () => {
        const isClosed =
          dropdown.style.maxHeight === "0px" || !dropdown.style.maxHeight;

        if (isClosed) {
          dropdown.style.maxHeight = dropdown.scrollHeight + "px";
          arrow.style.transform = "rotate(180deg)";
        } else {
          dropdown.style.maxHeight = "0px";
          arrow.style.transform = "rotate(0deg)";
        }
      });
    }
  });
</script>
<style is:inline>
    #dropdown-arrow {
        transition: transform 0.3s ease;
    }
</style>
    