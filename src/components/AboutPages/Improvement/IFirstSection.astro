---
import Card from "../../unitComponents/Card.astro";
import LearnBtn from "../../unitComponents/LearnBtn.astro";
import Planos from "../../../assets/images/planos.webp";
import logo from "../../../assets/images/About/Improvement/ANSYS_logo.webp";
import logo2 from "../../../assets/images/About/Improvement/Aggflow_logo.webp";
import logo3 from "../../../assets/images/About/Improvement/Autodesk_logo.webp"
import IAD1 from "../../../assets/images/About/Improvement/IAD1.webp";
import IAD2 from "../../../assets/images/About/Improvement/IAD2.webp";
import IAD3 from "../../../assets/images/About/Improvement/IAD3.webp";
import IAD4 from "../../../assets/images/About/Improvement/IAD4.webp";
import CD1 from "../../../assets/images/About/Improvement/CD1.webp";
import CD2 from "../../../assets/images/About/Improvement/CD2.webp";
import CD3 from "../../../assets/images/About/Improvement/CD3.webp";
import CD4 from "../../../assets/images/About/Improvement/CD4.webp";
import { Image } from "astro:assets";
---

<section class="w-full">
  <div class="w-full flex justify-center">
    <Image src={Planos} alt="Technical prints" fetchpriority="high" />
  </div>
  <div class="w-full max-w-7xl px-8 mx-auto font-bold my-10">
    <h1 class="text-3xl md:text-4xl text-grisT uppercase">
      Mejora en sistemas y diseños
    </h1>
  </div>

  <div class="max-w-7xl px-8 mx-auto space-y-5">
    <div class="w-full font-bold">
      <p class="text-sm lg:text-lg md:text-lg text-grisT">
        Todos nuestros sistemas están diseñados para cumplir con los más altos
        estándares internacionales y se adaptan cuidadosamente para cumplir con
        las regulaciones específicas del país o estado donde se instalará el
        equipo.
      </p><br />
      <p class="text-sm lg:text-lg md:text-lg text-grisT">
        Nuestro equipo de ingeniería y diseño de primer nivel está conformado
        por ingenieros especializados y con experiencia, que utilizan
        herramientas avanzadas y software de simulación para desarrollar nuevos
        sistemas industriales y optimizar los existentes.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 md:grid-cols-2">
      <div class="flex flex-col items-center justify-center space-y-3">
        <div class="flex flex-col">
          <div class="">
            <h2 class="text-2xl lg:text-4xl md:text-3xl text-black font-bold">
              Un equipo fiable y productivo comienza con un diseño perfecto y
              minucioso
            </h2>
          </div>
          <div class="w-40 h-0.5 bg-[#CA1C1C]"></div>
        </div>
        <div class="">
          <h3 class="text-black text-start">
            ...y después del proceso de diseño y fabricación, continuamos
            monitoreando el desempeño de los equipos mediante los servicios de
            mantenimiento que brindamos. Esta retroalimentación continua nos
            permite mejorar constantemente la producción futura, dando como
            resultado algunos de los equipos más confiables y productivos del
            mercado.
          </h3>
        </div>
      </div>

      <div>
        <div
          class="max-w-7xl grid grid-cols-1 lg:grid-cols-2 md:grid-cols-2 gap-10 px-8 font-bold text-black text-base md:text-lg my-16"
        >
          <Card
            className="p-4 rounded-2xl w-full bg-white flex flex-col items-center justify-center"
          >
            <div>
              <h3 class="text-center">
                Flujo de polvo en un filtro de mangas (baghouse)
              </h3>
            </div>

            <div class="w-full my-auto">
              <Image
                src={IAD1}
                alt="Dust flow in a baghouse"
                class="w-full h-full"
              />
            </div>
          </Card>
          <Card
            className="p-4 rounded-2xl w-full bg-white flex flex-col items-center justify-center"
          >
            <h3 class="text-center">Análisis de esfuerzos en un chasis</h3>
            <div class="w-full flex my-auto">
              <Image
                src={IAD2}
                alt="Dust flow in a baghouse"
                class="w-full h-full"
              />
            </div>
          </Card>
          <Card
            className="p-4 rounded-2xl w-full bg-white flex flex-col items-center justify-center"
          >
            <h3 class="text-center">Análisis de vibraciones en cribas</h3>
            <div class="w-full flex my-auto">
              <Image
                src={IAD3}
                alt="Dust flow in a baghouse"
                class="w-full h-full"
              />
            </div>
          </Card>
          <Card>
            <h3 class="text-center">
              Análisis del flujo de aire dentro del ciclón
            </h3>
            <div class="w-full aspect-square">
              <Image
                src={IAD4}
                alt="Dust flow in a baghouse"
                class="w-full h-full"
              />
            </div>
          </Card>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-8">
    <div class="flex justify-center items-center">
      <h1 class="text-center font-bold text-2xl text-[#14427C]">
        Nuestro enfoque de diseño aborda directamente problemas comunes e
        ineficiencias presentes en otras marcas.
      </h1>
    </div>

    <div class="carousel-wrapper">
      <div class="carousel-track" id="carouselTrack">
        <!-- Tarjeta 1: ANSYS -->
        <div class="card">
          <div class="card-logo">
            <!-- <Image src={ansysLogo} alt="ANSYS Logo" width={260} height={80} /> -->
            <!-- Placeholder mientras conectas tus imágenes: -->
            <img src={logo.src} alt="ANSYS Logo" class="logo-img" />
          </div>
          <div class="card-body">
            <div class="card-description">
              <p>
                Mediante el uso de software de análisis de elementos finitos
                (Ansys®), realizamos pruebas precisas para evaluar el
                comportamiento de nuevos diseños, mejoras a diseños existentes y
                proyectos personalizados mediante simulaciones por computadora.
                Estas pruebas rigurosas garantizan la calidad y confiabilidad de
                nuestros productos.
              </p>
            </div>
            <div class="card-list">
              <ul>
                <li>
                  Comportamiento del flujo de agregados y aire en cualquier
                  punto del proceso.
                </li>
                <li>Análisis de temperaturas, su uso y su aislamiento.</li>
                <li>
                  Análisis de esfuerzos estructurales, estáticos y dinámicos,
                  durante la operación y en maniobras de instalación y
                  desmontaje.
                </li>
                <li>
                  Análisis del comportamiento del flujo de aire y polvo en
                  separadores ciclónicos y filtros de mangas para control de
                  contaminación.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Tarjeta 2: AggFlow -->
        <div class="card">
          <div class="card-logo">
            <img src={logo2.src} alt="AggFlow Logo" class="logo-img" />
          </div>
          <div class="card-body">
            <div class="card-description">
              <p>
                Mediante el uso de software de simulación de procesos (AggFlow),
                analizamos y optimizamos el flujo de materiales en nuestros
                sistemas. Esto nos permite evaluar configuraciones, mejorar el
                desempeño y asegurar una operación más eficiente y equilibrada.
              </p>
            </div>
            <div class="card-list">
              <ul>
                <li>
                  Análisis del flujo de materiales en cada etapa del circuito de
                  trituración y clasificación.
                </li>
                <li>
                  Evaluación del rendimiento de equipos como trituradoras,
                  cribas y bandas transportadoras.
                </li>
                <li>
                  Simulación de diferentes configuraciones de planta para
                  optimizar producción y reducir cuellos de botella.
                </li>
                <li>
                  Balance de materiales y granulometrías para mejorar la
                  eficiencia global del sistema.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Tarjeta 3: Autodesk Inventor -->
        <div class="card">
          <div class="card-logo">
            <img
              src={logo3.src}
              alt="Autodesk Inventor Logo"
              class="logo-img"
            />
          </div>
          <div class="card-body">
            <div class="card-description">
              <p>
                Mediante el uso de software de diseño y modelado 3D (Inventor),
                desarrollamos y validamos componentes y sistemas mecánicos con
                alta precisión. Esto nos permite evaluar ensamblajes, detectar
                interferencias y optimizar el diseño antes de su fabricación.
              </p>
            </div>
            <div class="card-list">
              <ul>
                <li>
                  Diseño y modelado 3D de componentes y estructuras mecánicas
                  con alta precisión.
                </li>
                <li>
                  Desarrollo de ensamblajes completos para validar el
                  funcionamiento del equipo antes de su fabricación.
                </li>
                <li>
                  Detección de interferencias y errores de diseño en etapas
                  tempranas del proyecto.
                </li>
                <li>
                  Generación de planos técnicos y documentación lista para
                  manufactura.
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Indicadores / dots -->
      <div class="carousel-dots" id="carouselDots">
        <button class="dot active" data-index="0" aria-label="Tarjeta 1"
        ></button>
        <button class="dot" data-index="1" aria-label="Tarjeta 2"></button>
        <button class="dot" data-index="2" aria-label="Tarjeta 3"></button>
      </div>
    </div>
  </div>

  <div class="w-full max-w-7xl mx-auto px-8 font-bold flex flex-col gap-10">
    <h1 class="text-2xl md:text-3xl text-grisT text-center">
      Diseño a la medida
    </h1>
    <p class="text-sm lg:text-lg md:text-lg text-grisT text-center">
      Además de nuestros diseños estandarizados, nos especializamos en
      soluciones personalizadas adaptadas a las necesidades específicas de cada
      cliente. Ya sea para ajustarse a condiciones ambientales particulares o
      para cumplir con requerimientos específicos de desempeño, nuestro equipo
      trabaja en conjunto con el cliente para desarrollar sistemas que ofrecen
      una confiabilidad y eficiencia superiores.
    </p>
  </div>
  <div class="w-full flex flex-col justify-center items-center">
    <div
      class="max-w-7xl grid grid-cols-1 lg:grid-cols-4 md:grid-cols-4 gap-10 px-8 font-bold text-black text-base md:text-lg my-10"
    >
      <Card>
        <div>
          <Image src={CD1} alt="Custom Design for units" />
        </div>
      </Card>
      <Card>
        <div>
          <Image src={CD2} alt="Custom Design for units" />
        </div>
      </Card>
      <Card>
        <div>
          <Image src={CD3} alt="Custom Design for units" />
        </div>
      </Card>
      <Card>
        <div>
          <Image src={CD4} alt="Custom Design for units" />
        </div>
      </Card>
    </div>
  </div>
  <div class="flex justify-center pb-10">
    <LearnBtn href="/CustomDesign" />
  </div>
</section>

<style>
  .carousel-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
 
  .carousel-track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
 
  /* Cada tarjeta ocupa el 100% del ancho */
  .card {
    min-width: 100%;
    background: white;
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }
 
  .card-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem 0 1rem;
  }
 
  .logo-img {
    max-height: 80px;
    max-width: 300px;
    object-fit: contain;
  }
 
  .card-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 0.5rem 1.25rem 1.25rem;
    align-items: center;
  }
 
  @media (min-width: 768px) {
    .card-body {
      grid-template-columns: 1fr 1fr;
    }
  }
 
  .card-description p {
    color: #393939;
    line-height: 1.6;
    margin: 0;
  }
 
  .card-list ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    color: #393939;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
 
  .card-list li {
    line-height: 1.5;
  }
 
  /* Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0 0.25rem;
  }
 
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: #d1d5db;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
 
  .dot.active {
    background: #f59e0b; /* Amarillo/dorado que combina con logos de ANSYS/Inventor */
    transform: scale(1.3);
  }
 
  .dot:hover:not(.active) {
    background: #9ca3af;
  }
</style>
 
<script>
  const track = document.getElementById('carouselTrack') as HTMLElement;
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const totalCards = 3;
  let current = 0;
  let autoplayTimer: ReturnType<typeof setInterval>;
 
  function goTo(index: number) {
    current = (index + totalCards) % totalCards;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
  }
 
  function startAutoplay() {
    autoplayTimer = setInterval(() => goTo(current + 1), 5000);
  }
 
  function resetAutoplay() {
    clearInterval(autoplayTimer);
    startAutoplay();
  }
 
  // Click en dots
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(Number(dot.dataset.index));
      resetAutoplay();
    });
  });
 
  // Soporte para swipe en móvil
  let touchStartX = 0;
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
 
  track.addEventListener('touchend', (e) => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) > 50) {
      goTo(delta > 0 ? current + 1 : current - 1);
      resetAutoplay();
    }
  }, { passive: true });
 
  // Pausa al hacer hover
  track.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
  track.addEventListener('mouseleave', () => startAutoplay());
 
  // Iniciar
  startAutoplay();
</script>