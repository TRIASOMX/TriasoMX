---
const { news, variant = "default" } = Astro.props;
---

<a
    href={`/news/${news.id}`}
    class={`
    group block overflow-hidden rounded-2xl bg-[#ffffff]

    transition-all duration-500
    ${variant === "featured" ? "md:flex" : "flex flex-col"}
  `}
>
    <div
        class={`relative overflow-hidden ${variant === "featured" ? "md:w-1/2 h-64 md:h-auto" : "h-52"}`}
    >
        <img
            src={news.image}
            alt={news.title}
            class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"
        >
        </div>
    </div>

    <div
        class={`relative p-6 flex flex-col justify-between gap-4 ${variant === "featured" ? "md:w-1/2" : "flex-1"}`}
    >
        <div
            class="absolute top-0 left-6 right-6 h-px bg-gradient-to-r from-blueMain/0 via-blueMain to-blueMain/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        >
        </div>

        <div class="flex flex-col gap-3">
            <h3
                class="text-black/80 font-semibold text-base md:text-lg leading-snug tracking-tight group-hover:text-black transition-colors duration-300"
            >
                {news.title}
            </h3>
        </div>

        <div class="flex items-center justify-between">
            <span class="text-xs text-black font-medium tracking-wide">
                {news.date}
            </span>
            <span
                class="flex items-center gap-1 text-xs text-blueMain/70 group-hover:text-blueMain font-semibold tracking-wide transition-all duration-300 translate-x-0 group-hover:translate-x-1"
            >
                See more
                <svg
                    class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </span>
        </div>
    </div>
</a>
