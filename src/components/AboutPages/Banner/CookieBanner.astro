---

---

<div
    id="cookie-banner"
    role="dialog"
    aria-live="polite"
    aria-label="Cookie consent"
    class="cookie-banner
    fixed bottom-6 left-1/2 -translate-x-1/2
    w-[calc(100vw-2rem)] max-w-xl
    z-[9999]
    pointer-events-none opacity-0"
>
    <!-- Card -->
    <div
        class="relative
    bg-white text-[#e8e6e1]
    border border-[#2a2a2a]
    px-6 py-5
    shadow-[0_8px_40px_rgba(0,0,0,.55)]"
    >
        <!-- Accent line -->
        <span class="absolute top-0 left-0 w-full h-[2px] bg-[#14437d]"></span>

        <div class="flex flex-col sm:flex-row sm:items-end gap-4">
            <!-- Text -->
            <div class="flex-1 min-w-0">
                <p class="text-[13px] leading-relaxed text-black">
                    <span
                        class="block text-black text-[11px] tracking-[.18em] uppercase mb-1"
                    >
                        Usage of cookies
                    </span>
                    We use cookies to improve your experience and analyze traffic.
                    You can accept or reject the use of tracking cookies.
                </p>
            </div>

            <!-- Actions -->
            <div class="flex gap-2 shrink-0">
                <button
                    id="cookie-reject"
                    class="px-4 py-2
            text-[11px] tracking-[.14em] uppercase 
            border border-[#3a3a3a] text-[#7a7a72]
            cursor-pointer"
                >
                    Decline
                </button>
                <button
                    id="cookie-accept"
                    class="px-4 py-2
            text-[11px] tracking-[.14em] uppercase
            bg-[#14437d] text-white
            cursor-pointer font-medium"
                >
                    Accept
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .cookie-banner {
        transition:
            opacity 350ms cubic-bezier(0.4, 0, 0.2, 1),
            transform 350ms cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-50%) translateY(12px);
    }

    .cookie-banner.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }

    .cookie-banner.is-hiding {
        opacity: 0;
        transform: translateX(-50%) translateY(12px);
    }

    @media (prefers-reduced-motion: reduce) {
        .cookie-banner {
            transition: opacity 150ms linear;
        }
    }
</style>

<script>
    import { shouldShowBanner, setConsent } from "./Consent";

    const banner = document.getElementById("cookie-banner")!;
    const btnAccept = document.getElementById("cookie-accept")!;
    const btnReject = document.getElementById("cookie-reject")!;

    // ── Show / hide helpers ───────────────────────────────────────────────────

    function show() {
        banner.classList.remove("is-hiding");
        // Delay one frame so the initial opacity:0 is painted first
        requestAnimationFrame(() => {
            requestAnimationFrame(() => banner.classList.add("is-visible"));
        });
    }

    function hide(callback?: () => void) {
        banner.classList.add("is-hiding");
        banner.classList.remove("is-visible");
        banner.addEventListener(
            "transitionend",
            () => {
                banner.style.display = "none";
                callback?.();
            },
            { once: true },
        );
    }

    // ── Init ──────────────────────────────────────────────────────────────────

    if (shouldShowBanner()) {
        // Small delay so the banner doesn't flash before the page paints
        setTimeout(show, 300);
    }

    // ── Handlers ─────────────────────────────────────────────────────────────

    btnAccept.addEventListener("click", () => {
        setConsent("accepted");
        hide();
    });

    btnReject.addEventListener("click", () => {
        setConsent("rejected");
        hide();
    });
</script>
