---
import { Image } from "astro:assets";
import LearnBtn from "../unitComponents/LearnBtn.astro";
---

<section>
    <div class="w-full flex flex-col font-bold mt-5 lg:mt-0">
        <div class="hidden w-full mx-auto max-w-7xl px-8 lg:flex">
            <Image
                src="https://placehold.co/800x400/png"
                width={800}
                height={400}
                alt="Drum mixer on a construction zone"
                class="hero-img rounded-lg"
            />
        </div>

        <div
            class="flex max-w-7xl px-8 mx-auto lg:hidden md:flex justify-center"
        >
            <Image
                src="https://placehold.co/1920x720/png"
                width={1920}
                height={720}
                alt="Drum mixer on a construction zone"
                class="lg:w-4/5 rounded-lg"
            />
        </div>

        <div class="bg-[#393939]">
            <div
                class="max-w-7xl px-8 mx-auto flex flex-col lg:flex-row justify-between items-center py-2"
            >
                <div class="flex flex-col gap-6 lg:w-[40%]">
                    <div
                        class="w-full flex flex-col justify-center items-center space-y-3"
                    >
                        <h1 class="text-[#f9f9f9] text-lg md:text-xl">
                            Ecológia
                        </h1>
                        <h1 class="text-[#f9f9f9] text-lg md:text-xl">
                            Economía
                        </h1>
                        <h1 class="text-[#f9f9f9] text-lg md:text-xl">
                            Sustentabilidad
                        </h1>
                    </div>

                    <div>
                        <p
                            class="text-[#f4f5f6] text-sm lg:text-lg md:text-lg font-normal text-justify"
                        >
                            El incorporador de hule es una opción ecológica para
                            darle un segundo uso a las llantas, aprovechando su
                            composición ligante para la producción de mezcla
                            asfáltica, reduciendo el consumo de asfalto liquido,
                            economizando la mezcla asfáltica.
                        </p>
                    </div>
                </div>
                <div class="w-full hidden lg:flex md:w-auto">
                    <Image
                        src="https://placehold.co/600x400/png"
                        width={600}
                        height={400}
                        alt="Baghouse cleaning system"
                        class="side-img rounded-2xl will-change-transform"
                    />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="max-w-7xl mx-auto px-8 py-10 space-y-5">
    <div class="flex justify-center items-center">
        <img
            src="https://placehold.co/1920x1080/png"
            alt="Placehold"
            class="rounded-2xl"
        />
    </div>

    <div
        class="grid grid-cols-3 md:grid-cols-6 lg:grid-cols-6 gap-6 items-stretch"
    >
        <div class="flex flex-col items-center justify-between h-[136px]">
            <svg
                fill="#ca1c1c"
                width="128"
                height="128"
                viewBox="0 0 32 32"
                version="1.1"
                xmlns="http://www.w3.org/2000/svg"
                ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                    id="SVGRepo_tracerCarrier"
                    stroke-linecap="round"
                    stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                    <title>number10</title>
                    <path
                        d="M16 3c-7.18 0-13 5.82-13 13s5.82 13 13 13 13-5.82 13-13-5.82-13-13-13zM17.757 22.536h-2.469v-9.305c-0.901 0.841-1.964 1.463-3.188 1.867v-2.234c0.644-0.211 1.344-0.612 2.099-1.202s1.273-1.278 1.555-2.064h2.003v12.938z"
