<script>
    //Animación
    import { initScrollAnimations } from "./scrollHule";

    if (typeof window !== "undefined") {
        window.addEventListener("DOMContentLoaded", () => {
            initScrollAnimations();
        });
    }

    //Cards
    document
        .querySelectorAll<HTMLButtonElement>(".mostrar-mas")
        .forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const expandible = btn.nextElementSibling as HTMLElement;
                const chevron = btn.querySelector(".chevron") as HTMLElement;
                const isOpen =
                    expandible.style.maxHeight &&
                    expandible.style.maxHeight !== "0px";

                if (isOpen) {
                    expandible.style.maxHeight = "0px";
                    chevron.style.transform = "rotate(0deg)";
                    btn.setAttribute("aria-expanded", "false");
                } else {
                    expandible.style.maxHeight = expandible.scrollHeight + "px";
                    chevron.style.transform = "rotate(180deg)";
                    btn.setAttribute("aria-expanded", "true");
                }
            });
        });

    const track = document.getElementById("sliderTrack");
    const nextBtn = document.getElementById("nextBtn");
    const prevBtn = document.getElementById("prevBtn");

    const originalCards = Array.from(track.children);

    
    originalCards.forEach((card) => {
        const clone = card.cloneNode(true);
        track.appendChild(clone);
    });

    
    [...originalCards].reverse().forEach((card) => {
        const clone = card.cloneNode(true);
        track.prepend(clone);
    });

    const cards = track.children;

    let currentIndex = originalCards.length;

    function updateSlider(animate = true) {
        const cardWidth = cards[0].offsetWidth + 16;

        track.style.transition = animate
            ? "transform 0.5s ease-in-out"
            : "none";

        track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
    }

    
    updateSlider(false);

    nextBtn.addEventListener("click", () => {
        currentIndex++;
        updateSlider();

        if (currentIndex >= originalCards.length * 2) {
            setTimeout(() => {
                currentIndex = originalCards.length;
                updateSlider(false);
            }, 500);
        }
    });

    prevBtn.addEventListener("click", () => {
        currentIndex--;
        updateSlider();

        if (currentIndex <= 0) {
            setTimeout(() => {
                currentIndex = originalCards.length;
                updateSlider(false);
            }, 500);
        }
    });
</script>
