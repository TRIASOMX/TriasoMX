---
import rap from "../../assets/images/DrumMixers/rap.webp";
import TwoColumnSection from "../unitComponents/TwoColumnSection.astro";
import Tred from "../../assets/images/AsphaltStorage/redT.webp";
import AcordeonItem from "../unitComponents/AcordeonItem";
import binUnit1 from "../../assets/images/BinUnits/binUnit1.webp";
import img1 from "../../assets/images/RapBins/RAProv3.webp";
import img1Low from "../../assets/images/RapBins/Low/RAProv3Low.webp";
import img2 from "../../assets/images/RapBins/RAProv1.webp";
import RAProv5 from "../../assets/images/RapBins/RAProv5.webp";
import OSection from "../unitComponents/OSection.astro";
import rapFlight from "../../assets/images/DrumMixers/a21.webp";
import heroIMG from "../../assets/images/RapBins/heroBG.webp";
import img4 from "../../assets/images/RapBins/RapProv6.webp";
import img4Low from "../../assets/images/RapBins/Low/RapProv6Low.webp";
import { Image } from "astro:assets";
import poster1 from "../../assets/images/RapBins/Gallery/RBG1.webp";
import SmartVideo from "../unitComponents/SmartVideo";
import LearnBtnBlue from "../unitComponents/LearnBtnBlue.astro";
import Whatsbtn from "../unitComponents/Whatsbtn.astro";

import OSHand from "../../assets/images/OSHand.webp";
import Slider from "../IntegralAsphalt/SliderOsIntegral";
---

<section class="w-full font-bold">
  <div class="w-full h-[100px] bg-gradient-to-b from-blueMain to-grisT"></div>
  <div class="w-full bg-grisT">
    <div
      class="w-full grid grid-cols-1 md:grid-cols-3 bg-grisT max-w-7xl px-8 mx-auto"
    >
      <div
        class="w-full col-span-1 flex justify-center lg:justify-start md:justify-start py-5"
      >
        <Image src={rap} alt="RAP Collar" class="w-1/2 lg:w-3/4 md:w-3/4" />
      </div>
      <div class="w-full col-span-2 text-white flex flex-col justify-center">
        <h1 class="text-xl md:text-2xl font-bold">INCORPORACIÓN DE RAP</h1><br
        />
        <p class="text-sm lg:text-lg md:text-lg font-thin">
          La incorpotación de RAP en el tambor mezclador está diseñado para
          ofrecer una entrada controlada y eficiente de pavimento asfáltico
          reciclado (RAP) antes de la zona mezclado. Alimentado directamente
          desde la tolva de RAP a través de un transportador, el material entra
          en el tambor de forma uniforme.
        </p>
        <div class="flex flex-col justify-center items-center">
          <div class="w-1/4">
            <LearnBtnBlue />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-[#393939] p-10">
    <div class="max-w-7xl mx-auto">
      <div class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3" id="cardRow0">
        <!-- Card 1-A -->
        <div
          class="relative rounded-lg overflow-hidden group cursor-pointer"
          data-card="0-0"
        >
          <div class="w-full h-44 bg-black/10 flex items-center justify-center">
            <img src="https://placehold.co/600x400" alt="" />
          </div>

          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
          >
            <span
              class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
            >
              Tanque de aire
            </span>
            <button
              class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
              aria-expanded="false"
            >
              <svg
                class="chevron w-3 h-3 transition-transform duration-300"
                viewBox="0 0 12 12"
                fill="none"
              >
                <path
                  d="M2 4l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"></path>
              </svg>
              mostrar más
            </button>
            <div
              class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
            >
              <p class="text-white/75 text-xs leading-relaxed mt-2">
                Tanque de aire de 450 Lts para los sopladores explosivos,
                diseñado para la mezcla asfáltica apelmazada.El resultado es un
                flujo limpio y uniforme en cada descarga.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 1-B -->
        <div
          class="relative rounded-lg overflow-hidden group cursor-pointer"
          data-card="0-1"
        >
          <div class="w-full h-44 bg-black/10 flex items-center justify-center">
            <img src="https://placehold.co/600x400" alt="" />
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
          >
            <span
              class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
            >
              Sopladores explosivos
            </span>
            <button
              class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
              aria-expanded="false"
            >
              <svg
                class="chevron w-3 h-3 transition-transform duration-300"
                viewBox="0 0 12 12"
                fill="none"
              >
                <path
                  d="M2 4l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"></path>
              </svg>
              mostrar más
            </button>
            <div
              class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
            >
              <p class="text-white/75 text-xs leading-relaxed mt-2">
                Los sopladores explosivos están diseñados para deshacer los
                apelmazamientos de de mezcla asfáltica atorada con aire del
                tanque de aire 450 Lts.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 1-C -->
        <div
          class="relative rounded-lg overflow-hidden group cursor-pointer"
          data-card="0-2"
        >
          <div class="w-full h-44 bg-black/10 flex items-center justify-center">
            <img src="https://placehold.co/600x400" alt="" />
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
          >
            <span
              class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
            >
              Transportador
            </span>
            <button
              class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
              aria-expanded="false"
            >
              <svg
                class="chevron w-3 h-3 transition-transform duration-300"
                viewBox="0 0 12 12"
                fill="none"
              >
                <path
                  d="M2 4l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"></path>
              </svg>
              mostrar más
            </button>
            <div
              class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
            >
              <p class="text-white/75 text-xs leading-relaxed mt-2">
                El transportador está diseñado para integrar la carpeta
                asfáltica recuperada directamente en el collar de RAP.
                Garantizando un flujo constante al tambor mezclador.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- --------------------------------------------------------------------------- -->
  <div class="flex">
    <Image
      src={heroIMG}
      alt="Banner of a Counterflow asphalt plant on a road"
      class="bg-cover"
    />
  </div>

  <div class="w-full flex justify-center max-w-7xl px-4 mx-auto">
    <SmartVideo
      client:visible
      src="/Videos/Webm/ProvVideo1.webm"
      poster={poster1.src}
      isLoop={false}
      autoplayOnMobile={false}
    />
  </div>

  <div class="w-full flex flex-col font-bold mt-10">
    <div class="max-w-7xl px-8 lg:mb-20 mx-auto">
      <h1 class="text-redBg text-xl lg:text-3xl text-center">
        Con Triaso, conviértase en el proveedor exclusivo de mezcla asfáltica
        para los proyectos de pavimentación en su región.
      </h1>
    </div>
    <div class="max-w-7xl px-8 mx-auto flex justify-center">
      <Image
        src={RAProv5}
        alt="Counterflow Asphalt Plant with workers next to it"
        class="hero-img w-4/6 rounded-lg"
      />
    </div>
    <div class="bg-[#14427c]">
      <div
        class="max-w-7xl px-8 mx-auto flex flex-col md:flex-row items-center gap-6"
      >
        <div class="w-full mt-10">
          <h2 class="text-white text-lg md:text-xl">
            Sabemos la importancia de que su equipo no pare de trabajar.
          </h2>
          <p
            class="text-[#d9d9d9] pt-2 text-sm lg:text-lg md:text-lg text-justify"
          >
            Equipado con tolvas de RAP de gran capacidad, este proceso de
            alimentación maneja altos volúmenes de material manteniendo una
            distribución uniforme. El sistema está diseñado para prevenir
            acumulaciones, asegurando un flujo continuo y estable hacia el
            tambor mezclador sin interrupciones.
          </p>
        </div>

        <div class="w-full hidden lg:flex md:w-auto">
          <Image
            src={img2}
            alt="Large-capacity RAP bin"
            class="side-img rounded-2xl w-[85%] will-change-transform"
          />
        </div>
      </div>
    </div>

    <div
      class="max-w-7xl hidden px-8 mx-auto lg:flex justify-center lg:justify-start"
    >
      <Image
        src={img4Low}
        alt="Belt Feeders with Rubberized Pulley"
        class="fade-img rounded-lg lg:w-3/5 will-change-transform"
      />
    </div>

    <div class="relative flex flex-row items-center px-8 pb-5 gap-2 lg:hidden">
      <Image
        src={img2}
        alt="Large-capacity RAP bin"
        class="rounded-2xl w-1/2 object-contain"
      />

      <Image
        src={img4Low}
        alt="Belt Feeders with Rubberized Pulley"
        class="rounded-2xl w-1/2 object-contain"
      />
    </div>
  </div>

  <!-- ---- -->
  <div
    class="w-full grid grid-cols-1 md:grid-cols-5 gap-10 items-start justify-center"
  >
    <div class="col-span-2 flex lg:justify-center md:justify-center">
      <Image
        src={binUnit1}
        alt="Precision Dosing System in action"
        class="w-1/2 md:w-full"
      />
    </div>
    <div
      class="col-span-3 flex flex-col items-start h-full justify-center lg:pr-52 pr-8 lg:pl-0 pl-8"
    >
      <h1 class="text-2xl md:text-5xl font-bold">
        Sistemas de dosificación de precisión en los alimentadores de RAP
      </h1><br />

      <div class="w-full flex flex-col gap-6">
        <AcordeonItem
          client:only
          title="Sensores de alta precisión"
          content="Los sensores integrados controlan los niveles de material en tiempo real, lo que permite un control preciso de las cantidades dosificadas y evita desbordamientos o faltas de material."
        />
        <AcordeonItem
          client:only
          title="Dosificación ajustable"
          content="El sistema permite a los operadores ajustar el caudal, lo que permite procesar una amplia variedad de materiales, desde áridos finos hasta rocas de mayor tamaño o arena."
        />
        <AcordeonItem
          client:only
          title="Distribución constante del material"
          content="Garantiza una dosificación uniforme para mantener una mezcla equilibrada en las operaciones posteriores, como los procesos de mezcla o trituración."
        />
        <AcordeonItem
          client:only
          title="Controles automatizados"
          content="Equipado con controladores lógicos programables (PLC), el sistema puede automatizarse para ofrecer un rendimiento constante y repetible en diferentes proyectos."
        />
        <AcordeonItem
          client:only
          title="Mecanismo anti-obstrucción"
          content="Las rampas y compuertas especialmente diseñadas minimizan el riesgo de atascos, lo que garantiza un flujo de material fluido e ininterrumpido."
        />
        <AcordeonItem
          client:only
          title="Operación de bajo consumo energético"
          content="Diseñado para optimizar el consumo de energía, reduciendo los costos operativos sin dejar de ofrecer un alto rendimiento."
        />
      </div>
      <div
        class="text-base lg:text-xl md:text-xl font-thin text-grisT text-justify py-10"
      >
        <p>
          Estas características convierten nuestros sistemas de dosificación de
          RAP en un componente esencial para proyectos que requieren un manejo
          de materiales preciso y eficiente del RAP.
        </p>
      </div>
    </div>
  </div>

  <!-- Banner -->
  <!-- Banner -->
  <section class="">
    <div
      class="bg-black lg:h-[50vh] md:h-[50vh] flex items-center bg-[url(https://placehold.co/600x400/png)] bg-cover bg-center bg-no-repeat relative"
    >
      <div class="absolute inset-0 bg-[#000000]/70"></div>
      <div class="max-w-7xl mx-auto px-8 space-y-5 relative">
        <div class="pt-5">
          <h1 class="text-4xl font-bold text-white">
            ¿Indeciso sobre el equipo ideal para su proyecto?
          </h1>
        </div>

        <div
          class="w-full flex flex-col justify-center pb-5 lg:justify-around md:justify-around items-center lg:flex-row relative"
        >
          <div class="">
            <p class="text-white">
              La compra de una planta de asfalto es una gran inversión, y la
              base de un negocio de producción de mezcla asfáltica. Compre
              inteligentemente y con criterio.
            </p>
            <p class="text-white">
              Podemos asesorarlo de forma transparente en la inversión de su
              planta de asfalto, ayudándolo a elegir la opción más adecuada.
            </p>
          </div>
          <div
            class="w-full flex flex-col justify-center items-center gap-4 mb-5 lg:ml-28"
          >
            <!-- Botón 1 -->
            <Whatsbtn />

            <a
              href="/Contact"
              aria-label="Button to request a quote"
              class="bg-blueSecondary border-white border border- text-white text-sm md:text-lg rounded-full w-full py-2 flex items-center justify-center gap-2 shadow-md hover:bg-[#0044A4]/80"
            >
              Solicitar una cotización
              <svg
                width="24px"
                height="24px"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                color="#FFFFFF"
              >
                <!-- Icono del segundo botón (opcional) -->
                <path
                  d="M5 12H19M19 12L12 5M19 12L12 19"
                  stroke="#FFFFFF"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OS sección -->
  <section class="bg-white overflow-visible">
    <div class="max-w-7xl mx-auto lg:px-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-12">
        <!-- Texto -->
        <div class="text-white max-w-xl px-8">
          <h1
            class="text-2xl md:text-3xl font-semibold my-6 bg-gradient-to-r from-[#f8ad00] via-[#dc363a] to-[#3992ff] bg-clip-text text-transparent"
          >
            Sistema de operación Triaso® − Relief
          </h1>
          <p class="text-[#393939] font-semibold leading-relaxed">
            Ofrecemos una forma práctica y eficiente de gestionar el
            funcionamiento de nuestros equipos. Gracias a sistemas avanzados de
            monitoreo y automatización, <span class="text-black"
              >simplificamos tanto el manejo de los equipos como el trabajo de
              la tripulación.
            </span> Control total de cada etapa de la producción, con un seguimiento
            completo de todos los datos operativos.
          </p>
          <div class="pt-5 flex items-center justify-center">
            <a
              href="/Relief"
              aria-label="View page drum Mixers"
              class="text-white text-center mb-5 mt-5 text-xs md:text-sm font-normal border-2 border-[#14427c] rounded-full py-2 px-6 transition-all duration-300 ease-out transform hover:scale-110 hover:shadow-lg bg-[#14427c] hover:bg-white hover:text-black hover:border-white"
            >
              Ver más
            </a>
          </div>
        </div>

        <!-- Imagen -->
        <div class="flex justify-end relative">
          <Image
            src={OSHand}
            alt="Triaso OS"
            class="w-[280px] md:w-[360px] lg:w-[420px]"
          />
        </div>
      </div>

      <Slider client:only />
    </div>
  </section>

  <!-- Sección abajo -->
  <section>
    <div class="bg-[#272526]">
      <div
        class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 md:grid-cols-2 items-center justify-center"
      >
        <div class="pt-5">
          <Image
            src="https://placehold.co/600x400/png"
            alt="Placeholder"
            width={600}
            height={400}
            class="rounded-2xl"
          />
        </div>
        <div class="flex flex-col justify-center mx-auto">
          <div>
            <h1 class="text-center text-white">
              Control integrado del flujo de RAP
            </h1>
          </div>
          <div class="flex justify-center items-center"><LearnBtnBlue /></div>
        </div>

        <div class="flex flex-col justify-center mx-auto">
          <div>
            <h1 class="text-center text-white">
              Dosificación precisa para resultados confiables
            </h1>
          </div>
          <div class="flex justify-center items-center"><LearnBtnBlue /></div>
        </div>

        <div class="pb-5">
          <Image
            src="https://placehold.co/600x400/png"
            alt="Placeholder"
            width={600}
            height={400}
            class="rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="max-w-7xl mx-auto px-8 space-y-5 py-10">
      <!-- titulo -->
      <div class="flex flex-col space-y-5">
        <h1 class="font-bold text-3xl">Sistemas de trituración de RAP</h1>
        <p class="text-[#393939]">
          Como opción adicional para una operación completa, en Triaso ofrecemos
          sistemas de trituración integrados al sistema de RAP, capaces de
          reducir el material hasta la granulometría requerida para su mezcla.
        </p>
        <p class="text-[#393939]">
          Con control preciso de tamaño, su planta puede procesar incluso los
          lotes de RAP más difíciles de integrar, manteniendo estabilidad en la
          producción y calidad constante de la mezcla asfáltica.
        </p>
      </div>

      <!-- cards -->
      <div class="">
        <div class="max-w-7xl mx-auto">
          <div
            class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3"
            id="cardRow0"
          >
            <!-- Card 1-A -->
            <div
              class="relative rounded-lg overflow-hidden group cursor-pointer"
              data-card="0-0"
            >
              <div
                class="w-full h-80 bg-black/10 flex items-center justify-center"
              >
                <img src="https://placehold.co/600x400" alt="" />
              </div>

              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
              >
                <span
                  class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                >
                  Placeholder
                </span>
                <button
                  class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                  aria-expanded="false"
                >
                  <svg
                    class="chevron w-3 h-3 transition-transform duration-300"
                    viewBox="0 0 12 12"
                    fill="none"
                  >
                    <path
                      d="M2 4l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"></path>
                  </svg>
                  mostrar más
                </button>
                <div
                  class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                >
                  <p class="text-white/75 text-xs leading-relaxed mt-2">
                    El cribado de RAP elimina material sobredimensionado y
                    contaminantes antes del proceso. Se realiza mediante una
                    criba vibratoria integrada al sistema de RAP. Independiente
                    o integrada directamente en la tolva de RAP, sin necesidad
                    de un transportador adicional.
                  </p>
                  <ul class="list-disc pl-5">
                    <li class="text-white/75 text-xs leading-relaxed mt-2">
                      Una, dos o tres camas
                    </li>
                    <li class="text-white/75 text-xs leading-relaxed mt-2">
                      Integración directa a la tolva de RAP
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Card 1-B -->
            <div
              class="relative rounded-lg overflow-hidden group cursor-pointer"
              data-card="0-1"
            >
              <div
                class="w-full h-80 bg-black/10 flex items-center justify-center"
              >
                <img src="https://placehold.co/600x400" alt="" />
              </div>
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
              >
                <span
                  class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                >
                  Placeholder
                </span>
                <button
                  class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                  aria-expanded="false"
                >
                  <svg
                    class="chevron w-3 h-3 transition-transform duration-300"
                    viewBox="0 0 12 12"
                    fill="none"
                  >
                    <path
                      d="M2 4l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"></path>
                  </svg>
                  mostrar más
                </button>
                <div
                  class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                >
                  <p class="text-white/75 text-xs leading-relaxed mt-2">
                    Los trituradores de RAP reducen material sobredimensionado.
                    Se instalan en la descarga de la criba de RAP y pueden
                    operar en un sistema de recirculación cerrada para un
                    control preciso del tamaño.
                  </p>
                  <ul class="list-disc pl-5">
                    <li class="text-white/75 text-xs leading-relaxed mt-2">
                      Recirculación cerrada
                    </li>
                    <li class="text-white/75 text-xs leading-relaxed mt-2">
                      Integración directa a la tolva de RAP
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Card 1-C -->
            <div
              class="relative rounded-lg overflow-hidden group cursor-pointer"
              data-card="0-2"
            >
              <div
                class="w-full h-80 bg-black/10 flex items-center justify-center"
              >
                <img src="https://placehold.co/600x400" alt="" />
              </div>
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
              >
                <span
                  class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                >
                  Transportador
                </span>
                <button
                  class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                  aria-expanded="false"
                >
                  <svg
                    class="chevron w-3 h-3 transition-transform duration-300"
                    viewBox="0 0 12 12"
                    fill="none"
                  >
                    <path
                      d="M2 4l4 4 4-4"
