---
import SecondWhatsBtn from "../../unitComponents/SecondWhatsBtn.astro";
import Whatsbtn from "../../unitComponents/Whatsbtn.astro";
---

<div
  class="w-full bg-[url(/Boxes.webp)] bg-cover bg-center h-[350px] md:h-[35vh] mt-16"
>
  <div class="w-full h-full flex justify-center bg-white/40 py-10">
    <div
      class="grid grid-cols-1 md:grid-cols-3 px-8 gap-10 justify-center items-center max-w-7xl h-full"
    >
      <div class="w-full flex flex-col space-y-5 col-span-1 order-2 lg:order-1 ">
        
        <Whatsbtn />

        <a
          href=""
          target="_blank"
          rel="noopener noreferrer"
          class="w-full"
        >
          <div
            class="bg-white flex flex-row items-center justify-center w-full rounded-full py-2 gap-1 shadow-md hover:bg-verdeWhats/80"
          >
            <div class="mx-5">
              <p class="text-black text-[13px] lg:text-lg">Cotizar un equipo</p>
            </div>
          </div>
        </a>
      </div>


      <div class="col-span-1 md:col-span-2 w-full text-end order-1 lg:order-2">
        <h1 class="text-2xl md:text-3xl text-black font-bold">
          SERVICIO AL CLIENTE 24/7
        </h1>
        <h2 class="text-lg md:text-xl uppercase text-black font-bold">
          Nuestro equipo está disponible todo el día, listo para asistirle en
          cualquier momento, incluso fines de semana y días festivos.
        </h2>
      </div>
    </div>
  </div>
</div>
