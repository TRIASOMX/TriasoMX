---
import logo1 from "../../assets/images/IntegralAsphalt/14.svg";
import logo2 from "../../assets/images/IntegralAsphalt/15.svg";
import logo3 from "../../assets/images/IntegralAsphalt/16.svg";
import logo4 from "../../assets/images/IntegralAsphalt/17.svg";
import logo5 from "../../assets/images/IntegralAsphalt/18.svg";
import Image from "astro/components/Image.astro";
---

<div class="w-full flex flex-col items-center justify-center max-w-7xl mx-auto px-4 mt-10 font-bold">
  <div class="bg-white flex flex-col items-center justify-center rounded-md p-4 mb-10 w-full">
    <h1 class="text-2xl lg:text-4xl text-center mt-4 mb-8">
        Todo lo que necesita en una sola unidad
    </h1>
    <p class="text-[#14427c] text-sm mb-5 text-center lg:text-xl md:text-lg">
        Vaya directamente al sitio de trabajo, sin necesidad de cama baja ni cama plana, 
        eliminando los elevados costos de transporte.
    </p>

    <div class="relative w-full overflow-hidden" id="slider-wrapper">
      <div class="flex gap-4 transition-transform duration-500 ease-in-out" id="slider-track">

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px] relative overflow-hidden">
          <Image src={logo1} alt="Icon 1" class="absolute inset-0 w-full h-full object-contain z-0" />
          <div class="relative z-10 text-center">
            <h2 class="text-lg lg:text-2xl border-b-2 border-b-blueMain pb-4 mb-4 text-grisT">
                Ideal para proyectos pequeños, trabajos de bacheo, recapeos y sellos premezclados
            </h2>
            <p class="font-normal text-grisT text-justify">
                Su diseño compacto y operación eficiente la hacen adecuada para producir mezcla asfáltica bajo demanda de forma rápida y rentable.
            </p>
          </div>
        </div>

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px] relative overflow-hidden">
          <Image src={logo2} alt="Icon 2" class="absolute inset-0 w-full h-full object-contain z-0" />
          <div class="relative z-10 text-center">
            <h2 class="text-lg lg:text-2xl border-b-2 border-b-redBg pb-4 mb-4 text-grisT">
                Produzca su mezcla asfáltica directamente en el sitio, eliminando la necesidad de transportar material.
            </h2>
            <p class="font-normal text-grisT text-justify">
                Elimine la necesidad de transportarla desde plantas externas. Esto reduce costos logísticos, agiliza la ejecución de los trabajos y garantiza que la mezcla se coloque fresca y a la temperatura adecuada.
            </p>
          </div>
        </div>

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px] relative overflow-hidden">
          <Image src={logo3} alt="Icon 3" class="absolute inset-0 w-full h-full object-contain z-0" />
          <div class="relative z-10 text-center">
            <h2 class="text-lg lg:text-2xl border-b-2 border-b-redBg pb-4 mb-4 text-grisT">
                Cero emisiones, listo para funcionar en cualquier ciudad.
            </h2>
            <p class="font-normal text-grisT text-justify">
                La planta integral de asfalto de 10 TPH es una solución ecológica y de bajas emisiones para proyectos urbanos, que cumple con estrictas normas medioambientales.
            </p>
          </div>
        </div>

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px] flex flex-col items-center justify-center text-center">
          <Image src={logo4} alt="Icon 4" class="w-1/2 mb-4" />
          <h2 class="text-grisT text-lg lg:text-2xl">Producción continua <br /> durante 10 horas</h2>
          <p class="font-normal text-grisT text-base lg:text-lg">con el tanque lleno</p>
        </div>

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px] relative overflow-hidden">
          <Image src={logo5} alt="Icon 5" class="absolute inset-0 w-full h-full object-contain z-0" />
          <div class="relative z-10 text-center">
            <h2 class="text-lg lg:text-2xl border-b-2 border-b-blueMain pb-4 mb-4 text-grisT">
                No dependas de los proveedores locales de hormigón para los trabajos pequeños.
            </h2>
            <p class="font-normal text-grisT text-justify">
                Deje de depender de los proveedores locales de mezclas y obtenga un control total sobre su producción de mezclas en caliente.
            </p>
          </div>
        </div>

        <div class="slider-card shrink-0 bg-bgMain rounded-2xl p-4 min-h-[350px]">
          <h2 class="text-lg lg:text-2xl text-grisT mb-2 text-center">Drum Mixer Flights</h2>
          <p class="border-b-2 border-b-redBg pb-4 mb-4 font-normal text-grisT text-center">
            Pistas convencionales, como en cualquier mezcladora de tambor de capacidad estándar
          </p>
          <ul class="text-blueMain font-normal list-disc pl-6 text-start w-full">
            <li>Inlet Flights</li>
            <li>Drying Veiling Flights</li>
            <li>Radiation Flights</li>
            <li>Heating Flights</li>
            <li>Mixing Flights</li>
          </ul>
        </div>

      </div>
    </div>

    <div class="flex items-center justify-center gap-4 mt-6">
      <button id="slider-prev" class="w-9 h-9 rounded-full border border-gray-300 flex items-center justify-center text-grisT hover:bg-gray-100 transition">&#8592;</button>
      <div id="slider-dots" class="flex gap-2"></div>
      <button id="slider-next" class="w-9 h-9 rounded-full border border-gray-300 flex items-center justify-center text-grisT hover:bg-gray-100 transition">&#8594;</button>
    </div>

    <div class=" px-8 py-4  mt-8">
      <h2 class="text-center lg:text-lg text-base font-bold">
        Reduce los costos de producción en la fabricación de asfalto en pequeños volúmenes mediante la optimización de los arranques, la minimización del consumo de combustible y la reducción de los gastos de mano de obra y transporte.
      </h2>
    </div>
  </div>
</div>

<script>
  const wrapper = document.getElementById("slider-wrapper")!;
  const track = document.getElementById("slider-track")!;
  const dotsEl = document.getElementById("slider-dots")!;
  const prevBtn = document.getElementById("slider-prev")!;
  const nextBtn = document.getElementById("slider-next")!;

  const originalCards = Array.from(track.querySelectorAll(".slider-card")) as HTMLElement[];
  const total = originalCards.length;
  let current = 0;
  let isTransitioning = false;

  function getVisible() {
    return window.innerWidth >= 768 ? 2 : 1;
  }

  function getCardWidth() {
    const vis = getVisible();
    const gap = 16;
    return (wrapper.offsetWidth - gap * (vis - 1)) / vis + gap;
  }

  function buildSlider() {
    const vis = getVisible();
    track.querySelectorAll(".clone").forEach(c => c.remove());
    originalCards.forEach(c => {
      const vis2 = getVisible();
      const gap = 16;
      c.style.width = `${(wrapper.offsetWidth - gap * (vis2 - 1)) / vis2}px`;
    });
    const clonesBefore = originalCards.slice(-vis).map(c => {
      const cl = c.cloneNode(true) as HTMLElement;
      cl.classList.add("clone");
      return cl;
    });
    const clonesAfter = originalCards.slice(0, vis).map(c => {
      const cl = c.cloneNode(true) as HTMLElement;
      cl.classList.add("clone");
      return cl;
    });

    clonesBefore.forEach(c => track.prepend(c));
    clonesAfter.forEach(c => track.append(c));

    track.querySelectorAll(".slider-card, .clone").forEach((c) => {
      const vis2 = getVisible();
      const gap = 16;
      (c as HTMLElement).style.width = `${(wrapper.offsetWidth - gap * (vis2 - 1)) / vis2}px`;
    });

    dotsEl.innerHTML = Array.from({length: total}, (_, i) =>
      `<button class="w-2 h-2 rounded-full transition-colors ${i === current ? 'bg-[#14427c]' : 'bg-gray-300'}" data-i="${i}"></button>`
    ).join("");
    dotsEl.querySelectorAll("button").forEach(d => {
      d.addEventListener("click", () => goTo(Number((d as HTMLElement).dataset.i)));
    });

    setTranslate(vis + current, false);
  }

  function setTranslate(idx: number, animate: boolean) {
    track.style.transition = animate ? "transform 0.45s cubic-bezier(0.4,0,0.2,1)" : "none";
    track.style.transform = `translateX(-${getCardWidth() * idx}px)`;
  }

  function updateDots() {
    dotsEl.querySelectorAll("button").forEach((d, i) => {
      d.className = `w-2 h-2 rounded-full transition-colors ${i === current ? 'bg-[#14427c]' : 'bg-gray-300'}`;
    });
  }

  function goTo(idx: number) {
    if (isTransitioning) return;
    const vis = getVisible();
    current = ((idx % total) + total) % total;
    isTransitioning = true;
    setTranslate(vis + current, true);
    updateDots();
    setTimeout(() => { isTransitioning = false; }, 460);
  }

  function step(dir: number) {
    if (isTransitioning) return;
    const vis = getVisible();
    const next = current + dir;
    isTransitioning = true;
    setTranslate(vis + next, true);

    setTimeout(() => {
      if (next < 0) { current = total - 1; setTranslate(vis + current, false); }
      else if (next >= total) { current = 0; setTranslate(vis + current, false); }
      else { current = next; }
      updateDots();
      isTransitioning = false;
    }, 460);
  }

  prevBtn.addEventListener("click", () => step(-1));
  nextBtn.addEventListener("click", () => step(1));

  // Touch / swipe
  let startX = 0;
  wrapper.addEventListener("touchstart", e => { startX = e.touches[0].clientX; });
  wrapper.addEventListener("touchend", e => {
    const dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 40) step(dx < 0 ? 1 : -1);
  });

  buildSlider();
  window.addEventListener("resize", buildSlider);
</script>