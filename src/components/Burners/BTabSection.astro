---
import preH from "../../assets/images/Burners/preHeat.webp";
import preH2 from "../../assets/images/Burners/preHeat2.webp";
import preH2Low from "../../assets/images/Burners/Low/preHeat2Low.webp";
import Tred from "../../assets/images/AsphaltStorage/redT.webp";
import TwoColumnSection from "../unitComponents/TwoColumnSection.astro";
import batch from "../../assets/images/Burners/batch.webp";
import ficha from "../../assets/images/Burners/ficha.webp";
import world from "../../assets/images/Burners/world.webp";
import elevador2 from "../../assets/images/Burners/Elevador2.webp";
import elevador2Low from "../../assets/images/Burners/Low/Elevador2Low.webp";
import escudo1 from "../../assets/images/Burners/251022-Escudo.webp";
import QmdorSil from "../../assets/images/Burners/QmdorSil.webp";
import { Image } from "astro:assets";
import imgtab1 from "../../assets/images/Burners/14.webp";
import imgtab1Low from "../../assets/images/Burners/Low/14Low.webp";
import poster1 from "../../assets/images/Burners/Gallery/B1.webp";
import SmartVideo from "../unitComponents/SmartVideo";
import poster2 from "../../assets/images/Burners/preHeat.webp";
import PlaCQuemadorLow from "../../assets/images/Burners/Low/PlaC QuemadorLow.webp";
import flag from "../../assets/images/Burners/flag.svg";

import img1 from "../../assets/images/FuelPreHeaters/FPH4.webp"
import img2 from "../../assets/images/Burners/Filtro.webp"
import img3 from "../../assets/images/FuelPreHeaters/Gallery/PREH1.webp"
---

<section class="w-full flex 2 mt-6 md:mt-20 flex-col gap-4 bg-gray-100">
  <div class="flex flex-col gap-4 mt-8">
    <div
      role="tablist"
      aria-label="Characteristics tabs"
      class="flex w-full max-w-7xl mx-auto px-4 gap-2 sm:gap-4"
    >
      <button
        class="tab-button-1 flex-1 py-3 px-2 font-bold text-xs sm:text-sm md:text-xl text-center leading-tight focus:outline-none"
        data-tab="tab1"
        role="tab"
        aria-selected="true"
      >
        Desempeño y eficiencia de
        <span class="hidden md:block"></span>
        combustión
      </button>

      <button
        class="tab-button-1 flex-1 py-3 px-2 font-bold text-xs sm:text-sm md:text-xl text-center leading-tight focus:outline-none"
        data-tab="tab2"
        role="tab"
        aria-selected="false"
      >
        Calidad de la mezcla asfáltica y
        <span class="hidden md:block"></span>
        protección del equipo
      </button>

      <button
        class="tab-button-1 flex-1 py-3 px-2 font-bold text-xs sm:text-sm md:text-xl text-center leading-tight focus:outline-none"
        data-tab="tab3"
        role="tab"
        aria-selected="false"
      >
        Personalización para adaptarse a
        <span class="hidden md:block"></span>
        necesidades específicas del cliente
      </button>
    </div>

    <div class="py-4">
      <!-- First Section -->
      <div
        class="w-full flex flex-col items-center justify-center gap-4 mt-4 tab-content-1 text-base md:text-lg text-grisT"
        data-tab-content="tab1"
      >
        <!-- Primera sección de la primera tab -->
        <div
          class="w-full flex flex-col items-center justify-center font-bold mt-10 md:mt-20"
        >
          <div class="max-w-7xl px-8 mx-auto flex justify-center">
            <div class="hero-img w-full md:w-4/6 lg:w-full rounded-2xl">
              <SmartVideo
                client:visible
                className="rounded-full"
                src="/Videos/Webm/bprov1.webm"
                poster={poster1.src}
                isLoop={true}
                autoplayOnMobile={false}
              />
            </div>
          </div>
          <div
            class="max-w-7xl px-8 mx-auto flex flex-col md:flex-row items-center gap-6"
          >
            <div class="w-full mt-10 md:mt-20 lg:mt-0">
              <h2 class="text-lg md:text-xl font-bold text-black">
                Tecnología Total Air: combustión completa garantizada
              </h2><br />
              <p class="text-sm lg:text-lg md:text-lg">
                Los quemadores Triaso® suministran el 100% del aire necesario
                para la combustión a través de su propio soplador, sin depender
                del escape del tambor. Esto asegura una quema eficiente del
                combustible, evita la entrada de aire frío y produce una mezcla
                asfáltica limpia, sin contaminación.
              </p>
            </div>
            <div class="w-full hidden lg:flex md:w-auto">
              <Image
                src={escudo1}
                alt=""
                class="side-img rounded-2xl will-change-transform"
              />
            </div>
          </div>
          <div
            class="flex flex-col justify-center items-center py-10 lg:hidden"
          >
            <Image src={escudo1} alt="" class="rounded-2xl w-1/2" />
          </div>
        </div>

        <!-- Banner -->
        <TwoColumnSection
          leftBg="bg-redBg"
          rightBg="bg-blueMain"
          imageSrc={Tred.src}
          imageAlt="Red T icon"
          imageWidth="150px"
        >
          <div slot="left" class="flex flex-col h-full gap-3">
            <h1 class="text-xl md:text-2xl text-white">
              Operación estable en cualquier condición
            </h1>
            <p class="text-sm lg:text-lg md:text-lg">
              A diferencia de los sistemas tradicionales, los quemadores Triaso®
              mantienen una combustión constante independientemente de la
              altitud, las condiciones meteorológicas o la hora del día. Desde
              el arranque hasta el apagado, la eficiencia se mantiene alta y
              constante.
            </p>
          </div>
          <div slot="right" class="flex flex-col justify-center gap-3">
            <h1 class="text-xl md:text-2xl">
              Tecnología Total Air -<span class="font-normal">
                combustión limpia con cualquier combustible</span
              >
            </h1>
            <p class="text-sm lg:text-lg md:text-lg">
              El precalentador licúa cualquier combustible, asegurando una
              atomización perfecta y una combustión limpia: sin humo, sin
              residuos y sin desperdicio de combustible. Permite el uso de
              cualquier tipo de combustible manteniendo un desempeño óptimo en
              todo momento.
            </p>
          </div>
        </TwoColumnSection>

        <!-- Dropdown -->
        <div
          class="w-full bg-white text-grisSubP text-base md:text-lg my-20 max-w-7xl mx-auto px-8 rounded-2xl"
        >
          <details class="mx-auto px-8 group">
            <summary
              class="relative flex justify-between items-center cursor-pointer list-none"
            >
              <h1 class="text-black font-bold text-2xl md:text-3xl">
                Sin aire extra, sin combustible extra
              </h1>
              <svg
                class="transition-transform duration-300 group-open:rotate-180 ml-auto"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                  id="SVGRepo_tracerCarrier"
                  stroke-linecap="round"
                  stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier">
                  <path
                    d="M5.70711 9.71069C5.31658 10.1012 5.31658 10.7344 5.70711 11.1249L10.5993 16.0123C11.3805 16.7927 12.6463 16.7924 13.4271 16.0117L18.3174 11.1213C18.708 10.7308 18.708 10.0976 18.3174 9.70708C17.9269 9.31655 17.2937 9.31655 16.9032 9.70708L12.7176 13.8927C12.3271 14.2833 11.6939 14.2832 11.3034 13.8927L7.12132 9.71069C6.7308 9.32016 6.09763 9.32016 5.70711 9.71069Z"
                    fill="black"></path>
                </g></svg
              >
            </summary>

            <div
              class="w-full flex flex-col justify-center items-center max-w-7xl mx-auto pt-5 gap-5"
            >
              <div>
                <Image
                  src={imgtab1Low}
                  alt="Combustion process inside the system"
                  class="rounded-lg"
                />
              </div>
              <div class="pb-5">
                <div>
                  <p class="text-sm lg:text-lg md:text-lg text-black">
                    Al controlar internamente todo el aire de combustión, los
                    quemadores Triaso® eliminan la necesidad de aire secundario
                    proveniente fuera del tambor o la chimenea. Esto reduce la
                    pérdida de calor, ahorra combustible y mejora la eficiencia
                    general de la planta; cada gota de combustible se aprovecha
                    al máximo.
                  </p>
                </div>
              </div>
            </div>
          </details>
        </div>

        <!-- Sección con bg de lado -->
        <div class="w-full space-y-3">
          <div class="w-1/5 h-[2px] bg-redBg"></div>
          <div class="w-1/6 h-[2px] bg-blueMain"></div>
        </div>
        <div class="bg-bgBeige w-full -skew-y-2">
          <div
            class="w-full grid grid-cols-1 md:grid-cols-2 gap-10 mt-10 max-w-7xl px-8 mx-auto skew-y-2 py-20"
          >
            <div class="">
              <h2 class="text-lg md:text-xl font-bold text-black text-center">
                Sin humo. Sin residuos. Sin fallas prematuras.
              </h2><br />
              <p class="text-sm lg:text-lg md:text-lg font-thin">
                Los quemadores mal diseñados dejan partículas sin quemar, humo y
                pérdidas de calor que afectan tanto la mezcla como el equipo.
                Triaso® elimina estos problemas con un control de combustión
                avanzado.
              </p>
            </div>
            <div>
              <h2 class="text-lg md:text-xl font-bold text-black text-center">
                Queme combustible de bajo costo sin desperdicio
              </h2><br />
              <p class="text-sm lg:text-lg md:text-lg font-thin">
                Incluso con combustibles pesados o de baja calidad, los
                quemadores Triaso® aseguran una correcta atomización y una
                combustión completa. El precalentador integrado reduce la
                viscosidad del combustible, evitando gotas sin quemar,
                disminuyendo la contaminación y los costos de operación.
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- Second Section -->
      <div class="hidden tab-content-1" data-tab-content="tab2">
        <div
          class="w-full max-w-[2400px] mx-auto grid grid-cols-1 lg:flex items-center justify-center gap-4 mt-4 text-base md:text-lg text-grisT"
        >
          <div class="w-full order-2 md:order-1">
            <Image
              src={elevador2Low}
              alt="Adaptable lifts in action"
              class="w-3/4"
            />
          </div>
          <div class="w-full order-1 md:order-2">
            <div class="w-full lg:w-3/4 px-8 mx-auto gap-10 justify-center">
              <div class="w-full flex flex-col gap-3">
                <div class="w-full grid grid-cols-3">
                  <div class="w-full">
                    <p>Consistent</p>
                    <h2
                      class="text-2xl lg:text-4xl md:text-4xl text-redBg font-bold"
                    >
                      Flama
                    </h2>
                  </div>
                  <div class="w-full">
                    <p>Consistent</p>
                    <h2
                      class="text-2xl lg:text-4xl md:text-4xl text-blueMain font-bold"
                    >
                      Mezcla
                    </h2>
                  </div>
                  <div class="w-full">
                    <p>Consistent</p>
                    <h2
                      class="text-2xl lg:text-4xl md:text-4xl text-grisT font-bold"
                    >
                      Calidad
                    </h2>
                  </div>
                </div>
                <div>
                  <p class="text-sm lg:text-lg md:text-lg">
                    Las fluctuaciones en el desempeño del quemador generan un
                    calentamiento inconsistente, lo que afecta directamente la
                    mezcla asfáltica. Los quemadores Triaso® mantienen una flama
                    estable y uniforme que asegura que cada lote se mezcle a la
                    temperatura correcta, protegiendo tanto la durabilidad del
                    pavimento como los componentes de la planta del estrés
                    térmico.
                  </p>
                </div>
                <div class="w-full text-black pt-10">
                  <h2 class="text-xl md:text-2xl text-black font-bold">
                    Proteja
                  </h2>
                  <p class="text-sm lg:text-lg md:text-lg font-thin">
                    sus filtros
                  </p>
                  <h2 class="text-xl md:text-2xl text-black font-bold">
                    prevenga riesgos de quemado
                  </h2>
                  <p class="text-sm lg:text-lg md:text-lg font-thin">
                    El combustible no quemado puede obstruir los filtros de
                    bolsas, aumentar el mantenimiento e incluso generar riesgos
                    de incendio. Con los quemadores Triaso®, la combustión
                    completa evita la acumulación de residuos, manteniendo los
                    filtros limpios y la operación segura.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="w-full bg-blueMain py-10">
          <div
            class="relative w-full max-w-7xl px-8 mx-auto bg-[url('/public/LogoTriasoUs.webp')] bg-contain bg-center bg-no-repeat"
          >
            <div class="absolute inset-0 bg-[#14427c]/70"></div>

            <div class="relative z-10">
              <h1 class="text-white text-2xl md:text-4xl font-bold text-center">
                Mezcla más limpia, pavimento más duradero
              </h1>
              <br />
              <p class="text-grisSubP text-sm lg:text-lg md:text-lg font-bold">
                La combustión incompleta contamina la mezcla asfáltica con
                combustible sin quemar, reduciendo la vida del pavimento.
                Nuestros quemadores Triaso® evitan este problema, al asegurar
                una combustión limpia protegiendo su inversión, su planta de
                asfalto y la mezcla que entregará.
              </p>
            </div>
          </div>
        </div>
        <div
          class="grid grid-cols-1 md:grid-cols-2 justify-center items-center pl-8 pt-8 max-w-[2400px]"
        >
          <div class="w-full mx-auto flex flex-col items-end">
            <div class="w-full md:w-3/5">
              <h2
                class="text-[#393939] text-xl md:text-3xl font-bold text-start"
              >
                Silenciador para quemador para
              </h2>
              <h1 class="text-2xl md:text-5xl font-bold text-start">
                operación silenciosa
              </h1><br />
              <p class="w-full text-sm lg:text-xl md:text-xl">
                Operación silenciosa para cumplir con normas estrictas de bajo
                ruido, reduciendo el ruido del quemador y permitiendo operar la
                planta de asfalto en zonas urbanas o ubicaciones con
                regulaciones acústicas exigentes.
              </p>
            </div>
          </div>
          <div class="flex justify-end items-end">
            <Image src={QmdorSil} alt="Burner muffler" class="w-1/2" />
          </div>
        </div>
      </div>
    </div>

    <!-- Third Section -->
    <div
      class="w-full flex flex-col mt-4 tab-content-1 hidden text-base md:text-lg text-grisT font-bold"
      data-tab-content="tab3"
    >
      <div
        class="w-full flex flex-col justify-center items-center px-8 bg-gradient-to-t from-grisT to-bgMain min-h-[200px] space-y-10"
      >
        <div class="w-full">
          <div class="w-full max-w-7xl mx-auto">
            <div class="w-full bg-white rounded-2xl p-8">
              <div class="w-full md:w-3/4 justify-center m-auto">
                <SmartVideo
                  client:visible
                  src="/Videos/Webm/AnPreHeat.webm"
                  poster={poster2.src}
                  autoplayOnMobile={false}
                  isLoop={true}
                />
              </div>
              <div class="lg:px-20 text-center">
                <h2 class="text-lg md:text-xl font-bold text-black">
                  Precalentador incluido – sin costo adicional
                </h2>
                <p class="text-sm lg:text-lg md:text-lg">
                  Desde 2014, todos los tambores Triaso® incluyen un
                  precalentador integrado de serie. Esto incrementa la
                  eficiencia de combustión al reducir la viscosidad del
                  combustible y mejorar la atomización, sin aumentar su
                  presupuesto.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h1 class="text-bgBeige text-2xl md:text-4xl font-bold text-center">
            Para equipos duraderos, elija componentes <br /> diseñados para adaptarse
            a sus necesidades
          </h1>
        </div>
      </div>
      <div class="w-full bg-grisT">
        <div
          class="w-full max-w-7xl justify-center items-center bg-grisT px-8 mx-auto grid grid-cols-1 md:grid-cols-2"
        >
          <div class="w-full flex justify-center items-center">
            <Image src={preH} alt="Preheater" class="w-1/2" />
          </div>
          <div
            class="w-full text-white flex flex-col justify-center items-center"
          >
            <div
              class="w-full flex gap-3 justify-between lg:justify-center items-center"
            >
              <h2 class="text-xl md:text-2xl lg:text-end">
                Eficiente y <br />responsable con el <br />medio ambiente
              </h2>
              <Image src={world} alt="World icon" class="w-[120px]" />
            </div>
            <div class="lg:w-1/2 flex justify-center items-center">
              <p class="text-start text-sm lg:text-lg md:text-lg font-thin">
                Con una combustión completa del combustible y menores emisiones
                de NOx, los quemadores Triaso® cumplen con normas ambientales
                estrictas. Se reduce el consumo de combustible y se logra una
                operación más limpia sin afectar el desempeño.
              </p>
            </div>
          </div>
        </div>
      </div>







      <!-- slider -->
      <div class="bg-[#393939] p-10">
        <div
          class="card-row grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-7xl mx-auto px-8"
          id="cardRow0"
        >
          <!-- Card 1-A -->
          <div
            class="relative rounded-lg overflow-hidden group cursor-pointer"
            data-card="0-0"
          >
            <div
              class="w-full h-96 bg-black/10 flex items-center justify-center"
            >
              <img src={img1.src} alt="" />
            </div>

            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
            >
              <span
                class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
              >
                Calentamiento eléctrico en línea para máxima eficiencia
              </span>
              <button
                class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                aria-expanded="false"
              >
                <svg
                  class="chevron w-3 h-3 transition-transform duration-300"
                  viewBox="0 0 12 12"
                  fill="none"
                >
                  <path
                    d="M2 4l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"></path>
                </svg>
                mostrar más
              </button>
              <div
                class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
              >
                <p class="text-white/75 text-xs leading-relaxed mt-2">
                  El precalentador de combustible utiliza un sistema de
                  resistencias eléctricas en línea capaz de elevar la
                  temperatura del combustible en 40°C, con cualquier caudal.
                  Este calentamiento rápido y controlado reduce de inmediato la
                  viscosidad del combustible, asegurando una atomización óptima
                  y una combustión limpia, sin retrasos ni fuentes externas de
                  calor.
                </p>
                <p class="text-white/75 text-xs leading-relaxed mt-2">
                  Solución compacta y confiable para un desempeño eficiente del
                  quemador desde el primer segundo de operación.
                </p>
              </div>
            </div>
          </div>

          <!-- Card 1-B -->
          <div
            class="relative rounded-lg overflow-hidden group cursor-pointer"
            data-card="0-1"
          >
            <div
              class="w-full h-96 bg-black/20 flex items-center justify-center"
            >
              <img src={img2.src} alt="" />
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
            >
              <span
                class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
              >
                Filtro de combsutible
              </span>
              <button
                class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                aria-expanded="false"
              >
                <svg
                  class="chevron w-3 h-3 transition-transform duration-300"
                  viewBox="0 0 12 12"
                  fill="none"
                >
                  <path
                    d="M2 4l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"></path>
                </svg>
                mostrar más
              </button>
              <div
                class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
              >
                <p class="text-white/75 text-xs leading-relaxed mt-2">
                  Todos los sistemas de precalentamiento Triaso incluyen un
                  filtro calibre malla 100 para captar toda la fibra celulosa
                  presente en combustibles alternos o impurezas adicionales que
                  puedan dañar el sistema.
                </p>
                <p class="text-white/75 text-xs leading-relaxed mt-2">
                  Los combustibles alternos contienen mucha fibra de celulosa o
                  impurezas adicionales, al no ser filtrada anteriormente tapan
                  el sistema de atomización del quemador.
                </p>

                <ul class="list-disc">
                  <li class="pl-5 text-white/75 text-xs leading-relaxed mt-2">
                    Al llegar al quemador tapan la boquilla de atomización y más
                    sistemas del quemador, lo que causará muchos problemas
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Card 1-C -->
          <div
            class="relative rounded-lg overflow-hidden group cursor-pointer"
            data-card="0-2"
          >
            <div
              class="w-full h-96 bg-black/10 flex items-center justify-center"
            >
              <img src={img3.src} alt="" />
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
            >
              <span
                class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
              >
                Estándar en cada planta, no como un extra costoso
              </span>
              <button
                class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                aria-expanded="false"
              >
                <svg
                  class="chevron w-3 h-3 transition-transform duration-300"
                  viewBox="0 0 12 12"
                  fill="none"
                >
                  <path
                    d="M2 4l4 4 4-4"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"></path>
                </svg>
                mostrar más
              </button>
              <div
                class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
              >
                <p class="text-white/75 text-xs leading-relaxed mt-2">
                  Otras marcas ofrecen quemadores de aire total y
                  precalentadores como accesorios costosos. En Triaso®, vienen
                  incluidos como parte del equipo estándar en cada configuración
                  de planta, porque la combustión limpia no debería ser
                  opcional.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

