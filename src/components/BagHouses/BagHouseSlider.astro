---
import { Image } from "astro:assets";
import venturiSys from "../../assets/images/BagHouses/venturiSys.webp";
import ratioSys from "../../assets/images/BagHouses/ratioSys.webp";
import img1 from "../../assets/images/BagHouses/BHoppers.webp"
import img2 from "../../assets/images/BagHouses/finesReturn.webp"
import img3 from "../../assets/images/BagHouses/BoquillasVL.webp"
---

<section class="bg-[#393939] py-6">
    <div class="max-w-7xl mx-auto px-8">
        <div class="relative">
            <div
                class="card-track grid grid-cols-1 lg:grid-cols-3 md:grid-cols-3 gap-3"
                id="cardRow0"
            >
                <!-- Card 1-A -->
                <div
                    class="card-slide relative rounded-lg overflow-hidden group cursor-pointer"
                    data-card="0-0"
                >
                    <div
                        class="w-full h-80 bg-black/10 flex items-center justify-center"
                    >
                        <img src={img1.src} alt="" />
                    </div>
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                    >
                        <span
                            class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                        >
                            Tolva de finos
                        </span>
                        <button
                            class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                            aria-expanded="false"
                        >
                            <svg
                                class="chevron w-3 h-3 transition-transform duration-300"
                                viewBox="0 0 12 12"
                                fill="none"
                            >
                                <path
                                    d="M2 4l4 4 4-4"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"></path>
                            </svg>
                            mostrar más
                        </button>
                        <div
                            class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                        >
                            <p
                                class="text-white/75 text-xs leading-relaxed mt-2"
                            >
                                Posicionadas directamente debajo de la casa de
                                bolsas, estas tolvas permiten la recolección
                                controlada de finos, que pueden almacenarse
                                temporalmente, descargarse o reincorporarse a la
                                mezcla asfáltica según la configuración de la
                                planta. Una cámara de separación reduce la
                                velocidad del aire para que más material caiga a
                                la tolva, mientras que los deflectores internos
                                distribuyen el aire uniformemente y protegen las
                                mangas.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Card 1-B -->
                <div
                    class="card-slide relative rounded-lg overflow-hidden group cursor-pointer"
                    data-card="0-1"
                >
                    <div
                        class="w-full h-80 bg-black/10 flex items-center justify-center"
                    >
                        <img src={img2.src} alt="" />
                    </div>
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                    >
                        <span
                            class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                        >
                            Sistema de retorno de finos
                        </span>
                        <button
                            class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                            aria-expanded="false"
                        >
                            <svg
                                class="chevron w-3 h-3 transition-transform duration-300"
                                viewBox="0 0 12 12"
                                fill="none"
                            >
                                <path
                                    d="M2 4l4 4 4-4"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"></path>
                            </svg>
                            mostrar más
                        </button>
                        <div
                            class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                        >
                            <p
                                class="text-white/75 text-xs leading-relaxed mt-2"
                            >
                                Una vez que se recolectan los finos en las
                                tolvas, una serie de tornillos transportadores
                                reintegran al tambor mezclador, justo donde se
                                inyecta el asfalto líquido, asegurando que los
                                finos se integren a la mezcla. Evitando que
                                vuelvan a dispersarse en el aire, reduciendo la
                                pérdida de material y mejorando la calidad y
                                durabilidad de la mezcla asfáltica. Este proceso
                                optimiza el uso de recursos, mejora el desempeño
                                ambiental y reduce costos de operación.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Card 1-C -->
                <div
                    class="card-slide relative rounded-lg overflow-hidden group cursor-pointer"
                    data-card="0-2"
                >
                    <div
                        class="w-full h-80 bg-black/10 flex items-center justify-center"
                    >
                        <img src={img3.src} alt="" class="object-cover" />
                    </div>
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-3"
                    >
                        <span
                            class="font-bold text-white text-sm uppercase tracking-wide leading-tight mb-2"
                        >
                            Boquillas Triaso supersónicas
                        </span>
                        <button
                            class="mostrar-mas flex items-center gap-1 text-white/80 text-xs hover:text-white transition-colors"
                            aria-expanded="false"
                        >
                            <svg
                                class="chevron w-3 h-3 transition-transform duration-300"
                                viewBox="0 0 12 12"
                                fill="none"
                            >
                                <path
                                    d="M2 4l4 4 4-4"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"></path>
                            </svg>
                            mostrar más
                        </button>
                        <div
                            class="expandible max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
                        >
                            <p
                                class="text-white/75 text-xs leading-relaxed mt-2"
                            >
                                Nuestras boquillas supersónicas se fabrican
                                internamente mediante impresión 3D con
                                aleaciones de carbono, ofreciendo alta
                                resistencia a impactos, temperaturas elevadas y
                                vibraciones. Esto asegura una captación
                                altamente eficiente de partículas finas en el
                                filtro de mangas.
                            </p>
                            <div
                                class="rounded-2xl border border-white flex justify-center items-center w-1/2 mt-2"
                            >
                                <button
                                    id="btn-detalles"
                                    class="text-white text-xs leading-relaxed py-1 px-3 w-full"
                                >
                                    Todos los detalles técnicos
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="slider-dots" class="hidden justify-center gap-2 mt-4">
            <button
                class="dot w-2 h-2 rounded-full bg-[#dc2626] transition-opacity"
                data-index="0"
                aria-label="Ir a slide 1"></button>
            <button
                class="dot w-2 h-2 rounded-full bg-white/40 transition-opacity"
                data-index="1"
                aria-label="Ir a slide 2"></button>
            <button
                class="dot w-2 h-2 rounded-full bg-white/40 transition-opacity"
                data-index="2"
                aria-label="Ir a slide 3"></button>
        </div>
    </div>
</section>

<div
    id="modal-detalles"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-titulo"
>
    <div
        class="relative max-w-2xl w-full max-h-[85vh] overflow-y-auto shadow-2xl space-y-5"
    >
        <button
            id="modal-close"
            class="absolute top-8 right-3 text-gray-400 hover:text-gray-700 transition-colors"
            aria-label="Cerrar modal"
        >
            <svg viewBox="0 0 16 16" fill="none" class="w-5 h-5">
                <path
                    d="M2 2l12 12M14 2L2 14"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"></path>
            </svg>
        </button>

        <div class="p-6 bg-[#fffaea] rounded-2xl">
            <h2
                id="modal-titulo"
                class="font-bold text-lg text-gray-900 uppercase tracking-wide mb-4"
            >
                Sistema venturi tipico
            </h2>
            <div
                class="flex flex-col lg:flex-row justify-center items-center gap-3"
            >
                <div class="">
                    <Image src={venturiSys} alt="Sistema Venturi" />
                </div>
                <div class="space-y-2 lg:w-full lg:max-w-7xl">
                    <p class="text-gray-600 text-xs leading-relaxed">
                        En los sistemas de filtración con venturi, el diseño del
                        flujo de aire introduce varias ineficiencias que afectan
                        tanto la captación de polvo como la durabilidad del
                        sistema. El flujo de alta velocidad al salir del venturi
                        genera una zona de baja presión en la parte superior de
                        la manga, atrayendo el polvo hacia esa área. Esto
                        provoca una acumulación desigual y reduce la capacidad
                        de filtración. Con el tiempo, las partículas finas se
                        incrustan profundamente en la tela, haciendo menos
                        efectiva la limpieza.
                    </p>

                    <p class="text-gray-600 text-xs leading-relaxed">
                        Otro problema es la ubicación del pulso de aire de
                        limpieza cerca de la boca de la manga. Esta posición
                        limita su capacidad de inducir aire adicional que
                        ayudaría a remover el polvo. Además, el venturi angosto
                        acelera el aire filtrado hacia el plenum, generando un
                        flujo ascendente que se opone al pulso de limpieza. Como
                        resultado, se requieren pulsos más intensos, aumentando
                        el consumo de energía y el esfuerzo mecánico sobre las
                        mangas, lo que acelera su desgaste y reduce su vida
                        útil.
                    </p>
                </div>
            </div>
        </div>
        <div class="p-6 bg-[#bfbfbf] rounded-2xl">
            <div class="flex lg:justify-end lg:items-end">
                <h2
                    id="modal-titulo"
                    class="font-bold text-lg text-gray-900 uppercase tracking-wide mb-4"
                >
                    Sistema supersónico Triaso
                </h2>
            </div>
            <div class="flex flex-col lg:flex-row gap-3">
                <div class="space-y-2 lg:w-full lg:max-w-7xl">
                    <p class="text-gray-600 text-xs leading-relaxed">
                        Nuestro nuevo modelo de casa de bolsas mejora la captura
                        de finos al rediseñar completamente el flujo de aire. En
                        lugar de utilizar un sistema tradicional de venturi,
                        usamos una boquilla supersónica convergente-divergente
                        para generar el chorro de limpieza. Induciendo una mayor
                        cantidad de aire secundario, aumentando la eficiencia de
                        limpieza. Además, al eliminar el venturi se reduce la
                        velocidad en la entrada de la manga, evitando la presión
                        negativa que normalmente provoca acumulación de polvo en
                        la parte superior.
                    </p>
                    <p class="text-gray-600 text-xs leading-relaxed">
                        Al aprovechar completamente la boca de la manga, el
                        chorro de aire se expande de forma uniforme, reduciendo
                        el riesgo de desprendimientos bruscos finos en la manga.
                        Inflando la manga de manera más uniforme, logrando un
                        ciclo de limpieza más efectivo y menor desgaste del
                        material. Como resultado, el modelo Triaso requiere solo
                        la mitad del área de filtración en comparación con
                        sistemas tradicionales con venturi, permitiendo un alto
                        desempeño en un diseño más compacto.
                    </p>
                </div>

                <div class="">
                    <Image src={ratioSys} alt="Sistema Venturi" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @media (max-width: 767px) {
        .card-track {
            display: flex !important;
            overflow-x: scroll;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none; 
            gap: 0 !important;
        }
        .card-track::-webkit-scrollbar {
            display: none;
        }
        .card-slide {
            flex: 0 0 100%;
            scroll-snap-align: start;
     
        }
    }
</style>

<script>
    document
        .querySelectorAll<HTMLButtonElement>(".mostrar-mas")
        .forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const expandible = btn.nextElementSibling as HTMLElement;
                const chevron = btn.querySelector(".chevron") as HTMLElement;
                const isOpen =
                    expandible.style.maxHeight &&
                    expandible.style.maxHeight !== "0px";

                if (isOpen) {
                    expandible.style.maxHeight = "0px";
                    chevron.style.transform = "rotate(0deg)";
                    btn.setAttribute("aria-expanded", "false");
                } else {
                    expandible.style.maxHeight = expandible.scrollHeight + "px";
                    chevron.style.transform = "rotate(180deg)";
                    btn.setAttribute("aria-expanded", "true");
                }
            });
        });


    const track = document.querySelector<HTMLElement>(".card-track")!;
    const slides = Array.from(
        document.querySelectorAll<HTMLElement>(".card-slide"),
    );
    const dots = document.querySelectorAll<HTMLButtonElement>(".dot");
    const dotsWrapper = document.getElementById("slider-dots")!;
    const arrows = document.querySelectorAll<HTMLElement>(".slider-arrow");

    const total = slides.length;

    function isMobile() {
        return window.innerWidth < 768;
    }


    function getCurrentIndex(): number {
        const slideWidth = track.offsetWidth;
        return Math.round(track.scrollLeft / slideWidth);
    }

    function updateDots(index: number) {
        dots.forEach((dot, i) => {
            dot.classList.toggle("bg-[#dc2626]", i === index);
            dot.classList.toggle("bg-white/40", i !== index);
        });
    }

    function goTo(index: number) {
        const clamped = Math.max(0, Math.min(index, total - 1));
        const slideWidth = track.offsetWidth;
        track.scrollTo({ left: clamped * slideWidth, behavior: "smooth" });
    }

    function initSlider() {
        if (isMobile()) {
            dotsWrapper.classList.remove("hidden");
            dotsWrapper.classList.add("flex");
            arrows.forEach((a) => {
                a.classList.remove("hidden");
                a.classList.add("flex");
            });
        } else {
            dotsWrapper.classList.add("hidden");
            dotsWrapper.classList.remove("flex");
            arrows.forEach((a) => {
                a.classList.add("hidden");
                a.classList.remove("flex");
            });
        }
    }


    track.addEventListener(
        "scroll",
        () => {
            if (isMobile()) updateDots(getCurrentIndex());
        },
        { passive: true },
    );

    dots.forEach((dot) => {
        dot.addEventListener("click", () => goTo(Number(dot.dataset.index)));
    });

    initSlider();
    window.addEventListener("resize", initSlider);

    /* ── Modal ── */
    const modal = document.getElementById("modal-detalles")!;
    const modalClose = document.getElementById("modal-close")!;
    const btnDetalles = document.getElementById("btn-detalles")!;

    function openModal() {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        document.body.style.overflow = "hidden";
    }

    function closeModal() {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        document.body.style.overflow = "";
    }

    btnDetalles.addEventListener("click", (e) => {
        e.stopPropagation();
        openModal();
    });

    modalClose.addEventListener("click", closeModal);

    modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>
