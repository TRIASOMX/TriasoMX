          aria-label="See previous item"
          id="prev"
          class="hidden md:flex flex-shrink-0 w-16 h-16 rounded-full border-[3px] border-black items-center justify-center hover:bg-gray-300 transition group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-8 h-8 text-black group-hover:scale-110 transition-transform"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
          </svg>
        </button>

        <div class="w-full overflow-hidden relative">
          <div
            id="slider"
            class="flex transition-transform duration-500 ease-in-out items-stretch"
            style={`width: ${items.length * 100}%`}
          >
            {
              items.map((item, index) => (
                <div
                  class="w-full flex-shrink-0 px-4 md:px-12"
                  style={`width: ${100 / items.length}%`}
                >
                  <div class="h-[420px] md:h-[320px] overflow-y-auto overscroll-contain pr-2">
                    <div class="flex flex-col gap-6">
                      <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
                        <div class="flex-shrink-0 bg-[#14427c] text-white w-10 h-12 lg:w-12 lg:h-14 md:w-12 md:h-14 flex items-center justify-center text-3xl font-medium rounded-md">
                          {item.id}
                        </div>
                        <h1 class="text-[#14427c] text-lg lg:text-2xl md:text-2xl font-bold leading-snug">
                          {item.title}
                        </h1>
                      </div>

                      <div class="text-black text-sm md:text-lg lg:text-lg leading-relaxed md:pl-16 min-h-[180px]">
                        <p>{item.text}</p>

                        {item.list && (
                          <ul class="list-disc pl-5 mt-4 space-y-2">
                            {item.list.map((li) => (
                              <li class="text-black">{li}</li>
                            ))}
                          </ul>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <button
          aria-label="See next item"
          id="next"
          class="hidden md:flex flex-shrink-0 w-16 h-16 rounded-full border-[3px] border-black items-center justify-center hover:bg-gray-300 transition group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-8 h-8 text-black group-hover:scale-110 transition-transform"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </button>
      </div>

      <div class="flex justify-center gap-4 mt-8 md:hidden lg:hidden">
        <button
          id="prev-mobile"
          aria-label="See next item"
          class="px-4 py-2 bg-gray-300 rounded">←</button
        >
        <button
          id="next-mobile"
          aria-label="See previous item"
          class="px-4 py-2 bg-gray-300 rounded">→</button
        >
      </div>
    </div>
  </div>
</div>

<script>
  let index = 0;
  const slider = document.getElementById("slider");
  const total = slider.children.length;

  function moveSlider() {
    slider.style.transform = `translateX(-${index * 10}%)`;
  }

  document.getElementById("next").addEventListener("click", () => {
    index = (index + 1) % total;
    moveSlider();
  });

  document.getElementById("prev").addEventListener("click", () => {
    index = (index - 1 + total) % total;
    moveSlider();
  });

  document.getElementById("next-mobile").addEventListener("click", () => {
    index = (index + 1) % total;
    moveSlider();
  });

  document.getElementById("prev-mobile").addEventListener("click", () => {
    index = (index - 1 + total) % total;
    moveSlider();
  });
</script>
